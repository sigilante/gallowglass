-- Compiler: Self-hosting Gallowglass compiler
--
-- Milestone 8: Compiles restricted Gallowglass to PLAN seeds.
-- Single monolithic file (no cross-module imports in restricted dialect).
--
-- Phases: Utilities → Lexer → Parser → Scope → Codegen → Emit → Main
--
-- All arithmetic uses opcodes 0–4 only (pure recursive fallback).
-- External ops deferred to optimization pass after self-hosting.

external mod Core.PLAN {
  inc   : Nat → Nat
  unpin : Nat → Nat
}

external mod Core.IO.Prim {
  write_op : Nat → Nat
}

-- =====================================================================
-- Section 1: Core Types
-- =====================================================================

-- Pair: generic two-element product
type Pair a b =
  | MkPair a b

-- Result: success or failure
type Result a b =
  | Ok a
  | Err b

-- Option: value that may or may not be present
type Option a =
  | None
  | Some a

-- List: singly-linked list
type List a =
  | Nil
  | Cons a (List a)

-- =====================================================================
-- Section 2: Boolean Operations
-- =====================================================================

let not : Bool → Bool
  = λ b → if b then False else True

let and : Bool → Bool → Bool
  = λ a b → if a then b else False

let or : Bool → Bool → Bool
  = λ a b → if a then True else b

-- =====================================================================
-- Section 3: Nat Arithmetic (opcodes 0–4 only)
-- =====================================================================

-- pred: predecessor; pred 0 = 0
let pred : Nat → Nat
  = λ n → match n {
    | 0 → 0
    | k → k
  }

-- is_zero: True if n is zero
let is_zero : Nat → Bool
  = λ n → match n {
    | 0 → True
    | _ → False
  }

-- nat_eq: structural equality by simultaneous descent
let nat_eq : Nat → Nat → Bool
  = λ m n → match m {
    | 0 → match n { | 0 → True  | _ → False }
    | j → match n { | 0 → False | k → nat_eq j k }
  }

-- nat_lt: m < n?
let nat_lt : Nat → Nat → Bool
  = λ m n → match n {
    | 0 → False
    | k → match m { | 0 → True | j → nat_lt j k }
  }

-- lte: m <= n?
let lte : Nat → Nat → Bool
  = λ m n → match m {
    | 0 → True
    | j → match n { | 0 → False | k → lte j k }
  }

-- gte: m >= n?
let gte : Nat → Nat → Bool
  = λ m n → lte n m

-- add: addition by recursion on second arg
let add : Nat → Nat → Nat
  = λ m n → match n {
    | 0 → m
    | k → Core.PLAN.inc (add m k)
  }

-- sub: saturating subtraction
let sub : Nat → Nat → Nat
  = λ m n → match n {
    | 0 → m
    | k → match m {
      | 0 → 0
      | j → sub j k
    }
  }

-- mul: multiplication by recursion on second arg
let mul : Nat → Nat → Nat
  = λ m n → match n {
    | 0 → 0
    | k → add m (mul m k)
  }

-- div_go: division loop helper
-- PLAN kal eagerly evaluates the zero handler of Case_, so the recursive
-- call must be in the succ branch (lazy, wrapped in a law).
-- lte b a returns 1 when b <= a (continue), 0 when b > a (stop).
-- Matching on (lte b a): zero branch = base case (safe), succ = recurse (lazy).
let div_go : Nat → Nat → Nat → Nat
  = λ a b acc → match (lte b a) {
    | 0 → acc
    | k → div_go (sub a b) b (Core.PLAN.inc acc)
  }

-- div_nat: integer division (repeated subtraction)
-- div_nat a b = floor(a / b), with div_nat _ 0 = 0
let div_nat : Nat → Nat → Nat
  = λ a b → match b {
    | 0 → 0
    | bpred → div_go a b 0
  }

-- mod_go: modulus loop — same strategy as div_go
let mod_go : Nat → Nat → Nat
  = λ a b → match (lte b a) {
    | 0 → a
    | k → mod_go (sub a b) b
  }

-- mod_nat: modulus (remainder after division)
-- mod_nat a b = a mod b, with mod_nat _ 0 = 0
let mod_nat : Nat → Nat → Nat
  = λ a b → match b {
    | 0 → 0
    | bpred → mod_go a b
  }

-- max_nat: maximum of two nats
let max_nat : Nat → Nat → Nat
  = λ a b → if nat_lt a b then b else a

-- min_nat: minimum of two nats
let min_nat : Nat → Nat → Nat
  = λ a b → if nat_lt a b then a else b

-- =====================================================================
-- Section 4: Bitwise Operations (from div/mod by powers of 2)
-- =====================================================================

-- pow2: compute 2^n by repeated doubling
let pow2 : Nat → Nat
  = λ n → match n {
    | 0 → 1
    | k → mul 2 (pow2 k)
  }

-- bit_and: bitwise AND via decomposition
-- bit_and 0 _ = 0, bit_and _ 0 = 0
-- bit_and a b = (a%2 * b%2) + 2 * bit_and(a/2, b/2)
let bit_and : Nat → Nat → Nat
  = λ a b → match a {
    | 0 → 0
    | ap → match b {
      | 0 → 0
      | bp → add (mul (mod_nat a 2) (mod_nat b 2))
                  (mul 2 (bit_and (div_nat a 2) (div_nat b 2)))
    }
  }

-- bit_or: bitwise OR via decomposition
-- bit_or a b = (a%2 | b%2) + 2 * bit_or(a/2, b/2)
-- where (x | y) for single bits = if x then 1 else y
let bit_or : Nat → Nat → Nat
  = λ a b → match a {
    | 0 → b
    | ap → match b {
      | 0 → a
      | bp → add (if nat_eq (mod_nat a 2) 1 then 1 else mod_nat b 2)
                  (mul 2 (bit_or (div_nat a 2) (div_nat b 2)))
    }
  }

-- shift_right: arithmetic right shift (= div by 2^k)
let shift_right : Nat → Nat → Nat
  = λ n k → div_nat n (pow2 k)

-- shift_left: left shift (= mul by 2^k)
let shift_left : Nat → Nat → Nat
  = λ n k → mul n (pow2 k)

-- =====================================================================
-- Section 5: List Operations
-- =====================================================================

-- length: count elements
let length : ∀ a. List a → Nat
  = λ xs → match xs {
    | Nil        → 0
    | Cons _ rest → Core.PLAN.inc (length rest)
  }

-- map: apply f to every element
let map : ∀ a b. (a → b) → List a → List b
  = λ f xs → match xs {
    | Nil        → Nil
    | Cons x rest → Cons (f x) (map f rest)
  }

-- filter: keep elements satisfying predicate
let filter : ∀ a. (a → Bool) → List a → List a
  = λ p xs → match xs {
    | Nil        → Nil
    | Cons x rest →
        if p x
        then Cons x (filter p rest)
        else filter p rest
  }

-- foldl: left fold (tail-recursive)
let foldl : ∀ a b. (b → a → b) → b → List a → b
  = λ f acc xs → match xs {
    | Nil        → acc
    | Cons x rest → foldl f (f acc x) rest
  }

-- foldr: right fold
let foldr : ∀ a b. (a → b → b) → b → List a → b
  = λ f z xs → match xs {
    | Nil        → z
    | Cons x rest → f x (foldr f z rest)
  }

-- reverse: reverse a list
let reverse : ∀ a. List a → List a
  = λ xs → foldl (λ acc x → Cons x acc) Nil xs

-- append: concatenate two lists
let append : ∀ a. List a → List a → List a
  = λ xs ys → foldr (λ x acc → Cons x acc) ys xs

-- singleton: wrap a single value in a list
let singleton : ∀ a. a → List a
  = λ x → Cons x Nil

-- nth: get the nth element (0-indexed), or a default
let nth : ∀ a. a → Nat → List a → a
  = λ default n xs → match xs {
    | Nil → default
    | Cons x rest → match n {
      | 0 → x
      | k → nth default k rest
    }
  }

-- take: take the first n elements
let take : ∀ a. Nat → List a → List a
  = λ n xs → match n {
    | 0 → Nil
    | k → match xs {
      | Nil → Nil
      | Cons x rest → Cons x (take k rest)
    }
  }

-- drop: drop the first n elements
let drop : ∀ a. Nat → List a → List a
  = λ n xs → match n {
    | 0 → xs
    | k → match xs {
      | Nil → Nil
      | Cons _ rest → drop k rest
    }
  }

-- concat_list: flatten a list of lists
let concat_list : ∀ a. List (List a) → List a
  = λ xss → foldr append Nil xss

-- zip: pair up elements from two lists
let zip : ∀ a b. List a → List b → List (Pair a b)
  = λ xs ys → match xs {
    | Nil → Nil
    | Cons x xrest → match ys {
      | Nil → Nil
      | Cons y yrest → Cons (MkPair x y) (zip xrest yrest)
    }
  }

-- any: True if any element satisfies the predicate
let any : ∀ a. (a → Bool) → List a → Bool
  = λ p xs → match xs {
    | Nil → False
    | Cons x rest → if p x then True else any p rest
  }

-- all: True if all elements satisfy the predicate
let all : ∀ a. (a → Bool) → List a → Bool
  = λ p xs → match xs {
    | Nil → True
    | Cons x rest → if p x then all p rest else False
  }

-- =====================================================================
-- Section 6: Association List Operations
-- =====================================================================

-- assoc_lookup: find a value by key (nat equality)
let assoc_lookup : ∀ a. Nat → List (Pair Nat a) → Option a
  = λ key kvs → match kvs {
    | Nil → None
    | Cons kv rest → match kv {
      | MkPair k v → if nat_eq key k then Some v else assoc_lookup key rest
    }
  }

-- assoc_remove: remove all entries with a given key
let assoc_remove : ∀ a. Nat → List (Pair Nat a) → List (Pair Nat a)
  = λ key kvs → match kvs {
    | Nil → Nil
    | Cons kv rest → match kv {
      | MkPair k v →
          if nat_eq key k
          then assoc_remove key rest
          else Cons kv (assoc_remove key rest)
    }
  }

-- assoc_insert: insert or update a key-value pair
let assoc_insert : ∀ a. Nat → a → List (Pair Nat a) → List (Pair Nat a)
  = λ key val kvs → Cons (MkPair key val) (assoc_remove key kvs)

-- assoc_keys: extract all keys
let assoc_keys : ∀ a. List (Pair Nat a) → List Nat
  = λ kvs → map (λ kv → match kv { | MkPair k _ → k }) kvs

-- assoc_has : check if key exists
let assoc_has : ∀ a. Nat → List (Pair Nat a) → Bool
  = λ key kvs → match kvs {
    | Nil → False
    | Cons kv rest → match kv {
      | MkPair k _ → if nat_eq key k then True else assoc_has key rest
    }
  }

-- =====================================================================
-- Section 7: Byte-level Operations (Nat encoding)
-- =====================================================================
--
-- Bytes in PLAN: a nat where byte i is at bits [i*8 .. i*8+7].
-- byte_at(content, i) = (content >> (i*8)) & 0xFF
-- We track byte length separately as a Pair: MkPair byte_length content_nat.
-- This is the representation type "Bytes" in this compiler.

-- byte_at: extract byte at index i from a content nat
let byte_at : Nat → Nat → Nat
  = λ content idx → bit_and (shift_right content (mul 8 idx)) 255

-- bytes_length: get the byte length from a Bytes pair
let bytes_length : Pair Nat Nat → Nat
  = λ bytes → match bytes { | MkPair len _ → len }

-- bytes_content: get the content nat from a Bytes pair
let bytes_content : Pair Nat Nat → Nat
  = λ bytes → match bytes { | MkPair _ content → content }

-- bytes_at: extract byte at index from a Bytes pair
let bytes_at : Pair Nat Nat → Nat → Nat
  = λ bytes idx → byte_at (bytes_content bytes) idx

-- bytes_empty: the empty byte string
let bytes_empty : Pair Nat Nat
  = MkPair 0 0

-- bytes_singleton: a single byte
let bytes_singleton : Nat → Pair Nat Nat
  = λ b → MkPair 1 (bit_and b 255)

-- bytes_concat: concatenate two byte strings
-- content = b_content | (a_content << (b_len * 8))
-- Wait — little-endian nat encoding means bytes[0] is the LSB.
-- So concat(a, b) should produce a||b where a's bytes come first (lower indices).
-- a = [a0, a1, ...], b = [b0, b1, ...]
-- result = [a0, a1, ..., b0, b1, ...]
-- content = a_content | (b_content << (a_len * 8))
let bytes_concat : Pair Nat Nat → Pair Nat Nat → Pair Nat Nat
  = λ a b →
      let a_len = bytes_length a in
      let a_content = bytes_content a in
      let b_content = bytes_content b in
      let new_len = add a_len (bytes_length b) in
      let new_content = bit_or a_content (shift_left b_content (mul 8 a_len)) in
      MkPair new_len new_content

-- bytes_slice: extract a sub-range [start, start+len)
let bytes_slice : Pair Nat Nat → Nat → Nat → Pair Nat Nat
  = λ bytes start len →
      let content = bytes_content bytes in
      let shifted = shift_right content (mul 8 start) in
      MkPair len shifted

-- bytes_eq: equality of two byte strings
let bytes_eq : Pair Nat Nat → Pair Nat Nat → Bool
  = λ a b →
      if nat_eq (bytes_length a) (bytes_length b)
      then nat_eq (bytes_content a) (bytes_content b)
      else False

-- nat_to_u8: truncate a nat to a single byte
let nat_to_u8 : Nat → Nat
  = λ n → bit_and n 255

-- u64_le: encode a nat as 8 bytes little-endian (Bytes pair)
let u64_le : Nat → Pair Nat Nat
  = λ n → MkPair 8 (bit_and n (sub (pow2 64) 1))

-- =====================================================================
-- Section 8: Name Encoding
-- =====================================================================

-- name_to_nat: encode a string (already stored as a content nat) as-is.
-- In PLAN, text IS a nat with the UTF-8 bytes packed little-endian.
-- This is the identity function on the content nat representation.
let name_to_nat : Nat → Nat
  = λ n → n

-- =====================================================================
-- Section 9: Compiler-specific Types (for later phases)
-- =====================================================================

-- Token type (lexer output)
type Token =
  | TkNat Nat
  | TkText Nat
  | TkIdent Nat
  | TkLParen
  | TkRParen
  | TkLBrace
  | TkRBrace
  | TkBar
  | TkArrow
  | TkBackArrow
  | TkEqual
  | TkColon
  | TkDot
  | TkComma
  | TkAt
  | TkBacktick
  | TkLet
  | TkType
  | TkMatch
  | TkIf
  | TkThen
  | TkElse
  | TkExternal
  | TkMod
  | TkIn
  | TkFix
  | TkLambda
  | TkForall
  | TkUnderscore
  | TkEof
  | TkErr Nat
  | TkClass
  | TkInstance
  | TkEff
  | TkHandle
  | TkPure
  | TkRun

-- AST types (parser output)
-- Note: constructors are limited to arity ≤ 2 (bootstrap codegen restriction).
-- 3-field nodes use a nested Pair for the last two fields.
type Expr =
  | EVar Nat
  | EApp Expr Expr
  | ELam Nat Expr
  | ELet Nat (Pair Expr Expr)       -- name, (rhs, body)
  | ENat Nat
  | EIf Expr (Pair Expr Expr)       -- cond, (then_, else_)
  | EMatch Expr (List MatchArm)
  | EPin Nat (Pair Expr Expr)       -- name, (rhs, body)
  | EFix Nat (Pair (List Nat) Expr)  -- self_name, (params, body)
  | EHandle Expr (Pair Expr (List (Pair Nat (Pair Nat Expr))))  -- comp, (return_body, op_arms)
  | EDo Nat (Pair Expr Expr)        -- bind_name, (rhs, body)

type MatchArm =
  | ArmNat Nat Expr
  | ArmVar Nat Expr
  | ArmCon Nat (Pair (List Nat) Expr)   -- con_name, (field_names, body)

type Decl =
  | DLet Nat Expr
  | DType Nat (List ConDef)
  | DExt Nat (List Nat)
  | DClass Nat (List Nat)
  | DInst Nat (Pair Nat (List (Pair Nat Expr)))
  | DEff Nat (List Nat)

type ConDef =
  | MkConDef Nat Nat

-- PLAN value (codegen output)
-- PLaw: arity ≤ 2 restriction; name_nat and arity are nested in a Pair.
type PlanVal =
  | PNat Nat
  | PApp PlanVal PlanVal
  | PLaw Nat (Pair Nat PlanVal)     -- name_nat, (arity, body)
  | PPin PlanVal

-- Compilation environment (4 fields → nested Pairs)
-- globals : List (Pair Nat PlanVal)
-- locals  : List (Pair Nat Nat)
-- arity   : Nat
-- self_ref: Option Nat
type CEnv =
  | MkCEnv (Pair (List (Pair Nat PlanVal)) (List (Pair Nat Nat))) (Pair Nat (Option Nat))

-- =====================================================================
-- End of M8.1: Core Utilities
-- =====================================================================

-- =====================================================================
-- Section 10: Byte Classification Helpers
-- =====================================================================

-- is_digit: 1 if byte b is ASCII '0'-'9'
let is_digit : Nat → Nat
  = λ b →
      match (lte 0x30 b) {
        | 0 → 0
        | k → lte b 0x39
      }

-- is_upper: 1 if byte b is ASCII 'A'-'Z'
let is_upper : Nat → Nat
  = λ b →
      match (lte 0x41 b) {
        | 0 → 0
        | k → lte b 0x5A
      }

-- is_lower: 1 if byte b is ASCII 'a'-'z'
let is_lower : Nat → Nat
  = λ b →
      match (lte 0x61 b) {
        | 0 → 0
        | k → lte b 0x7A
      }

-- is_alpha: 1 if byte b is ASCII letter
let is_alpha : Nat → Nat
  = λ b →
      match (is_upper b) {
        | 0 → is_lower b
        | k → 1
      }

-- is_alnum_or_under: 1 if byte b is alphanumeric or underscore
let is_alnum_or_under : Nat → Nat
  = λ b →
      match (is_digit b) {
        | 0 →
            match (is_alpha b) {
              | 0 → nat_eq b 95
              | k → 1
            }
        | k → 1
      }

-- is_hex_digit: 1 if b is 0-9, a-f, A-F
let is_hex_digit : Nat → Nat
  = λ b →
      match (is_digit b) {
        | 0 →
            match (lte 0x61 b) {
              | 0 →
                  match (lte 0x41 b) {
                    | 0 → 0
                    | k → lte b 0x46
                  }
              | k → lte b 0x66
            }
        | k → 1
      }

-- hex_digit_val: value of a hex digit byte (0-15)
let hex_digit_val : Nat → Nat
  = λ b →
      match (is_digit b) {
        | 0 →
            match (is_lower b) {
              | 0 → sub b 0x37   -- 'A'=0x41, val = b - 0x41 + 10 = b - 0x37
              | k → sub b 0x57   -- 'a'=0x61, val = b - 0x61 + 10 = b - 0x57
            }
        | k → sub b 0x30
      }

-- =====================================================================
-- Section 11: Keyword Nat Constants
-- Each keyword is its UTF-8 bytes packed little-endian into a Nat.
-- =====================================================================

-- Each keyword is its UTF-8 bytes packed little-endian into a Nat.
-- Byte order: first char at bits [7:0], second at [15:8], etc.

let kw_let          : Nat = 0x74656C           -- "let"
let kw_type         : Nat = 0x65707974         -- "type"
let kw_match        : Nat = 0x686374616D       -- "match"
let kw_if           : Nat = 0x6669             -- "if"
let kw_then         : Nat = 0x6E656874         -- "then"
let kw_else         : Nat = 0x65736C65         -- "else"
let kw_external     : Nat = 0x6C616E7265747865  -- "external"
let kw_mod          : Nat = 0x646F6D           -- "mod"
let kw_in           : Nat = 0x6E69             -- "in"
let kw_fn           : Nat = 0x6E66             -- "fn"  (ASCII alt for λ)
let kw_forall_ascii : Nat = 0x6C6C61726F66     -- "forall"
let kw_lambda_uni   : Nat = 0xBBCE             -- "λ"  (CE BB)
let kw_arrow_uni    : Nat = 0x9286E2           -- "→"  (E2 86 92)
let kw_backarrow_uni: Nat = 0x9086E2           -- "←"  (E2 86 90)
let kw_forall_uni   : Nat = 0x8088E2           -- "∀"  (E2 88 80)
let kw_underscore   : Nat = 0x5F               -- "_"
let kw_fix          : Nat = 0x786966           -- "fix"
let kw_class        : Nat = 0x7373616c63       -- "class"
let kw_instance     : Nat = 0x65636e6174736e69 -- "instance"
let kw_eff          : Nat = 0x666665           -- "eff"
let kw_handle       : Nat = 0x656c646e6168     -- "handle"
let kw_pure         : Nat = 0x65727570         -- "pure"
let kw_run          : Nat = 0x6e7572           -- "run"

-- =====================================================================
-- Section 12: LexPos Helpers
-- =====================================================================

-- LexPos is encoded as Pair Nat (Pair Nat Nat) = MkPair offset (MkPair line col)
-- This avoids a 3-field constructor which the bootstrap codegen does not support.

let lexpos_offset : Pair Nat (Pair Nat Nat) → Nat
  = λ pos →
      match pos {
        | MkPair offset lc → offset
      }

let lexpos_line : Pair Nat (Pair Nat Nat) → Nat
  = λ pos →
      match pos {
        | MkPair offset lc →
            match lc {
              | MkPair line col → line
            }
      }

let lexpos_col : Pair Nat (Pair Nat Nat) → Nat
  = λ pos →
      match pos {
        | MkPair offset lc →
            match lc {
              | MkPair line col → col
            }
      }

-- Make a LexPos from offset, line, col
let mk_lexpos : Nat → Nat → Nat → Pair Nat (Pair Nat Nat)
  = λ offset line col → MkPair offset (MkPair line col)

-- Advance offset by 1 and col by 1
let lexpos_advance : Pair Nat (Pair Nat Nat) → Pair Nat (Pair Nat Nat)
  = λ pos →
      match pos {
        | MkPair offset lc →
            match lc {
              | MkPair line col →
                  MkPair (Core.PLAN.inc offset) (MkPair line (Core.PLAN.inc col))
            }
      }

-- Advance offset by n, col by n
let lexpos_advance_n : Pair Nat (Pair Nat Nat) → Nat → Pair Nat (Pair Nat Nat)
  = λ pos n →
      match pos {
        | MkPair offset lc →
            match lc {
              | MkPair line col →
                  MkPair (add offset n) (MkPair line (add col n))
            }
      }

-- Advance offset by 1, increment line, reset col to 1
let lexpos_newline : Pair Nat (Pair Nat Nat) → Pair Nat (Pair Nat Nat)
  = λ pos →
      match pos {
        | MkPair offset lc →
            match lc {
              | MkPair line col →
                  MkPair (Core.PLAN.inc offset) (MkPair (Core.PLAN.inc line) 1)
            }
      }

-- =====================================================================
-- Section 13: Whitespace and Comment Skipping
-- =====================================================================

-- lex_skip_line: advance past bytes until newline (0x0A) or end of source.
-- The newline itself is consumed.
let lex_skip_line : Pair Nat Nat → LexPos → LexPos
  = λ src pos →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            match (nat_eq (bytes_at src (lexpos_offset pos)) 0x0A) {
              | 0 →
                  lex_skip_line src (lexpos_advance pos)
              | k → lexpos_advance pos
            }
        | k → pos
      }

-- lex_skip_ws: skip whitespace (0x20 space, 0x09 tab, 0x0D CR, 0x0A LF) and
-- line comments (--).  Returns position after last skipped char.
-- Uses deep nesting because multiple match cases cannot be flattened
-- without mutual recursion.
let lex_skip_ws : Pair Nat Nat → LexPos → LexPos
  = λ src pos →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            let b = bytes_at src (lexpos_offset pos) in
            match (nat_eq b 0x20) {
              | 0 →
                  match (nat_eq b 0x09) {
                    | 0 →
                        match (nat_eq b 0x0D) {
                          | 0 →
                              match (nat_eq b 0x0A) {
                                | 0 →
                                    -- Check for "--" comment: b must be 0x2D '-'
                                    match (nat_eq b 0x2D) {
                                      | 0 → pos
                                      | k →
                                          -- peek at next byte
                                          match (nat_eq (Core.PLAN.inc (lexpos_offset pos)) (bytes_length src)) {
                                            | 0 →
                                                match (nat_eq (bytes_at src (Core.PLAN.inc (lexpos_offset pos))) 0x2D) {
                                                  | 0 → pos
                                                  | k →
                                                      lex_skip_ws src (lex_skip_line src (lexpos_advance_n pos 2))
                                                }
                                            | k → pos
                                          }
                                    }
                                | k → lex_skip_ws src (lexpos_newline pos)
                              }
                          | k → lex_skip_ws src (lexpos_advance pos)
                        }
                    | k → lex_skip_ws src (lexpos_advance pos)
                  }
              | k → lex_skip_ws src (lexpos_advance pos)
            }
        | k → pos
      }

-- =====================================================================
-- Section 14: Identifier and Keyword Scanning
-- =====================================================================

-- lex_scan_ident_go: accumulate bytes while is_alnum_or_under.
-- Returns MkPair end_pos (MkPair byte_len ident_nat)
let lex_scan_ident_go : Pair Nat Nat → LexPos → Nat → Nat → Pair LexPos (Pair Nat Nat)
  = λ src pos ident_len ident_nat →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            match (is_alnum_or_under (bytes_at src (lexpos_offset pos))) {
              | 0 → MkPair pos (MkPair ident_len ident_nat)
              | k →
                  let b = bytes_at src (lexpos_offset pos) in
                  lex_scan_ident_go src (lexpos_advance pos)
                    (Core.PLAN.inc ident_len)
                    (bit_or ident_nat (shift_left b (mul 8 ident_len)))
            }
        | k → MkPair pos (MkPair ident_len ident_nat)
      }

-- lex_classify_ident: given (byte_len, ident_nat), return the Token.
-- Keywords map to their token; leading uppercase → TkIdent (PascalCase);
-- leading lowercase → TkIdent (snake_case) unless keyword.
-- "_" alone → TkUnderscore.
let lex_classify_ident : Nat → Nat → Token
  = λ ident_len ident_nat →
      match (nat_eq ident_nat kw_let) {
        | 0 →
            match (nat_eq ident_nat kw_type) {
              | 0 →
                  match (nat_eq ident_nat kw_match) {
                    | 0 →
                        match (nat_eq ident_nat kw_if) {
                          | 0 →
                              match (nat_eq ident_nat kw_then) {
                                | 0 →
                                    match (nat_eq ident_nat kw_else) {
                                      | 0 →
                                          match (nat_eq ident_nat kw_external) {
                                            | 0 →
                                                match (nat_eq ident_nat kw_mod) {
                                                  | 0 →
                                                      match (nat_eq ident_nat kw_in) {
                                                        | 0 →
                                                            match (nat_eq ident_nat kw_fn) {
                                                              | 0 →
                                                                  match (nat_eq ident_nat kw_forall_ascii) {
                                                                    | 0 →
                                                                        match (nat_eq ident_nat kw_underscore) {
                                                                          | 0 →
                                                                              match (nat_eq ident_nat kw_fix) {
                                                                                | 0 →
                                                                                    match (nat_eq ident_nat kw_class) {
                                                                                      | 0 →
                                                                                          match (nat_eq ident_nat kw_instance) {
                                                                                            | 0 →
                                                                                                match (nat_eq ident_nat kw_eff) {
                                                                                                  | 0 →
                                                                                                      match (nat_eq ident_nat kw_handle) {
                                                                                                        | 0 →
                                                                                                            match (nat_eq ident_nat kw_pure) {
                                                                                                              | 0 →
                                                                                                                  match (nat_eq ident_nat kw_run) {
                                                                                                                    | 0 → TkIdent ident_nat
                                                                                                                    | k → TkRun
                                                                                                                  }
                                                                                                              | k → TkPure
                                                                                                            }
                                                                                                        | k → TkHandle
                                                                                                      }
                                                                                                  | k → TkEff
                                                                                                }
                                                                                            | k → TkInstance
                                                                                          }
                                                                                      | k → TkClass
                                                                                    }
                                                                                | k → TkFix
                                                                              }
                                                                          | k → TkUnderscore
                                                                        }
                                                                    | k → TkForall
                                                                  }
                                                              | k → TkLambda
                                                            }
                                                        | k → TkIn
                                                      }
                                                  | k → TkMod
                                                }
                                            | k → TkExternal
                                          }
                                      | k → TkElse
                                    }
                                | k → TkThen
                              }
                          | k → TkIf
                        }
                    | k → TkMatch
                  }
              | k → TkType
            }
        | k → TkLet
      }

-- =====================================================================
-- Section 15: Nat Literal Scanning
-- =====================================================================

-- lex_scan_nat_dec_go: accumulate decimal digits, building up the value.
-- Returns MkPair end_pos accumulated_value
let lex_scan_nat_dec_go : Pair Nat Nat → LexPos → Nat → Pair LexPos Nat
  = λ src pos acc →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            match (is_digit (bytes_at src (lexpos_offset pos))) {
              | 0 → MkPair pos acc
              | k →
                  let d = sub (bytes_at src (lexpos_offset pos)) 0x30 in
                  lex_scan_nat_dec_go src (lexpos_advance pos) (add (mul acc 10) d)
            }
        | k → MkPair pos acc
      }

-- lex_scan_nat_hex_go: accumulate hex digits after "0x" prefix.
let lex_scan_nat_hex_go : Pair Nat Nat → LexPos → Nat → Pair LexPos Nat
  = λ src pos acc →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            match (is_hex_digit (bytes_at src (lexpos_offset pos))) {
              | 0 → MkPair pos acc
              | k →
                  let d = hex_digit_val (bytes_at src (lexpos_offset pos)) in
                  lex_scan_nat_hex_go src (lexpos_advance pos) (add (mul acc 16) d)
            }
        | k → MkPair pos acc
      }

-- =====================================================================
-- Section 16: Text Literal Scanning
-- =====================================================================

-- lex_scan_text_go: accumulate bytes inside double-quoted string.
-- Handles \" escape only; other bytes included as-is.
-- Returns MkPair end_pos (MkPair byte_len content_nat)
-- Caller must have already consumed the opening '"'.
let lex_scan_text_go : Pair Nat Nat → LexPos → Nat → Nat → Pair LexPos (Pair Nat Nat)
  = λ src pos tlen tnat →
      match (nat_eq (lexpos_offset pos) (bytes_length src)) {
        | 0 →
            match (nat_eq (bytes_at src (lexpos_offset pos)) 0x22) {   -- '"'
              | 0 →
                  -- Check for backslash escape
                  match (nat_eq (bytes_at src (lexpos_offset pos)) 0x5C) {  -- '\'
                    | 0 →
                        let b = bytes_at src (lexpos_offset pos) in
                        lex_scan_text_go src (lexpos_advance pos)
                          (Core.PLAN.inc tlen)
                          (bit_or tnat (shift_left b (mul 8 tlen)))
                    | k →
                        -- backslash: consume next byte literally
                        match (nat_eq (Core.PLAN.inc (lexpos_offset pos)) (bytes_length src)) {
                          | 0 →
                              let b2 = bytes_at src (Core.PLAN.inc (lexpos_offset pos)) in
                              lex_scan_text_go src (lexpos_advance_n pos 2)
                                (Core.PLAN.inc tlen)
                                (bit_or tnat (shift_left b2 (mul 8 tlen)))
                          | k →
                              -- backslash at end of file: produce error token
                              MkPair pos (MkPair tlen tnat)
                        }
                  }
              | k →
                  -- closing '"': consume it
                  MkPair (lexpos_advance pos) (MkPair tlen tnat)
            }
        | k →
            -- end of file inside string: return what we have
            MkPair pos (MkPair tlen tnat)
      }

-- =====================================================================
-- Section 17: Single Token Dispatch
-- =====================================================================

-- lex_one: consume one token starting at pos (after whitespace is skipped).
-- Returns MkPair token end_pos.
-- Multi-byte Unicode operators are handled by inspecting the lead byte.
-- Precondition: pos is within bounds (caller has checked).
let lex_one : Pair Nat Nat → LexPos → Pair Token LexPos
  = λ src pos →
      let b = bytes_at src (lexpos_offset pos) in
      let pos1 = lexpos_advance pos in
      -- Digits
      match (is_digit b) {
        | 0 →
            -- Identifiers / keywords
            match (is_alpha b) {
              | 0 →
                  match (nat_eq b 0x5F) {           -- '_'
                    | 0 →
                        -- Punctuation and operators
                        match (nat_eq b 0x28) {           -- '('
                          | 0 →
                              match (nat_eq b 0x29) {     -- ')'
                                | 0 →
                                    match (nat_eq b 0x7B) {   -- '{'
                                      | 0 →
                                          match (nat_eq b 0x7D) {   -- '}'
                                            | 0 →
                                                match (nat_eq b 0x7C) {   -- '|'
                                                  | 0 →
                                                      match (nat_eq b 0x3D) {   -- '='
                                                        | 0 →
                                                            match (nat_eq b 0x3A) {   -- ':'
                                                              | 0 →
                                                                  match (nat_eq b 0x2E) {   -- '.'
                                                                    | 0 →
                                                                        match (nat_eq b 0x2C) {   -- ','
                                                                          | 0 →
                                                                              match (nat_eq b 0x40) {   -- '@'
                                                                                | 0 →
                                                                                    match (nat_eq b 0x60) {   -- '`'
                                                                                      | 0 →
                                                                                          match (nat_eq b 0x22) {   -- '"'
                                                                                            | 0 →
                                                                                                -- 0xE2: lead byte for → ← ∀
                                                                                                match (nat_eq b 0xE2) {
                                                                                                  | 0 →
                                                                                                      -- 0xCE: lead byte for λ
                                                                                                      match (nat_eq b 0xCE) {
                                                                                                        | 0 →
                                                                                                            -- Unknown byte: emit error token
                                                                                                            MkPair (TkErr b) pos1
                                                                                                        | k →
                                                                                                            -- λ = CE BB (2 bytes)
                                                                                                            MkPair TkLambda (lexpos_advance pos1)
                                                                                                      }
                                                                                                  | k →
                                                                                                      -- E2 xx xx: 3-byte sequence for → ← ∀
                                                                                                      -- Collect as LE nat: b | (b2 << 8) | (b3 << 16)
                                                                                                      let b2 = bytes_at src (lexpos_offset pos1) in
                                                                                                      let b3 = bytes_at src (Core.PLAN.inc (lexpos_offset pos1)) in
                                                                                                      let seq = bit_or b (bit_or (shift_left b2 8) (shift_left b3 16)) in
                                                                                                      let pos3 = lexpos_advance_n pos 3 in
                                                                                                      match (nat_eq seq kw_arrow_uni) {
                                                                                                        | 0 →
                                                                                                            match (nat_eq seq kw_backarrow_uni) {
                                                                                                              | 0 →
                                                                                                                  match (nat_eq seq kw_forall_uni) {
                                                                                                                    | 0 → MkPair (TkErr b) pos3
                                                                                                                    | k → MkPair TkForall pos3
                                                                                                                  }
                                                                                                              | k → MkPair TkBackArrow pos3
                                                                                                            }
                                                                                                        | k → MkPair TkArrow pos3
                                                                                                      }
                                                                                                }
                                                                                            | k →
                                                                                                -- Text literal
                                                                                                let tr = lex_scan_text_go src pos1 0 0 in
                                                                                                match tr {
                                                                                                  | MkPair end_pos tpair →
                                                                                                      match tpair {
                                                                                                        | MkPair tlen tnat →
                                                                                                            MkPair (TkText tnat) end_pos
                                                                                                      }
                                                                                                }
                                                                                          }
                                                                                      | k → MkPair TkBacktick pos1
                                                                                    }
                                                                                | k → MkPair TkAt pos1
                                                                              }
                                                                          | k → MkPair TkComma pos1
                                                                        }
                                                                    | k → MkPair TkDot pos1
                                                                  }
                                                              | k → MkPair TkColon pos1
                                                            }
                                                        | k → MkPair TkEqual pos1
                                                      }
                                                  | k → MkPair TkBar pos1
                                                }
                                            | k → MkPair TkRBrace pos1
                                          }
                                      | k → MkPair TkLBrace pos1
                                    }
                                | k → MkPair TkRParen pos1
                              }
                          | k → MkPair TkLParen pos1
                        }
                    | k →
                        -- Leading underscore: start identifier scan
                        let tr = lex_scan_ident_go src pos 0 0 in
                        match tr {
                          | MkPair end_pos ipair →
                              match ipair {
                                | MkPair ilen inat →
                                    MkPair (lex_classify_ident ilen inat) end_pos
                              }
                        }
                  }
              | k →
                  -- Leading alpha: start identifier scan
                  let tr = lex_scan_ident_go src pos 0 0 in
                  match tr {
                    | MkPair end_pos ipair →
                        match ipair {
                          | MkPair ilen inat →
                              MkPair (lex_classify_ident ilen inat) end_pos
                        }
                  }
            }
        | k →
            -- Digit: check for 0x/0X hex prefix
            match (nat_eq b 0x30) {           -- '0'
              | 0 →
                  -- Non-zero digit: decimal scan starting with value (b - '0')
                  let tr = lex_scan_nat_dec_go src pos1 (sub b 0x30) in
                  match tr {
                    | MkPair end_pos n → MkPair (TkNat n) end_pos
                  }
              | k →
                  -- '0': peek at next byte for 'x'/'X'
                  match (nat_eq (lexpos_offset pos1) (bytes_length src)) {
                    | 0 →
                        match (nat_eq (bytes_at src (lexpos_offset pos1)) 0x78) {   -- 'x'
                          | 0 →
                              match (nat_eq (bytes_at src (lexpos_offset pos1)) 0x58) {   -- 'X'
                                | 0 →
                                    -- plain '0' (or '0' followed by non-x digit)
                                    MkPair (TkNat 0) pos1
                                | k →
                                    -- '0X': hex literal
                                    let tr = lex_scan_nat_hex_go src (lexpos_advance pos1) 0 in
                                    match tr {
                                      | MkPair end_pos n → MkPair (TkNat n) end_pos
                                    }
                              }
                          | k →
                              -- '0x': hex literal
                              let tr = lex_scan_nat_hex_go src (lexpos_advance pos1) 0 in
                              match tr {
                                | MkPair end_pos n → MkPair (TkNat n) end_pos
                              }
                        }
                    | k → MkPair (TkNat 0) pos1
                  }
            }
      }

-- =====================================================================
-- Section 18: Main Lex Loop
-- =====================================================================

-- lex: tokenize src starting at (offset, line, col).
-- Returns a List Token ending with TkEof.
-- The list is built lazily via cons; each call processes one token.
let lex : Pair Nat Nat → Nat → Nat → Nat → List Token
  = λ src offset line col →
      let pos1 = lex_skip_ws src (mk_lexpos offset line col) in
      match (nat_eq (lexpos_offset pos1) (bytes_length src)) {
        | 0 →
            let tr = lex_one src pos1 in
            match tr {
              | MkPair tok pos2 →
                  Cons tok (lex src (lexpos_offset pos2) (lexpos_line pos2) (lexpos_col pos2))
            }
        | k → Cons TkEof Nil
      }

-- =====================================================================
-- End of M8.2: Lexer
-- =====================================================================


-- =====================================================================
-- Section 19: Token Helpers
-- =====================================================================

-- peek at first token without consuming
let tok_peek : List Token → Token
  = λ toks →
      match toks {
        | Nil → TkEof
        | Cons t rest → t
      }

-- consume first token, return rest
let tok_tail : List Token → List Token
  = λ toks →
      match toks {
        | Nil → Nil
        | Cons t rest → rest
      }

-- tok_is: 1 if head token equals the given nullary token value
let tok_is : List Token → Token → Nat
  = λ toks tok → nat_eq (tok_peek toks) tok

-- eat TkIdent; returns Pair name_nat rest (name_nat=0 means not found)
-- Safe sentinel: all valid ident nats are ≥ 0x30 ('0'), never 0.
let tok_eat_ident : List Token → Pair Nat (List Token)
  = λ toks →
      match (tok_peek toks) {
        | TkIdent n → MkPair n (tok_tail toks)
        | _ → MkPair 0 toks
      }

-- skip tokens until TkEqual is consumed; used to discard type annotations
let tok_skip_to_equal : List Token → List Token
  = λ toks →
      match toks {
        | Nil → Nil
        | Cons t rest →
            match (nat_eq t TkEqual) {
              | 0 → tok_skip_to_equal rest
              | k → rest
            }
      }

-- skip_ann: skip optional ": Type" annotation and consume the "="
-- If head is TkColon: skip to and including TkEqual
-- If head is TkEqual: consume it
-- Otherwise: return toks unchanged (caller handles)
let skip_ann : List Token → List Token
  = λ toks →
      match (tok_is toks TkColon) {
        | 0 → tok_tail toks
        | k → tok_skip_to_equal toks
      }

-- tok_eat_nat_token: if head is TkNat return MkPair (Some n) rest; else MkPair None toks
-- Single App arm — avoids the multi-App-arm pred_env bug in the bootstrap codegen.
let tok_eat_nat_token : List Token → Pair (Option Nat) (List Token)
  = λ toks →
      match (tok_peek toks) {
        | TkNat n → MkPair (Some n) (tok_tail toks)
        | _ → MkPair None toks
      }

-- tok_eat_text_token: if head is TkText return MkPair (Some n) rest; else MkPair None toks
-- Single App arm — avoids the multi-App-arm pred_env bug in the bootstrap codegen.
let tok_eat_text_token : List Token → Pair (Option Nat) (List Token)
  = λ toks →
      match (tok_peek toks) {
        | TkText n → MkPair (Some n) (tok_tail toks)
        | _ → MkPair None toks
      }

-- =====================================================================
-- Section 20: Qualified Name Building
-- =====================================================================

-- Count significant bytes in a nat (nat_byte_len 0 = 0)
let nat_byte_len : Nat → Nat
  = λ n →
      match (nat_eq n 0) {
        | 0 → Core.PLAN.inc (nat_byte_len (shift_right n 8))
        | k → 0
      }

-- Append a dot (0x2E) to a (len, content) name pair
let name_append_dot : Pair Nat Nat → Pair Nat Nat
  = λ nb →
      match nb {
        | MkPair len n →
            MkPair (Core.PLAN.inc len) (bit_or n (shift_left 0x2E (mul 8 len)))
      }

-- parse_qual_name_go: consume additional TkDot TkIdent segments
let parse_qual_name_go : List Token → Pair Nat Nat → Pair Nat (List Token)
  = λ toks acc →
      match toks {
        | Nil → match acc { | MkPair len n → MkPair n Nil }
        | Cons t1 rest1 →
            match (nat_eq t1 TkDot) {
              | 0 → match acc { | MkPair len n → MkPair n toks }
              | k →
                  match rest1 {
                    | Nil → match acc { | MkPair len n → MkPair n toks }
                    | Cons t2 rest2 →
                        match t2 {
                          | TkIdent part_nat →
                              parse_qual_name_go rest2
                                (bytes_concat (name_append_dot acc)
                                              (MkPair (nat_byte_len part_nat) part_nat))
                          | _ → match acc { | MkPair len n → MkPair n toks }
                        }
                  }
            }
      }

-- parse_qual_name: parse TkIdent (TkDot TkIdent)*; 0 = not found
let parse_qual_name : List Token → Pair Nat (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair 0 toks
        | MkPair head_nat rest →
            parse_qual_name_go rest (MkPair (nat_byte_len head_nat) head_nat)
      }

-- =====================================================================
-- Section 21: Expression Parser
-- Rule: NO let bindings inside match arm bodies.
--       All intermediate values must be passed as direct arguments.
--       Rationale: let forms in match arm bodies are not evaluated by kal.
-- =====================================================================

-- is_atom_start: 1 if current token can begin an atom expression
let is_atom_start : List Token → Nat
  = λ toks →
      match (tok_peek toks) {
        | TkNat _ → 1
        | TkText _ → 1
        | TkIdent _ → 1
        | TkLParen → 1
        | TkMatch → 1
        | _ → 0
      }

-- is_upper_first_byte: 1 if lowest byte of n is uppercase ASCII
let is_upper_first_byte : Nat → Nat
  = λ n → is_upper (bit_and n 0xFF)

-- parse_ident_list: collect TkIdent tokens (constructor field names)
let parse_ident_list : List Token → Pair (List Nat) (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair Nil toks
        | MkPair n rest →
            match (parse_ident_list rest) {
              | MkPair names rest2 → MkPair (Cons n names) rest2
            }
      }

-- =====================================================================
-- Section 21: Expression Parser (pe = parse_expr passed as parameter)
-- All helpers take pe : (List Token → Pair Expr (List Token)) as first arg.
-- This breaks the forward-reference cycle: helpers are defined before
-- parse_expr, which ties the knot by passing itself (N(0) self-ref) to
-- parse_expr_dispatch, which threads pe through all recursive calls.
-- =====================================================================

-- arm_con_upper_pe: build ArmCon after we know con_nat is uppercase
-- toks is positioned AFTER the constructor name
let arm_con_upper_pe : (List Token → Pair Expr (List Token)) → Nat → List Token → Pair MatchArm (List Token)
  = λ pe con_nat toks →
      match (parse_ident_list toks) {
        | MkPair fields toks2 →
            match (pe (tok_tail toks2)) {
              | MkPair body rest →
                  MkPair (ArmCon con_nat (MkPair fields body)) rest
            }
      }

-- arm_con_lower_pe: build ArmVar after we know name is lowercase
-- toks is positioned AFTER the variable name (next token should be →)
let arm_con_lower_pe : (List Token → Pair Expr (List Token)) → Nat → List Token → Pair MatchArm (List Token)
  = λ pe var_nat toks →
      match (pe (tok_tail toks)) {
        | MkPair body rest → MkPair (ArmVar var_nat body) rest
      }

-- parse_match_arm_pe: parse  | Pat → Expr
-- Precondition: head is TkBar
-- Uses tok_eat_nat_token first (1 App arm) so the inner match on TkIdent
-- has only 1 App arm — avoids the multi-App-arm pred_env bug in bootstrap.
let parse_match_arm_pe : (List Token → Pair Expr (List Token)) → List Token → Pair MatchArm (List Token)
  = λ pe toks →
      match (tok_eat_nat_token (tok_tail toks)) {
        | MkPair n_opt rest →
            match n_opt {
              | Some n →
                  -- | n → expr: rest is after the nat literal, tok_tail skips →
                  match (pe (tok_tail rest)) {
                    | MkPair body rest2 → MkPair (ArmNat n body) rest2
                  }
              | None →
                  -- Only TkIdent is an App arm here (1 App arm only)
                  match (tok_peek (tok_tail toks)) {
                    | TkIdent con_nat →
                        match (is_upper_first_byte con_nat) {
                          | 0 → arm_con_lower_pe pe con_nat (tok_tail (tok_tail toks))
                          | k → arm_con_upper_pe pe con_nat (tok_tail (tok_tail toks))
                        }
                    | _ →
                        -- pe is in handler_env via TkIdent arm above
                        match (tok_is (tok_tail toks) TkUnderscore) {
                          | 0 → MkPair (ArmVar 0 (EVar 0)) (tok_tail toks)
                          | k →
                              -- | _ → expr  (tok_tail x3: skip |, _, →)
                              match (pe (tok_tail (tok_tail (tok_tail toks)))) {
                                | MkPair body rest2 → MkPair (ArmVar 0 body) rest2
                              }
                        }
                  }
            }
      }

-- parse_match_arms_pe: parse arms while head is TkBar
let parse_match_arms_pe : (List Token → Pair Expr (List Token)) → List Token → Pair (List MatchArm) (List Token)
  = λ pe toks →
      match (tok_is toks TkBar) {
        | 0 → MkPair Nil toks
        | k →
            match (parse_match_arm_pe pe toks) {
              | MkPair arm rest →
                  match (parse_match_arms_pe pe rest) {
                    | MkPair arms rest2 → MkPair (Cons arm arms) rest2
                  }
            }
      }

-- parse_lambda_params: collect TkIdent params until TkArrow
let parse_lambda_params : List Token → Pair (List Nat) (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair Nil toks
        | MkPair n rest →
            match (tok_is rest TkArrow) {
              | 0 →
                  match (parse_lambda_params rest) {
                    | MkPair ps rest2 → MkPair (Cons n ps) rest2
                  }
              | k → MkPair (Cons n Nil) rest
            }
      }

-- build_lambda: fold param list into nested ELam nodes
let build_lambda : List Nat → Expr → Expr
  = λ params body →
      match params {
        | Nil → body
        | Cons p rest → ELam p (build_lambda rest body)
      }

-- parse_match_expr_pe: parse  match scrut { arms }
-- toks is positioned AFTER the 'match' keyword
let parse_match_expr_pe : (List Token → Pair Expr (List Token)) → List Token → Pair Expr (List Token)
  = λ pe toks →
      match (pe toks) {
        | MkPair scrut toks2 →
            match (parse_match_arms_pe pe (tok_tail toks2)) {
              | MkPair arms toks3 →
                  MkPair (EMatch scrut arms) (tok_tail toks3)
            }
      }

-- parse_qual_name_pe: wrapper taking pe so pe appears in the TkIdent arm body
-- of parse_atom_expr_pe. Bootstrap workaround: pe must be referenced in at
-- least one App arm body to be captured in handler_env for the wildcard arm.
let parse_qual_name_pe : (List Token → Pair Expr (List Token)) → List Token → Pair Nat (List Token)
  = λ pe toks → parse_qual_name toks

-- parse_atom_expr_pe: parse a single non-application atom
-- Uses tok_eat_nat_token and tok_eat_text_token (1 App arm each) to handle
-- TkNat/TkText before the innermost match, which then has only 1 App arm
-- (TkIdent via parse_qual_name_pe pe) — avoids the multi-App-arm pred_env bug.
let parse_atom_expr_pe : (List Token → Pair Expr (List Token)) → List Token → Pair Expr (List Token)
  = λ pe toks →
      match (tok_eat_nat_token toks) {
        | MkPair n_opt rest →
            match n_opt {
              | Some n → MkPair (ENat n) rest
              | None →
                  match (tok_eat_text_token toks) {
                    | MkPair n_opt2 rest2 →
                        match n_opt2 {
                          | Some n → MkPair (ENat n) rest2
                          | None →
                              -- Only TkIdent is an App arm here (1 App arm only).
                              -- pe appears in TkIdent arm body (parse_qual_name_pe pe toks)
                              -- so pe is captured in handler_env for the wildcard arm.
                              match (tok_peek toks) {
                                | TkIdent _ →
                                    match (parse_qual_name_pe pe toks) {
                                      | MkPair n rest3 → MkPair (EVar n) rest3
                                    }
                                | _ →
                                    -- pe and toks both in handler_env
                                    match (tok_is toks TkLParen) {
                                      | 0 →
                                          match (tok_is toks TkMatch) {
                                            | 0 → MkPair (EVar 0) toks
                                            | k → parse_match_expr_pe pe (tok_tail toks)
                                          }
                                      | k →
                                          match (pe (tok_tail toks)) {
                                            | MkPair e toks2 → MkPair e (tok_tail toks2)
                                          }
                                    }
                              }
                        }
                  }
            }
      }

-- parse_app_go_pe: fold additional atoms into application spine
let parse_app_go_pe : (List Token → Pair Expr (List Token)) → Expr → List Token → Pair Expr (List Token)
  = λ pe acc toks →
      match (is_atom_start toks) {
        | 0 → MkPair acc toks
        | k →
            match (parse_atom_expr_pe pe toks) {
              | MkPair arg rest → parse_app_go_pe pe (EApp acc arg) rest
            }
      }

-- parse_app_expr_pe: head atom followed by zero or more atom arguments
let parse_app_expr_pe : (List Token → Pair Expr (List Token)) → List Token → Pair Expr (List Token)
  = λ pe toks →
      match (parse_atom_expr_pe pe toks) {
        | MkPair head rest → parse_app_go_pe pe head rest
      }

-- parse_lam_body_pe: finish parsing lambda after params are collected
-- toks is positioned AFTER the last param (next token should be →)
let parse_lam_body_pe : (List Token → Pair Expr (List Token)) → List Nat → List Token → Pair Expr (List Token)
  = λ pe params toks →
      match (pe (tok_tail toks)) {
        | MkPair body rest → MkPair (build_lambda params body) rest
      }

-- parse_fix_body_pe: finish parsing fix expression body
-- self_name: the self-reference name; params: user params; toks: positioned on →
-- Produces EFix self_name (MkPair params body) rather than nested ELam
let parse_fix_body_pe : (List Token → Pair Expr (List Token)) → Nat → List Nat → List Token → Pair Expr (List Token)
  = λ pe self_name params toks →
      match (pe (tok_tail toks)) {
        | MkPair body rest → MkPair (EFix self_name (MkPair params body)) rest
      }

-- parse_if_else_pe: finish parsing if/then/else given cond and then_ parsed
-- toks is positioned on 'else' keyword
let parse_if_else_pe : (List Token → Pair Expr (List Token)) → Expr → Expr → List Token → Pair Expr (List Token)
  = λ pe cond then_ toks →
      match (pe (tok_tail toks)) {
        | MkPair else_ rest →
            MkPair (EIf cond (MkPair then_ else_)) rest
      }

-- parse_if_then_pe: finish parsing if after cond is parsed
-- toks is positioned on 'then' keyword
let parse_if_then_pe : (List Token → Pair Expr (List Token)) → Expr → List Token → Pair Expr (List Token)
  = λ pe cond toks →
      match (pe (tok_tail toks)) {
        | MkPair then_ toks2 → parse_if_else_pe pe cond then_ toks2
      }

-- parse_let_body_pe: finish a let-in expression given name and rhs
-- toks is positioned on 'in' keyword
let parse_let_body_pe : (List Token → Pair Expr (List Token)) → Nat → Expr → List Token → Pair Expr (List Token)
  = λ pe name rhs toks →
      match (pe (tok_tail toks)) {
        | MkPair body rest → MkPair (ELet name (MkPair rhs body)) rest
      }

-- parse_let_rhs_pe: finish a let-in expression after name is parsed
-- toks is positioned on ':' or '=' (start of annotation-or-equals)
let parse_let_rhs_pe : (List Token → Pair Expr (List Token)) → Nat → List Token → Pair Expr (List Token)
  = λ pe name toks →
      match (pe (skip_ann toks)) {
        | MkPair rhs toks2 → parse_let_body_pe pe name rhs toks2
      }

-- parse_pin_body_pe: finish @name = rhs in body
let parse_pin_body_pe : (List Token → Pair Expr (List Token)) → Nat → Expr → List Token → Pair Expr (List Token)
  = λ pe name rhs toks →
      match (pe (tok_tail toks)) {
        | MkPair body rest → MkPair (EPin name (MkPair rhs body)) rest
      }

-- parse_pin_rhs_pe: finish @name after name consumed
let parse_pin_rhs_pe : (List Token → Pair Expr (List Token)) → Nat → List Token → Pair Expr (List Token)
  = λ pe name toks →
      match (pe (skip_ann toks)) {
        | MkPair rhs toks2 → parse_pin_body_pe pe name rhs toks2
      }

-- parse_expr_dispatch: full expression parser body, parameterised over pe
-- ALL of TkLambda, TkIf, TkLet, TkAt are nullary with tags > 1.  Matching them
-- directly as constructor arms compiles their pe-referencing bodies in pred_env
-- (bootstrap codegen bug).  Using tok_is (nat match) keeps pe in scope everywhere.
let parse_expr_dispatch : (List Token → Pair Expr (List Token)) → List Token → Pair Expr (List Token)
  = λ pe toks →
      match (tok_is toks TkLambda) {
        | 0 →
            match (tok_is toks TkIf) {
              | 0 →
                  match (tok_is toks TkLet) {
                    | 0 →
                        match (tok_is toks TkAt) {
                          | 0 →
                              match (tok_is toks TkFix) {
                                | 0 →
                                    match (tok_is toks TkHandle) {
                                      | 0 →
                                          match (tok_is toks TkPure) {
                                            | 0 →
                                                match (tok_is toks TkRun) {
                                                  | 0 →
                                      -- Check for do-bind: name ← rhs in body
                                      match (tok_peek toks) {
                                        | TkIdent bind_name →
                                            match (tok_is (tok_tail toks) TkBackArrow) {
                                              | 0 → parse_app_expr_pe pe toks
                                              | k →
                                                  -- skip ident, skip ←
                                                  let rest_do = tok_tail (tok_tail toks) in
                                                  match (pe rest_do) {
                                                    | MkPair rhs rest_do2 →
                                                        -- skip 'in'
                                                        let rest_do3 = tok_tail rest_do2 in
                                                        match (pe rest_do3) {
                                                          | MkPair body rest_do4 →
                                                              MkPair (EDo bind_name (MkPair rhs body)) rest_do4
                                                        }
                                                  }
                                            }
                                        | _ → parse_app_expr_pe pe toks
                                      }
                                                  | k →
                                                      -- run expr → EApp (EVar "run") expr
                                                      match (pe (tok_tail toks)) {
                                                        | MkPair arg rest →
                                                            MkPair (EApp (EVar kw_run) arg) rest
                                                      }
                                                }
                                            | k →
                                                -- pure expr → EApp (EVar "pure") expr
                                                match (pe (tok_tail toks)) {
                                                  | MkPair arg rest →
                                                      MkPair (EApp (EVar kw_pure) arg) rest
                                                }
                                          }
                                      | k →
                                          -- handle comp { ... }
                                          parse_handle_expr (tok_tail toks)
                                    }
                                | k →
                                    -- fix λ self params → body
                                    -- tok_tail twice: skip 'fix', skip 'λ'
                                    match (tok_eat_ident (tok_tail (tok_tail toks))) {
                                      | MkPair 0 _ → MkPair (EVar 0) toks
                                      | MkPair self_name toks2 →
                                          match (parse_lambda_params toks2) {
                                            | MkPair params toks3 →
                                                parse_fix_body_pe pe self_name params toks3
                                          }
                                    }
                              }
                          | k →
                              match (tok_eat_ident (tok_tail toks)) {
                                | MkPair 0 _ → MkPair (EVar 0) toks
                                | MkPair name toks2 → parse_pin_rhs_pe pe name toks2
                              }
                        }
                    | k →
                        match (tok_eat_ident (tok_tail toks)) {
                          | MkPair 0 _ → MkPair (EVar 0) toks
                          | MkPair name toks2 → parse_let_rhs_pe pe name toks2
                        }
                  }
              | k →
                  match (pe (tok_tail toks)) {
                    | MkPair cond toks2 → parse_if_then_pe pe cond toks2
                  }
            }
        | k →
            match (parse_lambda_params (tok_tail toks)) {
              | MkPair params toks2 → parse_lam_body_pe pe params toks2
            }
      }

-- parse_expr: entry point — ties the knot by passing self (N(0)) to dispatch
let parse_expr : List Token → Pair Expr (List Token)
  = λ toks → parse_expr_dispatch parse_expr toks

-- =====================================================================
-- Section 22: Declaration Parser
-- =====================================================================

-- skip_type_params: skip TkIdent type parameter tokens before =
let skip_type_params : List Token → List Token
  = λ toks →
      match (tok_peek toks) {
        | TkIdent _ → skip_type_params (tok_tail toks)
        | _ → toks
      }

-- is_arity_stop: 1 if token ends a constructor field list (| } EOF let type external eff class instance)
-- Uses nat_eq chains (each with 1 named arm) — avoids multi-nat-arm pred_env bug.
let is_arity_stop : Nat → Nat
  = λ t →
      match (nat_eq t TkBar) {
        | 0 →
            match (nat_eq t TkRBrace) {
              | 0 →
                  match (nat_eq t TkEof) {
                    | 0 →
                        match (nat_eq t TkLet) {
                          | 0 →
                              match (nat_eq t TkType) {
                                | 0 →
                                    match (nat_eq t TkExternal) {
                                      | 0 →
                                          match (nat_eq t TkEff) {
                                            | 0 →
                                                match (nat_eq t TkClass) {
                                                  | 0 → nat_eq t TkInstance
                                                  | k → 1
                                                }
                                            | k → 1
                                          }
                                      | k → 1
                                    }
                                | k → 1
                              }
                          | k → 1
                        }
                    | k → 1
                  }
              | k → 1
            }
        | k → 1
      }

-- parse_con_arity: count tokens before next | } let type external (arity)
-- Uses is_arity_stop (1 named nat arm) — avoids multi-nat-arm pred_env bug.
let parse_con_arity : List Token → Nat → Pair Nat (List Token)
  = λ toks acc →
      match (is_arity_stop (tok_peek toks)) {
        | 0 → parse_con_arity (tok_tail toks) (Core.PLAN.inc acc)
        | k → MkPair acc toks
      }

-- parse_con_def: parse  | Name fields...
let parse_con_def : List Token → Pair ConDef (List Token)
  = λ toks →
      match (tok_eat_ident (tok_tail toks)) {
        | MkPair 0 _ → MkPair (MkConDef 0 0) (tok_tail toks)
        | MkPair name toks2 →
            match (parse_con_arity toks2 0) {
              | MkPair arity rest → MkPair (MkConDef name arity) rest
            }
      }

-- parse_con_defs: parse | Con ... arms while head = TkBar
let parse_con_defs : List Token → Pair (List ConDef) (List Token)
  = λ toks →
      match (tok_is toks TkBar) {
        | 0 → MkPair Nil toks
        | k →
            match (parse_con_def toks) {
              | MkPair cd rest →
                  match (parse_con_defs rest) {
                    | MkPair cds rest2 → MkPair (Cons cd cds) rest2
                  }
            }
      }

-- is_ext_type_body_stop: 1 if token ends an external mod type annotation
-- Uses nat_eq chain (1 named arm each) — avoids multi-nat-arm pred_env bug.
let is_ext_type_body_stop : Nat → Nat
  = λ t →
      match (nat_eq t TkRBrace) {
        | 0 → nat_eq t TkEof
        | k → 1
      }

-- tok_skip_ext_type_body: skip past type tokens until next ident or } or EOF
-- Uses tok_eat_ident (1 App arm) + is_ext_type_body_stop (nat_eq) to avoid
-- multi-nullary-arm pred_env bug.
let tok_skip_ext_type_body : List Token → List Token
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair n _ →
            match (nat_eq n 0) {
              | 0 → toks
              | k →
                  match (is_ext_type_body_stop (tok_peek toks)) {
                    | 0 → tok_skip_ext_type_body (tok_tail toks)
                    | k → toks
                  }
            }
      }

-- tok_skip_ext_type: skip `: Type` annotation in external mod item
let tok_skip_ext_type : List Token → List Token
  = λ toks →
      match (tok_is toks TkColon) {
        | 0 → toks
        | k → tok_skip_ext_type_body (tok_tail toks)
      }

-- parse_ext_items: parse  name : Type  items inside external mod { }
-- Uses tok_is chain instead of multi-nullary constructor match to avoid pred_env bug.
let parse_ext_items : List Token → Pair (List Nat) (List Token)
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_is toks TkEof) {
              | 0 → MkPair Nil toks
              | k →
                  match (tok_eat_ident toks) {
                    | MkPair 0 _ → MkPair Nil (tok_tail toks)
                    | MkPair name toks1 →
                        match (parse_ext_items (tok_skip_ext_type toks1)) {
                          | MkPair names rest → MkPair (Cons name names) rest
                        }
                  }
            }
        | k → MkPair Nil toks
      }

-- parse_let_decl: finish parsing a top-level let after name
-- toks is positioned on ':' or '='
let parse_let_decl : Nat → List Token → Pair Decl (List Token)
  = λ name toks →
      match (parse_expr (skip_ann toks)) {
        | MkPair body rest → MkPair (DLet name body) rest
      }

-- parse_type_decl: finish parsing type after name
-- toks is positioned after optional type params, on '='
let parse_type_decl_body : Nat → List Token → Pair Decl (List Token)
  = λ name toks →
      match (parse_con_defs (tok_tail toks)) {
        | MkPair cdefs rest → MkPair (DType name cdefs) rest
      }

-- parse_ext_decl: finish parsing external mod after mod name
-- toks is positioned on '{'
let parse_ext_decl : Nat → List Token → Pair Decl (List Token)
  = λ mod_name toks →
      match (parse_ext_items (tok_tail toks)) {
        | MkPair names toks2 →
            MkPair (DExt mod_name names) (tok_tail toks2)
      }

-- Precomputed name nat: "inst" (4 bytes) — prefix for instance dict names.
-- Used as starting point for name_concat_under chains.
let nn_inst : Nat = 0x74736e69  -- "inst"

-- tok_is_class_member_start: 1 if next two tokens are TkIdent + TkColon
-- (signals the start of a class method declaration)
let tok_is_class_member_start : List Token → Nat
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → 0
        | MkPair _ rest → tok_is rest TkColon
      }

-- tok_skip_to_class_member: skip tokens until "ident :" or "}" is reached
let tok_skip_to_class_member : List Token → List Token
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_is_class_member_start toks) {
              | 0 → tok_skip_to_class_member (tok_tail toks)
              | k → toks
            }
        | k → toks
      }

-- parse_class_member_names: parse method names from { name : type \n ... }
-- toks is positioned after the opening '{'.
-- Returns (method_name_list, tokens_after_closing_}).
let parse_class_member_names : List Token → Pair (List Nat) (List Token)
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_eat_ident toks) {
              | MkPair 0 _ → MkPair Nil (tok_tail toks)
              | MkPair method_name rest →
                  let rest2 = tok_skip_to_class_member (tok_tail rest) in
                  match (parse_class_member_names rest2) {
                    | MkPair names rest3 → MkPair (Cons method_name names) rest3
                  }
            }
        | k → MkPair Nil (tok_tail toks)
      }

-- parse_class_decl: parse class body after 'class' keyword
-- toks positioned on class name ident
let parse_class_decl : List Token → Pair Decl (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair (DClass 0 Nil) toks
        | MkPair class_name rest →
            let rest2 = skip_type_params rest in
            match (parse_class_member_names (tok_tail rest2)) {
              | MkPair methods rest3 → MkPair (DClass class_name methods) rest3
            }
      }

-- tok_is_inst_member_start: 1 if next two tokens are TkIdent + TkEqual
-- (signals the start of an instance method binding)
let tok_is_inst_member_start : List Token → Nat
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → 0
        | MkPair _ rest → tok_is rest TkEqual
      }

-- is_inst_arg_start: like is_atom_start but also stops at "ident =" boundary
let is_inst_arg_start : List Token → Nat
  = λ toks →
      match (is_atom_start toks) {
        | 0 → 0
        | k →
            match (tok_is_inst_member_start toks) {
              | 0 → 1
              | k → 0
            }
      }

-- parse_inst_app_go_pe: application accumulator for instance bodies
-- Like parse_app_go_pe but stops at "ident =" member separator
let parse_inst_app_go_pe
      : (List Token → Pair Expr (List Token)) → Expr → List Token → Pair Expr (List Token)
  = λ pe acc toks →
      match (is_inst_arg_start toks) {
        | 0 → MkPair acc toks
        | k →
            match (parse_atom_expr_pe pe toks) {
              | MkPair arg rest → parse_inst_app_go_pe pe (EApp acc arg) rest
            }
      }

-- parse_inst_member_body_pe: parse one instance method body
-- Handles λ-bodies and simple applications; stops before "ident =" or "}"
let parse_inst_member_body_pe
      : (List Token → Pair Expr (List Token)) → List Token → Pair Expr (List Token)
  = λ pe toks →
      match (tok_is toks TkLambda) {
        | 0 →
            match (parse_atom_expr_pe pe toks) {
              | MkPair head rest → parse_inst_app_go_pe pe head rest
            }
        | k →
            match (parse_lambda_params (tok_tail toks)) {
              | MkPair params toks2 → parse_lam_body_pe pe params toks2
            }
      }

-- parse_inst_members: parse { method = body \n ... } block
-- toks positioned after the opening '{'.
-- Returns (member_list, tokens_after_closing_}).
let parse_inst_members : List Token → Pair (List (Pair Nat Expr)) (List Token)
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_eat_ident toks) {
              | MkPair 0 _ → MkPair Nil (tok_tail toks)
              | MkPair method_name rest →
                  match (parse_inst_member_body_pe parse_expr (tok_tail rest)) {
                    | MkPair body rest2 →
                        match (parse_inst_members rest2) {
                          | MkPair members rest3 →
                              MkPair (Cons (MkPair method_name body) members) rest3
                        }
                  }
            }
        | k → MkPair Nil (tok_tail toks)
      }

-- parse_inst_decl: parse instance body after 'instance' keyword
-- toks positioned on class name ident
let parse_inst_decl : List Token → Pair Decl (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair (DInst 0 (MkPair 0 Nil)) toks
        | MkPair class_name rest →
            match (tok_eat_ident rest) {
              | MkPair 0 _ → MkPair (DInst class_name (MkPair 0 Nil)) rest
              | MkPair type_name rest2 →
                  match (parse_inst_members (tok_tail rest2)) {
                    | MkPair members rest3 →
                        MkPair (DInst class_name (MkPair type_name members)) rest3
                  }
            }
      }

-- parse_eff_op_names: parse op names from { name : type \n ... }
-- Skips everything except idents before each colon (the op name).
-- Stops at }.
let parse_eff_op_names : List Token → Pair (List Nat) (List Token)
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_eat_ident toks) {
              | MkPair 0 _ → MkPair Nil (tok_tail toks)
              | MkPair op_name rest →
                  -- skip tokens until next ident or }
                  let rest2 = skip_type_params (tok_tail rest) in
                  match (parse_eff_op_names rest2) {
                    | MkPair ops rest3 →
                        MkPair (Cons op_name ops) rest3
                  }
            }
        | k → MkPair Nil (tok_tail toks)
      }

-- parse_eff_decl: parse eff declaration after 'eff' keyword
-- eff Name { op1 : Type \n op2 : Type }
let parse_eff_decl : List Token → Pair Decl (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair (DEff 0 Nil) toks
        | MkPair eff_name rest →
            let rest2 = skip_type_params rest in
            match (parse_eff_op_names (tok_tail rest2)) {
              | MkPair ops rest3 →
                  MkPair (DEff eff_name ops) rest3
            }
      }

-- parse_handle_op_arm: parse | op_name arg_name k_name → body
let parse_handle_op_arm
      : List Token → Pair (Pair Nat (Pair Nat Expr)) (List Token)
  = λ toks →
      match (tok_eat_ident toks) {
        | MkPair 0 _ → MkPair (MkPair 0 (MkPair 0 (EVar 0))) toks
        | MkPair op_name rest →
            match (tok_eat_ident rest) {
              | MkPair 0 _ → MkPair (MkPair op_name (MkPair 0 (EVar 0))) rest
              | MkPair arg_name rest2 →
                  match (tok_eat_ident rest2) {
                    | MkPair 0 _ → MkPair (MkPair op_name (MkPair arg_name (EVar 0))) rest2
                    | MkPair k_name rest3 →
                        match (parse_expr (tok_tail rest3)) {
                          | MkPair body rest4 →
                              MkPair (MkPair op_name (MkPair k_name body)) rest4
                        }
                  }
            }
      }

-- parse_handle_arms: parse op arms after return arm, before }
let parse_handle_arms
      : List Token → Pair (List (Pair Nat (Pair Nat Expr))) (List Token)
  = λ toks →
      match (tok_is toks TkRBrace) {
        | 0 →
            match (tok_is toks TkBar) {
              | 0 → MkPair Nil toks
              | k →
                  match (parse_handle_op_arm (tok_tail toks)) {
                    | MkPair arm rest →
                        match (parse_handle_arms rest) {
                          | MkPair arms rest2 →
                              MkPair (Cons arm arms) rest2
                        }
                  }
            }
        | k → MkPair Nil toks
      }

-- parse_handle_expr: parse handle comp { | return x → body | op ... }
-- toks positioned after 'handle' keyword
let parse_handle_expr : List Token → Pair Expr (List Token)
  = λ toks →
      match (parse_expr toks) {
        | MkPair comp rest →
            -- skip opening {
            let rest2 = tok_tail rest in
            -- skip | before 'return'
            let rest3 = match (tok_is rest2 TkBar) {
                          | 0 → rest2
                          | k → tok_tail rest2
                        } in
            -- eat 'return' ident, then return var name, then → then body
            let rest4 = tok_tail rest3 in
            match (tok_eat_ident rest4) {
              | MkPair 0 _ → MkPair (EVar 0) toks
              | MkPair ret_var rest5 →
                  match (parse_expr (tok_tail rest5)) {
                    | MkPair ret_body rest6 →
                        match (parse_handle_arms rest6) {
                          | MkPair op_arms rest7 →
                              -- skip closing }
                              MkPair (EHandle comp (MkPair (ELam ret_var ret_body) op_arms))
                                     (tok_tail rest7)
                        }
                  }
            }
      }

-- parse_decl: parse one top-level declaration
-- Uses tok_is chain (1 named nat arm each) — avoids multi-nullary-arm pred_env bug.
let parse_decl : List Token → Pair Decl (List Token)
  = λ toks →
      match (tok_is toks TkLet) {
        | 0 →
            match (tok_is toks TkType) {
              | 0 →
                  match (tok_is toks TkExternal) {
                    | 0 →
                        match (tok_is toks TkClass) {
                          | 0 →
                              match (tok_is toks TkInstance) {
                                | 0 →
                                    match (tok_is toks TkEff) {
                                      | 0 → MkPair (DLet 0 (EVar 0)) (tok_tail toks)
                                      | k → parse_eff_decl (tok_tail toks)
                                    }
                                | k → parse_inst_decl (tok_tail toks)
                              }
                          | k → parse_class_decl (tok_tail toks)
                        }
                    | k →
                        match (parse_qual_name (tok_tail (tok_tail toks))) {
                          | MkPair mod_name toks2 → parse_ext_decl mod_name toks2
                        }
                  }
              | k →
                  match (tok_eat_ident (tok_tail toks)) {
                    | MkPair 0 _ → MkPair (DType 0 Nil) toks
                    | MkPair name toks2 →
                        parse_type_decl_body name (skip_type_params toks2)
                  }
            }
        | k →
            match (tok_eat_ident (tok_tail toks)) {
              | MkPair 0 _ → MkPair (DLet 0 (EVar 0)) toks
              | MkPair name toks2 → parse_let_decl name toks2
            }
      }

-- =====================================================================
-- Section 23: parse_program
-- =====================================================================

let parse_program : List Token → List Decl
  = λ toks →
      match (tok_peek toks) {
        | TkEof → Nil
        | _ →
            match (parse_decl toks) {
              | MkPair decl rest → Cons decl (parse_program rest)
            }
      }

-- =====================================================================
-- End of M8.3: Parser
-- =====================================================================

-- =====================================================================
-- Section 24: M8.5 Codegen
-- =====================================================================
--
-- Compiles AST (Decl list) to PLAN values.
-- Reference: bootstrap/codegen.py
-- All match expressions follow the pred_env workaround pattern:
-- at most one App arm per match when outer lambda params are referenced.

-- -------------------------------------------------------------------
-- Layer 1a: CEnv accessors
-- -------------------------------------------------------------------

let cenv_globals : CEnv → List (Pair Nat PlanVal)
  = λ env →
      match env {
        | MkCEnv p _ →
            match p { | MkPair g _ → g }
      }

let cenv_locals : CEnv → List (Pair Nat Nat)
  = λ env →
      match env {
        | MkCEnv p _ →
            match p { | MkPair _ l → l }
      }

let cenv_arity : CEnv → Nat
  = λ env →
      match env {
        | MkCEnv _ q →
            match q { | MkPair a _ → a }
      }

let cenv_self : CEnv → Option Nat
  = λ env →
      match env {
        | MkCEnv _ q →
            match q { | MkPair _ s → s }
      }

let cenv_empty : CEnv
  = MkCEnv (MkPair Nil Nil) (MkPair 0 None)

let cenv_make : List (Pair Nat PlanVal) → List (Pair Nat Nat) → Nat → Option Nat → CEnv
  = λ g l a s → MkCEnv (MkPair g l) (MkPair a s)

let cenv_set_arity : CEnv → Nat → CEnv
  = λ env a → cenv_make (cenv_globals env) (cenv_locals env) a (cenv_self env)

let cenv_set_self : CEnv → Option Nat → CEnv
  = λ env s → cenv_make (cenv_globals env) (cenv_locals env) (cenv_arity env) s

let cenv_bind_local : CEnv → Nat → Nat → CEnv
  = λ env name idx →
      cenv_make (cenv_globals env)
                (assoc_insert name idx (cenv_locals env))
                (cenv_arity env)
                (cenv_self env)

let cenv_bind_global : CEnv → Nat → PlanVal → CEnv
  = λ env name val →
      cenv_make (assoc_insert name val (cenv_globals env))
                (cenv_locals env)
                (cenv_arity env)
                (cenv_self env)

let cenv_local_lookup : CEnv → Nat → Option Nat
  = λ env name → assoc_lookup name (cenv_locals env)

let cenv_global_lookup : CEnv → Nat → Option PlanVal
  = λ env name → assoc_lookup name (cenv_globals env)

-- cenv_new_param: add name at index arity+1, increment arity
let cenv_new_param : CEnv → Nat → CEnv
  = λ env name →
      let a = cenv_arity env in
      let new_a = add a 1 in
      cenv_bind_local (cenv_set_arity env new_a) name new_a

-- -------------------------------------------------------------------
-- Layer 1b: ConTable (fq_name_nat → (tag, arity))
-- -------------------------------------------------------------------

let contab_empty : List (Pair Nat (Pair Nat Nat))
  = Nil

let contab_lookup : List (Pair Nat (Pair Nat Nat)) → Nat → Option (Pair Nat Nat)
  = λ tab name → assoc_lookup name tab

let contab_insert : List (Pair Nat (Pair Nat Nat)) → Nat → Pair Nat Nat
                  → List (Pair Nat (Pair Nat Nat))
  = λ tab name info → assoc_insert name info tab

-- contab_tag: extract tag from contab entry
let contab_tag : Pair Nat Nat → Nat
  = λ p → match p { | MkPair t _ → t }

-- contab_arity: extract arity from contab entry
let contab_arity_of : Pair Nat Nat → Nat
  = λ p → match p { | MkPair _ a → a }

-- -------------------------------------------------------------------
-- Layer 1c: PlanVal constants and helpers
-- -------------------------------------------------------------------

-- id_law: L(1, 0, N(1)) — identity function
let id_law : PlanVal
  = PLaw 0 (MkPair 1 (PNat 1))

-- const2_law: L(2, 0, N(1)) — takes 2 args, returns first
let const2_law : PlanVal
  = PLaw 0 (MkPair 2 (PNat 1))

-- planval_is_nat: 1 if PNat (single App arm + wildcard — safe)
let planval_is_nat : PlanVal → Nat
  = λ v → match v { | PNat _ → 1 | _ → 0 }

let planval_get_nat : PlanVal → Nat
  = λ v → match v { | PNat n → n | _ → 0 }

let planval_is_pin : PlanVal → Nat
  = λ v → match v { | PPin _ → 1 | _ → 0 }

let planval_is_app : PlanVal → Nat
  = λ v → match v { | PApp _ _ → 1 | _ → 0 }

let planval_is_law : PlanVal → Nat
  = λ v → match v { | PLaw _ _ → 1 | _ → 0 }

let planval_get_pin_inner : PlanVal → PlanVal
  = λ v → match v { | PPin inner → inner | _ → v }

-- -------------------------------------------------------------------
-- Layer 2: PLAN value builders
-- -------------------------------------------------------------------

-- cg_quote_nat: literal k inside law body with given arity
-- k <= arity → quote form PApp(PNat 0)(PNat k); else PNat k
let cg_quote_nat : Nat → Nat → PlanVal
  = λ k arity →
      match (nat_eq arity 0) {
        | 0 →
            match (lte k arity) {
              | 0 → PNat k
              | _ → PApp (PNat 0) (PNat k)
            }
        | _ → PNat k
      }

-- cg_bapp: A(A(N(0), f), x) — application inside a law body
let cg_bapp : PlanVal → PlanVal → PlanVal
  = λ f x → PApp (PApp (PNat 0) f) x

-- cg_apply: bapp in law body, direct PApp at top level
let cg_apply : PlanVal → PlanVal → Nat → PlanVal
  = λ f x arity →
      match (nat_eq arity 0) {
        | 0 → cg_bapp f x
        | _ → PApp f x
      }

-- cg_ensure_pin: wrap in PPin if not already pinned
let cg_ensure_pin : PlanVal → PlanVal
  = λ v → match v { | PPin _ → v | _ → PPin v }

-- cg_build_op2: Case_(id, id, id, z, m, scr) — nat dispatch
-- arity=0 → top-level (direct Apps); arity>0 → law body (bapp)
let cg_build_op2 : PlanVal → PlanVal → PlanVal → Nat → PlanVal
  = λ z m scr arity →
      let op3 = PPin (PNat 3) in
      let id_pin = PPin id_law in
      match (nat_eq arity 0) {
        | 0 →
            cg_bapp (cg_bapp (cg_bapp (cg_bapp (cg_bapp (cg_bapp op3 id_pin) id_pin) id_pin) z) m) scr
        | _ →
            PApp (PApp (PApp (PApp (PApp (PApp op3 id_pin) id_pin) id_pin) z) m) scr
      }

-- cg_build_reflect_dispatch: Case_(id, id, app_fn, z, m, scr)
let cg_build_reflect_dispatch : PlanVal → PlanVal → PlanVal → PlanVal → Nat → PlanVal
  = λ app_fn z m scr arity →
      let op3 = PPin (PNat 3) in
      let id_pin = PPin id_law in
      match (nat_eq arity 0) {
        | 0 →
            cg_bapp (cg_bapp (cg_bapp (cg_bapp (cg_bapp (cg_bapp op3 id_pin) id_pin) app_fn) z) m) scr
        | _ →
            PApp (PApp (PApp (PApp (PApp (PApp op3 id_pin) id_pin) app_fn) z) m) scr
      }

-- cg_build_reflect_app: Case_(id, id, app_fn, z, const2(0), scr)
-- used when App branch is the real handler and Nat cases are trivial
let cg_build_reflect_app : PlanVal → PlanVal → PlanVal → Nat → PlanVal
  = λ app_fn z scr arity →
      let const2_pin = PPin const2_law in
      let m = match (nat_eq arity 0) {
                | 0 → cg_bapp const2_pin (PPin (PNat 0))
                | _ → PApp const2_pin (PNat 0)
              } in
      cg_build_reflect_dispatch app_fn z m scr arity

-- cg_apply_params: bapp acc to N(idx), N(idx+1), ..., N(max)
let cg_apply_params : PlanVal → Nat → Nat → PlanVal
  = λ acc idx max →
      match (lte idx max) {
        | 0 → acc
        | _ → cg_apply_params (cg_bapp acc (PNat idx)) (add idx 1) max
      }

-- cg_build_constructor_body: law body for constructor (tag, n_fields)
-- Always uses quote form for tag since tag <= n_fields in any sane type
let cg_build_constructor_body : Nat → Nat → PlanVal
  = λ tag n_fields →
      cg_apply_params (PApp (PNat 0) (PNat tag)) 1 n_fields

-- -------------------------------------------------------------------
-- Layer 3a: Expr tag extractors and single-arm helpers
-- -------------------------------------------------------------------

-- expr_tag: 0=EVar 1=EApp 2=ELam 3=ELet 4=ENat 5=EIf 6=EMatch 7=EPin 8=EFix
-- SAFE: all arms return constant nats (no outer param refs in bodies)
let expr_tag : Expr → Nat
  = λ e →
      match e {
        | EVar _    → 0
        | EApp _ _  → 1
        | ELam _ _  → 2
        | ELet _ _  → 3
        | ENat _    → 4
        | EIf _ _   → 5
        | EMatch _ _ → 6
        | EPin _ _  → 7
        | EFix _ _  → 8
        | EHandle _ _ → 9
        | EDo _ _   → 10
      }

-- Per-constructor accessors (each: single App arm + wildcard — safe)
let cg_is_lam : Expr → Nat
  = λ e → match e { | ELam _ _ → 1 | _ → 0 }

let cg_lam_param : Expr → Nat
  = λ e → match e { | ELam p _ → p | _ → 0 }

let cg_lam_body : Expr → Expr
  = λ e → match e { | ELam _ b → b | _ → e }

let cg_evar_name : Expr → Nat
  = λ e → match e { | EVar n → n | _ → 0 }

let cg_app_fun : Expr → Expr
  = λ e → match e { | EApp f _ → f | _ → e }

let cg_app_arg : Expr → Expr
  = λ e → match e { | EApp _ a → a | _ → e }

let cg_enat_val : Expr → Nat
  = λ e → match e { | ENat n → n | _ → 0 }

let cg_eif_cond : Expr → Expr
  = λ e → match e { | EIf c _ → c | _ → e }

let cg_eif_pair : Expr → Pair Expr Expr
  = λ e → match e { | EIf _ p → p | _ → MkPair e e }

let cg_elet_name : Expr → Nat
  = λ e → match e { | ELet n _ → n | _ → 0 }

let cg_elet_pair : Expr → Pair Expr Expr
  = λ e → match e { | ELet _ p → p | _ → MkPair e e }

let cg_ematch_scrutinee : Expr → Expr
  = λ e → match e { | EMatch s _ → s | _ → e }

let cg_ematch_arms : Expr → List MatchArm
  = λ e → match e { | EMatch _ arms → arms | _ → Nil }

let cg_epin_name : Expr → Nat
  = λ e → match e { | EPin n _ → n | _ → 0 }

let cg_epin_pair : Expr → Pair Expr Expr
  = λ e → match e { | EPin _ p → p | _ → MkPair e e }

let cg_efix_self : Expr → Nat
  = λ e → match e { | EFix n _ → n | _ → 0 }

let cg_efix_pair : Expr → Pair (List Nat) Expr
  = λ e → match e { | EFix _ p → p | _ → MkPair Nil e }

let cg_ehandle_comp : Expr → Expr
  = λ e → match e { | EHandle c _ → c | _ → e }

let cg_ehandle_pair : Expr → Pair Expr (List (Pair Nat (Pair Nat Expr)))
  = λ e → match e { | EHandle _ p → p | _ → MkPair e Nil }

let cg_edo_name : Expr → Nat
  = λ e → match e { | EDo n _ → n | _ → 0 }

let cg_edo_pair : Expr → Pair Expr Expr
  = λ e → match e { | EDo _ p → p | _ → MkPair e e }

-- -------------------------------------------------------------------
-- Layer 3b: MatchArm single-arm helpers
-- -------------------------------------------------------------------

let arm_tag : MatchArm → Nat
  = λ a → match a { | ArmNat _ _ → 0 | ArmVar _ _ → 1 | ArmCon _ _ → 2 }

let arm_is_nat : MatchArm → Nat
  = λ a → match a { | ArmNat _ _ → 1 | _ → 0 }

let arm_is_var : MatchArm → Nat
  = λ a → match a { | ArmVar _ _ → 1 | _ → 0 }

let arm_is_con : MatchArm → Nat
  = λ a → match a { | ArmCon _ _ → 1 | _ → 0 }

let arm_get_nat_tag : MatchArm → Nat
  = λ a → match a { | ArmNat t _ → t | _ → 0 }

let arm_get_nat_body : MatchArm → Expr
  = λ a → match a { | ArmNat _ b → b | _ → EVar 0 }

let arm_get_var_name : MatchArm → Nat
  = λ a → match a { | ArmVar n _ → n | _ → 0 }

let arm_get_var_body : MatchArm → Expr
  = λ a → match a { | ArmVar _ b → b | _ → EVar 0 }

let arm_get_con_name : MatchArm → Nat
  = λ a → match a { | ArmCon n _ → n | _ → 0 }

let arm_get_con_fields : MatchArm → List Nat
  = λ a →
      match a {
        | ArmCon _ p → match p { | MkPair fs _ → fs }
        | _ → Nil
      }

let arm_get_con_body : MatchArm → Expr
  = λ a →
      match a {
        | ArmCon _ p → match p { | MkPair _ b → b }
        | _ → EVar 0
      }

-- -------------------------------------------------------------------
-- Layer 3c: Decl single-arm helpers
-- -------------------------------------------------------------------

-- Predicates use exhaustive 5-arm matches to avoid the wildcard-arm-drop
-- bootstrap bug (| Con _ _ → 1 | _ → 0 matches all constructors as Con).
let decl_is_let : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 1
      | DType _ _  → 0
      | DExt _ _   → 0
      | DClass _ _ → 0
      | DInst _ _  → 0
      | DEff _ _   → 0
    }

let decl_is_type : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 0
      | DType _ _  → 1
      | DExt _ _   → 0
      | DClass _ _ → 0
      | DInst _ _  → 0
      | DEff _ _   → 0
    }

let decl_is_ext : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 0
      | DType _ _  → 0
      | DExt _ _   → 1
      | DClass _ _ → 0
      | DInst _ _  → 0
      | DEff _ _   → 0
    }

let decl_get_let_name : Decl → Nat
  = λ d → match d { | DLet n _ → n | _ → 0 }

let decl_get_let_body : Decl → Expr
  = λ d → match d { | DLet _ b → b | _ → EVar 0 }

let decl_get_type_name : Decl → Nat
  = λ d → match d { | DType n _ → n | _ → 0 }

let decl_get_type_cdefs : Decl → List ConDef
  = λ d → match d { | DType _ cs → cs | _ → Nil }

let decl_get_ext_mod : Decl → Nat
  = λ d → match d { | DExt m _ → m | _ → 0 }

let decl_get_ext_items : Decl → List Nat
  = λ d → match d { | DExt _ items → items | _ → Nil }

let decl_is_class : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 0
      | DType _ _  → 0
      | DExt _ _   → 0
      | DClass _ _ → 1
      | DInst _ _  → 0
      | DEff _ _   → 0
    }

let decl_is_inst : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 0
      | DType _ _  → 0
      | DExt _ _   → 0
      | DClass _ _ → 0
      | DInst _ _  → 1
      | DEff _ _   → 0
    }

let decl_is_eff : Decl → Nat
  = λ d → match d {
      | DLet _ _   → 0
      | DType _ _  → 0
      | DExt _ _   → 0
      | DClass _ _ → 0
      | DInst _ _  → 0
      | DEff _ _   → 1
    }

let decl_get_eff_name : Decl → Nat
  = λ d → match d { | DEff n _ → n | _ → 0 }

let decl_get_eff_ops : Decl → List Nat
  = λ d → match d { | DEff _ ops → ops | _ → Nil }

let decl_get_class_name : Decl → Nat
  = λ d → match d { | DClass n _ → n | _ → 0 }

let decl_get_class_methods : Decl → List Nat
  = λ d → match d { | DClass _ ms → ms | _ → Nil }

let decl_get_inst_class : Decl → Nat
  = λ d → match d { | DInst cls _ → cls | _ → 0 }

let decl_get_inst_body : Decl → Pair Nat (List (Pair Nat Expr))
  = λ d → match d {
      | DInst _ p → p
      | _ → MkPair 0 Nil
    }


-- -------------------------------------------------------------------
-- Layer 4: Recursive AST traversal (free variable collection)
-- Pass-self pattern breaks mutual recursion between collect_free and
-- collect_free_arms (which would otherwise form a cycle via cfree_match).
-- -------------------------------------------------------------------

-- cg_name_in_list: 1 if name appears in list
let cg_name_in_list : Nat → List Nat → Nat
  = λ name lst →
      match lst {
        | Nil → 0
        | Cons h rest →
            match (nat_eq name h) {
              | 0 → cg_name_in_list name rest
              | _ → 1
            }
      }

-- cg_add_name_once: add name to list if not already present
let cg_add_name_once : Nat → List Nat → List Nat
  = λ name lst →
      match (cg_name_in_list name lst) {
        | 0 → Cons name lst
        | _ → lst
      }

-- cg_free_arm_bound: names bound by a match arm (con fields or var name)
let cg_free_arm_bound : MatchArm → List Nat → List Nat
  = λ arm bound →
      match (arm_is_var arm) {
        | 0 →
            match (arm_is_con arm) {
              | 0 → bound
              | _ → append (arm_get_con_fields arm) bound
            }
        | _ → Cons (arm_get_var_name arm) bound
      }

-- cg_free_arm_body_of: get the body expression from any arm type
let cg_free_arm_body_of : MatchArm → Expr
  = λ arm →
      match (arm_is_nat arm) {
        | 0 →
            match (arm_is_var arm) {
              | 0 → arm_get_con_body arm
              | _ → arm_get_var_body arm
            }
        | _ → arm_get_nat_body arm
      }

-- cg_cf_arms: iterate arms, calling cf on each body with arm-extended bound
-- cf: the collect_free function (passed to break mutual recursion)
let cg_cf_arms : (Expr → List Nat → CEnv → List Nat → List Nat)
               → List MatchArm → List Nat → CEnv → List Nat → List Nat
  = λ cf arms bound env acc →
      match arms {
        | Nil → acc
        | Cons arm rest →
            let ab = cg_free_arm_bound arm bound in
            let body = cg_free_arm_body_of arm in
            cg_cf_arms cf rest bound env (cf body ab env acc)
      }

-- cg_cf_handle_arms: collect free vars from handler op arms
let cg_cf_handle_arms
      : (Expr → List Nat → CEnv → List Nat → List Nat)
      → List (Pair Nat (Pair Nat Expr)) → List Nat → CEnv → List Nat → List Nat
  = λ cf arms bound env acc →
      match arms {
        | Nil → acc
        | Cons arm rest →
            match arm {
              | MkPair _ inner →
                  match inner {
                    | MkPair k_name body →
                        cg_cf_handle_arms cf rest bound env
                          (cf body (Cons k_name bound) env acc)
                  }
            }
      }

-- cg_cf_dispatch: dispatch collect_free to the right per-constructor handler
-- cf: the collect_free function (passed to avoid mutual recursion)
-- Uses nat_eq chain on expr_tag to route (all safe: 1 named arm + wildcard)
let cg_cf_dispatch : (Expr → List Nat → CEnv → List Nat → List Nat)
                   → Expr → List Nat → CEnv → List Nat → List Nat
  = λ cf expr bound env acc →
      match (nat_eq (expr_tag expr) 0) {
        | 0 →
            match (nat_eq (expr_tag expr) 4) {
              | 0 →
                  match (nat_eq (expr_tag expr) 1) {
                    | 0 →
                        match (nat_eq (expr_tag expr) 2) {
                          | 0 →
                              match (nat_eq (expr_tag expr) 3) {
                                | 0 →
                                    match (nat_eq (expr_tag expr) 5) {
                                      | 0 →
                                          match (nat_eq (expr_tag expr) 6) {
                                            | 0 →
                                                match (nat_eq (expr_tag expr) 7) {
                                                  | 0 →
                                                      match (nat_eq (expr_tag expr) 8) {
                                                        | 0 →
                                                            match (nat_eq (expr_tag expr) 9) {
                                                              | 0 →
                                                                  -- EDo (tag 10): collect from rhs and body (bind_name bound in body)
                                                                  match expr {
                                                                    | EDo bind_n pair →
                                                                        match pair {
                                                                          | MkPair rhs body →
                                                                              cf body (Cons bind_n bound) env
                                                                                (cf rhs bound env acc)
                                                                        }
                                                                    | _ → acc
                                                                  }
                                                              | _ →
                                                                  -- EHandle (tag 9): collect from comp, return body, all op arm bodies
                                                                  match expr {
                                                                    | EHandle comp pair →
                                                                        match pair {
                                                                          | MkPair ret_fn op_arms →
                                                                              cg_cf_handle_arms cf op_arms bound env
                                                                                (cf ret_fn bound env
                                                                                  (cf comp bound env acc))
                                                                        }
                                                                    | _ → acc
                                                                  }
                                                            }
                                                        | _ →
                                                            -- EFix (tag 8): body has self_name and all params bound
                                                            match expr {
                                                              | EFix self_n pair →
                                                                  match pair {
                                                                    | MkPair params body →
                                                                        cf body (append params (Cons self_n bound)) env acc
                                                                  }
                                                              | _ → acc
                                                            }
                                                      }
                                                  | _ →
                                                      -- EPin (tag 7): collect from rhs then body (name bound in body)
                                                      match expr {
                                                        | EPin n pair →
                                                            match pair {
                                                              | MkPair rhs body →
                                                                  cf body (Cons n bound) env
                                                                    (cf rhs bound env acc)
                                                            }
                                                        | _ → acc
                                                      }
                                                }
                                            | _ →
                                                -- EMatch: collect from scrutinee + all arms
                                                match expr {
                                                  | EMatch scr arms →
                                                      cg_cf_arms cf arms bound env
                                                        (cf scr bound env acc)
                                                  | _ → acc
                                                }
                                          }
                                      | _ →
                                          -- EIf: collect from cond, then, else
                                          match expr {
                                            | EIf cond pair →
                                                match pair {
                                                  | MkPair then_ else_ →
                                                      cf else_ bound env
                                                        (cf then_ bound env
                                                          (cf cond bound env acc))
                                                }
                                            | _ → acc
                                          }
                                    }
                                | _ →
                                    -- ELet: collect from rhs then body (name bound in body)
                                    match expr {
                                      | ELet n pair →
                                          match pair {
                                            | MkPair rhs body →
                                                cf body (Cons n bound) env
                                                  (cf rhs bound env acc)
                                          }
                                      | _ → acc
                                    }
                              }
                          | _ →
                              -- ELam: collect from body (param bound)
                              match expr {
                                | ELam p b → cf b (Cons p bound) env acc
                                | _ → acc
                              }
                        }
                    | _ →
                        -- EApp: collect from fun and arg
                        match expr {
                          | EApp f a →
                              cf a bound env (cf f bound env acc)
                          | _ → acc
                        }
                  }
              | _ → acc  -- ENat: no free vars
            }
        | _ →
            -- EVar: check if name is free (in env.locals, not in bound)
            match expr {
              | EVar n →
                  match (cg_name_in_list n bound) {
                    | 0 →
                        match (assoc_has n (cenv_locals env)) {
                          | 0 → acc
                          | _ → cg_add_name_once n acc
                        }
                    | _ → acc
                  }
              | _ → acc
            }
      }

-- cg_collect_free: main free-var collector (self-recursive, passes itself to dispatch)
let cg_collect_free : Expr → List Nat → CEnv → List Nat → List Nat
  = λ expr bound env acc →
      cg_cf_dispatch cg_collect_free expr bound env acc

-- cg_keep_free_locals: filter locals to keep only those in found and not in bound
let cg_keep_free_locals : List (Pair Nat Nat) → List Nat → List Nat → List Nat
  = λ locals found bound →
      match locals {
        | Nil → Nil
        | Cons kv rest →
            match kv {
              | MkPair name _ →
                  let rest_result = cg_keep_free_locals rest found bound in
                  match (cg_name_in_list name bound) {
                    | 0 →
                        match (cg_name_in_list name found) {
                          | 0 → rest_result
                          | _ → Cons name rest_result
                        }
                    | _ → rest_result
                  }
            }
      }

-- cg_free_vars: names in cenv_locals order that appear free in expr (not in bound)
let cg_free_vars : Expr → List Nat → CEnv → List Nat
  = λ expr bound env →
      let found = cg_collect_free expr bound env Nil in
      cg_keep_free_locals (cenv_locals env) found bound

-- cg_free_vars_bodies: free locals across multiple bodies (union)
let cg_free_vars_bodies : List Expr → List Nat → CEnv → List Nat
  = λ bodies bound env →
      let all_found = foldl (λ acc body → cg_collect_free body bound env acc) Nil bodies in
      cg_keep_free_locals (cenv_locals env) all_found bound

-- -------------------------------------------------------------------
-- Layer 4b: Self-reference detection (same pass-self pattern)
-- -------------------------------------------------------------------

-- cg_hv_arms must be defined before cg_hv_dispatch (forward reference fix)
let cg_hv_arms : (Expr → Nat → Nat) → List MatchArm → Nat → Nat
  = λ hv arms name →
      match arms {
        | Nil → 0
        | Cons arm rest →
            match (hv (cg_free_arm_body_of arm) name) {
              | 0 → cg_hv_arms hv rest name
              | _ → 1
            }
      }

-- cg_hv_dispatch: dispatch has_var to the right handler
-- hv: the has_var function (passed to avoid mutual recursion)
let cg_hv_dispatch : (Expr → Nat → Nat) → Expr → Nat → Nat
  = λ hv expr name →
      match (nat_eq (expr_tag expr) 0) {
        | 0 →
            match (nat_eq (expr_tag expr) 4) {
              | 0 →
                  match (nat_eq (expr_tag expr) 1) {
                    | 0 →
                        match (nat_eq (expr_tag expr) 2) {
                          | 0 →
                              match (nat_eq (expr_tag expr) 3) {
                                | 0 →
                                    match (nat_eq (expr_tag expr) 5) {
                                      | 0 →
                                          match (nat_eq (expr_tag expr) 6) {
                                            | 0 →
                                                match (nat_eq (expr_tag expr) 7) {
                                                  | 0 →
                                                      match (nat_eq (expr_tag expr) 8) {
                                                        | 0 →
                                                            match (nat_eq (expr_tag expr) 9) {
                                                              | 0 →
                                                                  -- EDo (tag 10): check rhs and body
                                                                  match expr {
                                                                    | EDo _ pair →
                                                                        match pair {
                                                                          | MkPair r b →
                                                                              match (hv r name) {
                                                                                | 0 → hv b name
                                                                                | _ → 1
                                                                              }
                                                                        }
                                                                    | _ → 0
                                                                  }
                                                              | _ →
                                                                  -- EHandle (tag 9): check comp, return fn, all op arm bodies
                                                                  match expr {
                                                                    | EHandle comp pair →
                                                                        match pair {
                                                                          | MkPair ret_fn _ →
                                                                              match (hv comp name) {
                                                                                | 0 → hv ret_fn name
                                                                                | _ → 1
                                                                              }
                                                                        }
                                                                    | _ → 0
                                                                  }
                                                            }
                                                        | _ →
                                                            -- EFix (tag 8): check body (self_name and params are not free)
                                                            match expr {
                                                              | EFix _ pair →
                                                                  match pair {
                                                                    | MkPair _ body → hv body name
                                                                  }
                                                              | _ → 0
                                                            }
                                                      }
                                                  | _ →
                                                      -- EPin (tag 7)
                                                      match expr {
                                                        | EPin _ pair →
                                                            match pair {
                                                              | MkPair r b →
                                                                  match (hv r name) {
                                                                    | 0 → hv b name
                                                                    | _ → 1
                                                                  }
                                                            }
                                                        | _ → 0
                                                      }
                                                }
                                            | _ →
                                                match expr {
                                                  | EMatch s arms →
                                                      match (hv s name) {
                                                        | 0 → cg_hv_arms hv arms name
                                                        | _ → 1
                                                      }
                                                  | _ → 0
                                                }
                                          }
                                      | _ →
                                          match expr {
                                            | EIf c pair →
                                                match pair {
                                                  | MkPair t el →
                                                      match (hv c name) {
                                                        | 0 →
                                                            match (hv t name) {
                                                              | 0 → hv el name
                                                              | _ → 1
                                                            }
                                                        | _ → 1
                                                      }
                                                }
                                            | _ → 0
                                          }
                                    }
                                | _ →
                                    match expr {
                                      | ELet _ pair →
                                          match pair {
                                            | MkPair r b →
                                                match (hv r name) {
                                                  | 0 → hv b name
                                                  | _ → 1
                                                }
                                          }
                                      | _ → 0
                                    }
                              }
                          | _ →
                              match expr {
                                | ELam _ b → hv b name
                                | _ → 0
                              }
                        }
                    | _ →
                        match expr {
                          | EApp f a →
                              match (hv f name) {
                                | 0 → hv a name
                                | _ → 1
                              }
                          | _ → 0
                        }
                  }
              | _ → 0  -- ENat
            }
        | _ →
            match expr {
              | EVar n → nat_eq n name
              | _ → 0
            }
      }

let cg_has_var : Expr → Nat → Nat
  = λ expr name → cg_hv_dispatch cg_has_var expr name

-- cg_body_uses_self: does expr reference env's self_ref?
let cg_body_uses_self : Expr → CEnv → Nat
  = λ expr env →
      match (cenv_self env) {
        | None → 0
        | Some fq_nat → cg_has_var expr fq_nat
      }

-- cg_flatten_lam: collect params and find body (workaround: no multi-arm match)
let cg_flatten_lam_go : Expr → List Nat → Pair (List Nat) Expr
  = λ e acc →
      match (cg_is_lam e) {
        | 0 → MkPair (reverse acc) e
        | _ → cg_flatten_lam_go (cg_lam_body e) (Cons (cg_lam_param e) acc)
      }

let cg_flatten_lam : Expr → Pair (List Nat) Expr
  = λ e → cg_flatten_lam_go e Nil

-- -------------------------------------------------------------------
-- Layer 5: Sorting utilities and arm extraction
-- -------------------------------------------------------------------

-- cg_insert_sorted_pair: insertion sort on (Nat, Expr) by nat key
let cg_insert_sorted_pair : Pair Nat Expr → List (Pair Nat Expr) → List (Pair Nat Expr)
  = λ p lst →
      match p {
        | MkPair k _ →
            match lst {
              | Nil → Cons p Nil
              | Cons h rest →
                  match h {
                    | MkPair hk _ →
                        match (lte k hk) {
                          | 0 → Cons h (cg_insert_sorted_pair p rest)
                          | _ → Cons p lst
                        }
                  }
            }
      }

let cg_sort_nat_pairs : List (Pair Nat Expr) → List (Pair Nat Expr)
  = λ lst →
      match lst {
        | Nil → Nil
        | Cons h rest → cg_insert_sorted_pair h (cg_sort_nat_pairs rest)
      }

-- cg_insert_sorted_pv: insertion sort on (Nat, PlanVal) by nat key
let cg_insert_sorted_pv : Pair Nat PlanVal → List (Pair Nat PlanVal) → List (Pair Nat PlanVal)
  = λ p lst →
      match p {
        | MkPair k _ →
            match lst {
              | Nil → Cons p Nil
              | Cons h rest →
                  match h {
                    | MkPair hk _ →
                        match (lte k hk) {
                          | 0 → Cons h (cg_insert_sorted_pv p rest)
                          | _ → Cons p lst
                        }
                  }
            }
      }

let cg_sort_pv_pairs : List (Pair Nat PlanVal) → List (Pair Nat PlanVal)
  = λ lst →
      match lst {
        | Nil → Nil
        | Cons h rest → cg_insert_sorted_pv h (cg_sort_pv_pairs rest)
      }

-- cg_extract_nat_arms: collect ArmNat arms as sorted (tag, body) pairs
let cg_extract_nat_arms : List MatchArm → List (Pair Nat Expr)
  = λ arms →
      cg_sort_nat_pairs
        (foldr (λ arm acc →
            match (arm_is_nat arm) {
              | 0 → acc
              | _ → Cons (MkPair (arm_get_nat_tag arm) (arm_get_nat_body arm)) acc
            }) Nil arms)

-- cg_extract_wild_arm: find first ArmVar
-- Returns Some (MkPair (Some name) body) for variable, Some (MkPair None body) for wildcard
let cg_extract_wild_arm : List MatchArm → Option (Pair (Option Nat) Expr)
  = λ arms →
      match arms {
        | Nil → None
        | Cons arm rest →
            match (arm_is_var arm) {
              | 0 → cg_extract_wild_arm rest
              | _ →
                  let name = arm_get_var_name arm in
                  let body = arm_get_var_body arm in
                  match (nat_eq name 0) {
                    | 0 → Some (MkPair (Some name) body)
                    | _ → Some (MkPair None body)
                  }
            }
      }

-- -------------------------------------------------------------------
-- Layer 6: Nat match compilation
-- -------------------------------------------------------------------

-- cg_bind_params: fold cenv_new_param over a list of names
let cg_bind_params : List Nat → CEnv → CEnv
  = λ names env →
      match names {
        | Nil → env
        | Cons name rest → cg_bind_params rest (cenv_new_param env name)
      }

-- cg_apply_free_locals: partially apply v to free vars via de Bruijn indices
let cg_apply_free_locals : PlanVal → List Nat → CEnv → PlanVal
  = λ v names env →
      match names {
        | Nil → v
        | Cons name rest →
            match (cenv_local_lookup env name) {
              | None → cg_apply_free_locals v rest env
              | Some idx →
                  let applied = match (nat_eq (cenv_arity env) 0) {
                                   | 0 → cg_bapp v (PNat idx)
                                   | _ → PApp v (PNat idx)
                                 } in
                  cg_apply_free_locals applied rest env
            }
      }

-- cg_make_pred_succ_law: 1-arg succ function binding wild_var to predecessor
-- Captures free locals and self_ref via lambda lifting
let cg_make_pred_succ_law : Expr → Nat → CEnv
                           → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                           → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ wild_body wild_var env ce ctab hint →
      let free_vars = cg_free_vars wild_body (Cons wild_var Nil) env in
      let uses_self = cg_body_uses_self wild_body env in
      let g = cenv_globals env in
      let env0 = cenv_make g Nil 0 None in
      let env1 = match (nat_eq uses_self 0) {
                   | 0 →
                       match (cenv_self env) {
                         | None → env0
                         | Some fq → cenv_new_param env0 fq
                       }
                   | _ → env0
                 } in
      let env2 = cg_bind_params free_vars env1 in
      let env3 = cenv_new_param env2 wild_var in
      let body_val = ce wild_body env3 ctab 0 in
      let arity = cenv_arity env3 in
      let lifted_law = PPin (PLaw 0 (MkPair arity body_val)) in
      let result0 = match (nat_eq uses_self 0) {
                      | 0 →
                          match (nat_eq (cenv_arity env) 0) {
                            | 0 → cg_bapp lifted_law (PNat 0)
                            | _ → PApp lifted_law (PNat 0)
                          }
                      | _ → lifted_law
                    } in
      cg_apply_free_locals result0 free_vars env

-- cg_make_wild_succ: build succ function for the wild arm (no more named arms)
let cg_make_wild_succ : Option (Pair (Option Nat) Expr) → CEnv
                       → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                       → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ wild env ce ctab hint →
      let const2_pin = PPin const2_law in
      match wild {
        | None →
            let fallback = cg_quote_nat 0 (cenv_arity env) in
            match (nat_eq (cenv_arity env) 0) {
              | 0 → cg_bapp const2_pin fallback
              | _ → PApp const2_pin fallback
            }
        | Some p →
            match p {
              | MkPair wild_name_opt wild_body →
                  match wild_name_opt {
                    | None →
                        let wv = ce wild_body env ctab hint in
                        match (nat_eq (cenv_arity env) 0) {
                          | 0 → cg_bapp const2_pin wv
                          | _ → PApp const2_pin wv
                        }
                    | Some wild_var →
                        cg_make_pred_succ_law wild_body wild_var env ce ctab hint
                  }
            }
      }

-- cg_build_nat_dispatch: build nat dispatch using Case_ (opcode 3)
-- Self-recursive on the arm list; uses fresh pred_env for arms[1+]
let cg_build_nat_dispatch : List (Pair Nat Expr) → Option (Pair (Option Nat) Expr)
                           → PlanVal → CEnv
                           → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                           → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ arms wild scr env ce ctab hint →
      match arms {
        | Nil →
            match wild {
              | None → cg_quote_nat 0 (cenv_arity env)
              | Some p →
                  match p { | MkPair _ wb → ce wb env ctab hint }
            }
        | Cons arm0 rest →
            match arm0 {
              | MkPair _ body0 →
                  let zero_val = ce body0 env ctab hint in
                  let succ = match rest {
                                | Nil →
                                    cg_make_wild_succ wild env ce ctab hint
                                | Cons _ _ →
                                    let g = cenv_globals env in
                                    let pred_env = cenv_make g Nil 1 None in
                                    let inner = cg_build_nat_dispatch rest wild (PNat 1) pred_env ce ctab hint in
                                    PPin (PLaw 0 (MkPair 1 inner))
                              } in
                  cg_build_op2 zero_val succ scr (cenv_arity env)
            }
      }

-- cg_normalize_pv_tags: subtract (base+1) from tags in a (Nat, PlanVal) list
let cg_normalize_pv_tags : List (Pair Nat PlanVal) → Nat → List (Pair Nat PlanVal)
  = λ lst base →
      match lst {
        | Nil → Nil
        | Cons p rest →
            match p {
              | MkPair t v →
                  Cons (MkPair (sub t (add base 1)) v)
                       (cg_normalize_pv_tags rest base)
            }
      }

-- cg_build_precompiled_nat_dispatch: dispatch on already-compiled (tag, PlanVal) pairs
let cg_build_precompiled_nat_dispatch : List (Pair Nat PlanVal) → Option (Pair (Option Nat) Expr)
                                       → PlanVal → CEnv
                                       → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                                       → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ tag_val_pairs wild scr env ce ctab hint →
      match tag_val_pairs {
        | Nil →
            match wild {
              | None → cg_quote_nat 0 (cenv_arity env)
              | Some p → match p { | MkPair _ wb → ce wb env ctab hint }
            }
        | Cons pair0 rest →
            match pair0 {
              | MkPair tag0 zero_val →
                  let g = cenv_globals env in
                  let pred_env = cenv_make g Nil 1 None in
                  match rest {
                    | Nil →
                        -- Single entry. tag0=0: standard z dispatch.
                        -- tag0>0: build succ chain so zero_val fires at pred=tag0.
                        match (nat_eq tag0 0) {
                          | 0 →
                              -- tag0 > 0: shift by 1 and recurse to build succ chain
                              let shifted = Cons (MkPair (sub tag0 1) zero_val) Nil in
                              let inner = cg_build_precompiled_nat_dispatch shifted wild (PNat 1) pred_env ce ctab hint in
                              let succ = PPin (PLaw 0 (MkPair 1 inner)) in
                              let fallback = cg_quote_nat 0 (cenv_arity env) in
                              cg_build_op2 fallback succ scr (cenv_arity env)
                          | _ →
                              -- tag0 = 0: standard z dispatch
                              let succ = cg_make_wild_succ wild env ce ctab hint in
                              cg_build_op2 zero_val succ scr (cenv_arity env)
                        }
                    | Cons _ _ →
                        let normalized = cg_normalize_pv_tags rest tag0 in
                        let inner = cg_build_precompiled_nat_dispatch normalized wild (PNat 1) pred_env ce ctab hint in
                        let succ = PPin (PLaw 0 (MkPair 1 inner)) in
                        cg_build_op2 zero_val succ scr (cenv_arity env)
                  }
            }
      }

-- cg_compile_nat_match: compile a nat/bool match
let cg_compile_nat_match : PlanVal → List MatchArm → CEnv
                          → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                          → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ scr arms env ce ctab hint →
      let nat_arms = cg_extract_nat_arms arms in
      let wild = cg_extract_wild_arm arms in
      cg_build_nat_dispatch nat_arms wild scr env ce ctab hint


-- -------------------------------------------------------------------

-- -------------------------------------------------------------------
-- Layer 7: Constructor match compilation
-- -------------------------------------------------------------------

-- cg_arm_con_arity: arity of a con arm (number of field names)
let cg_arm_con_arity : MatchArm → Nat
  = λ arm → length (arm_get_con_fields arm)

-- cg_max_con_arity: maximum field count across con arms
let cg_max_con_arity : List MatchArm → Nat
  = λ arms →
      foldl (λ acc arm →
               let a = cg_arm_con_arity arm in
               match (lte acc a) {
                 | 0 → acc
                 | _ → a
               }) 0 arms

-- cg_filter_nullary_arms: keep ArmCon arms with 0 fields
let cg_filter_nullary_arms : List MatchArm → List MatchArm
  = λ arms →
      filter (λ arm → nat_eq (cg_arm_con_arity arm) 0) arms

-- cg_filter_field_arms: keep ArmCon arms with > 0 fields
let cg_filter_field_arms : List MatchArm → List MatchArm
  = λ arms →
      filter (λ arm →
                match (nat_eq (cg_arm_con_arity arm) 0) {
                  | 0 → 1
                  | _ → 0
                }) arms

-- cg_arms_to_tag_expr: convert con arms to (tag, body) pairs using ctab
let cg_arms_to_tag_expr : List MatchArm → List (Pair Nat (Pair Nat Nat)) → List (Pair Nat Expr)
  = λ arms ctab →
      map (λ arm →
             let con_name = arm_get_con_name arm in
             let tag = match (contab_lookup ctab con_name) {
                         | None → 0
                         | Some p → contab_tag p
                       } in
             MkPair tag (arm_get_con_body arm)) arms

-- cg_all_field_names: collect all field names across con arms
let cg_all_field_names : List MatchArm → List Nat
  = λ arms →
      foldl (λ acc arm → append acc (arm_get_con_fields arm)) Nil arms

-- cg_build_z_body: value for z (scrutinee = Nat 0) in reflect dispatch
let cg_build_z_body : List (Pair Nat Expr) → Option (Pair (Option Nat) Expr) → CEnv
                     → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                     → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ nullary_nat_arms wild env ce ctab →
      match (assoc_lookup 0 nullary_nat_arms) {
        | Some z_expr → ce z_expr env ctab 0
        | None →
            match wild {
              | None → cg_quote_nat 0 (cenv_arity env)
              | Some p → match p { | MkPair _ wb → ce wb env ctab 0 }
            }
      }

-- cg_build_nullary_remaining: (tag-1, body) pairs for nullary arms with tag > 0
let cg_build_nullary_remaining : List (Pair Nat Expr) → List (Pair Nat Expr)
  = λ nat_arms →
      foldr (λ p acc →
               match p {
                 | MkPair tag body →
                     match (nat_eq tag 0) {
                       | 0 → Cons (MkPair (sub tag 1) body) acc
                       | _ → acc
                     }
               }) Nil nat_arms

-- cg_build_m_body: m (succ fn) for remaining nullary constructors with tag > 0
let cg_build_m_body : List (Pair Nat Expr) → Option (Pair (Option Nat) Expr) → CEnv
                     → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                     → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ remaining wild env ce ctab →
      let const2_pin = PPin const2_law in
      match remaining {
        | Nil →
            match wild {
              | None →
                  match (nat_eq (cenv_arity env) 0) {
                    | 0 → cg_bapp const2_pin (PPin (PNat 0))
                    | _ → PApp const2_pin (PNat 0)
                  }
              | Some p →
                  match p {
                    | MkPair _ wb →
                        let wv = ce wb env ctab 0 in
                        match (nat_eq (cenv_arity env) 0) {
                          | 0 → cg_bapp const2_pin wv
                          | _ → PApp const2_pin wv
                        }
                  }
            }
        | Cons _ _ →
            let g = cenv_globals env in
            let pred_env = cenv_make g Nil 1 None in
            let m_inner = cg_build_nat_dispatch remaining wild (PNat 1) pred_env ce ctab 0 in
            PPin (PLaw 0 (MkPair 1 m_inner))
      }

-- cg_arm_find_by_tag: find a con arm whose ctab tag equals the given tag
let cg_arm_find_by_tag : List MatchArm → Nat → List (Pair Nat (Pair Nat Nat)) → MatchArm
  = λ arms tag ctab →
      match arms {
        | Nil →
            -- Return sentinel arm with empty body
            ArmCon 0 (MkPair Nil (EVar 0))
        | Cons arm rest →
            let con_tag = match (contab_lookup ctab (arm_get_con_name arm)) {
                            | None → 0
                            | Some p → contab_tag p
                          } in
            match (nat_eq con_tag tag) {
              | 0 → cg_arm_find_by_tag rest tag ctab
              | _ → arm
            }
      }

-- cg_build_unary_handler_body: handler body for arity-1 field arms
-- henv has [self?]+[free_locals]+[fun]+[arg] (arity = arg_idx)
-- fun_idx = arg_idx - 1, arg_idx = arg_idx
let cg_build_unary_handler_body : List MatchArm → Option (Pair (Option Nat) Expr)
                                  → CEnv → Nat → Nat
                                  → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                                  → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ field_arms wild henv fun_idx arg_idx ce ctab →
      match field_arms {
        | Nil → cg_quote_nat 0 (cenv_arity henv)
        | Cons arm0 rest_arms →
            match rest_arms {
              | Nil →
                  -- Single arm: bind field to arg_idx
                  let fields = arm_get_con_fields arm0 in
                  let ae = match fields {
                             | Nil → henv
                             | Cons fname _ → cenv_bind_local henv fname arg_idx
                           } in
                  ce (arm_get_con_body arm0) ae ctab 0
              | Cons _ _ →
                  -- Multiple arms: compile each body, dispatch on fun (tag)
                  let tag_val_pairs = map (λ arm →
                                            let fields = arm_get_con_fields arm in
                                            let ae = match fields {
                                                       | Nil → henv
                                                       | Cons fname _ → cenv_bind_local henv fname arg_idx
                                                     } in
                                            let tag = match (contab_lookup ctab (arm_get_con_name arm)) {
                                                        | None → 0
                                                        | Some p → contab_tag p
                                                      } in
                                            MkPair tag (ce (arm_get_con_body arm) ae ctab 0)
                                          ) field_arms in
                  cg_build_precompiled_nat_dispatch (cg_sort_pv_pairs tag_val_pairs)
                    wild (PNat fun_idx) henv ce ctab 0
            }
      }

-- cg_build_unary_z_body: compile the z handler for a unary (arity=1) arm with tag=0.
-- outer_fun = Nat 0 for such constructors → outer Case_ z fires.
-- The arm's field is bound to arg_idx (= outer_arg) in henv.
-- Falls back to constant 0 if no such arm exists.
let cg_build_unary_z_body : List MatchArm → CEnv → Nat
                             → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                             → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ field_arms henv arg_idx ce ctab →
      let tag0_arms = filter (λ arm →
                                match (nat_eq (cg_arm_con_arity arm) 1) {
                                  | 0 → 0
                                  | _ → match (contab_lookup ctab (arm_get_con_name arm)) {
                                          | None → 0
                                          | Some p → nat_eq (contab_tag p) 0
                                        }
                                }) field_arms in
      match tag0_arms {
        | Nil → cg_quote_nat 0 (cenv_arity henv)
        | Cons arm _ →
            let fields = arm_get_con_fields arm in
            let ae = match fields {
                       | Nil → henv
                       | Cons f _ → cenv_bind_local henv f arg_idx
                     } in
            ce (arm_get_con_body arm) ae ctab 0
      }

-- cg_build_unary_m_body: compile the m (succ) handler for unary (arity=1) arms with tag>0.
-- outer_fun = Nat(tag) → outer Case_ m fires with pred = tag-1.
-- Builds a succ law that dispatches on pred using cg_build_precompiled_nat_dispatch.
-- Each arm's field is bound to arg_idx (= outer_arg) in the extended env.
let cg_build_unary_m_body : List MatchArm → Option (Pair (Option Nat) Expr) → CEnv → Nat
                             → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                             → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ field_arms wild henv arg_idx ce ctab →
      let const2_pin = PPin const2_law in
      let unary_gt0 = filter (λ arm →
                                match (nat_eq (cg_arm_con_arity arm) 1) {
                                  | 0 → 0
                                  | _ → match (contab_lookup ctab (arm_get_con_name arm)) {
                                          | None → 0
                                          | Some p →
                                              match (nat_eq (contab_tag p) 0) {
                                                | 0 → 1
                                                | _ → 0
                                              }
                                        }
                                }) field_arms in
      match unary_gt0 {
        | Nil →
            -- No unary arms with tag>0: fall to constant-0 or wild
            match wild {
              | None →
                  match (nat_eq (cenv_arity henv) 0) {
                    | 0 → cg_bapp const2_pin (PPin (PNat 0))
                    | _ → PApp const2_pin (PNat 0)
                  }
              | Some p →
                  match p {
                    | MkPair _ wb →
                        let n_cap = cenv_arity henv in
                        let m_ext_env = cenv_set_arity henv (add n_cap 1) in
                        let m_compiled = ce wb m_ext_env ctab 0 in
                        let m_law = PPin (PLaw 0 (MkPair (add n_cap 1) m_compiled)) in
                        cg_apply_params m_law 1 n_cap
                  }
            }
        | Cons _ _ →
            -- Build a succ law: arity = n_cap+1 (captures + pred)
            -- Each arm's body compiled with field bound to arg_idx in m_ext_env
            let n_cap = cenv_arity henv in
            let pred_idx = add n_cap 1 in
            let m_ext_env = cenv_set_arity henv pred_idx in
            let m_pairs = cg_sort_pv_pairs (map (λ arm →
                let fields = arm_get_con_fields arm in
                let ae = match fields {
                           | Nil → m_ext_env
                           | Cons f _ → cenv_bind_local m_ext_env f arg_idx
                         } in
                let tag = match (contab_lookup ctab (arm_get_con_name arm)) {
                            | None → 0
                            | Some p → contab_tag p
                          } in
                MkPair (sub tag 1) (ce (arm_get_con_body arm) ae ctab 0)) unary_gt0) in
            let m_dispatch = cg_build_precompiled_nat_dispatch m_pairs wild (PNat pred_idx) m_ext_env ce ctab 0 in
            let m_succ_law = PPin (PLaw 0 (MkPair pred_idx m_dispatch)) in
            cg_apply_params m_succ_law 1 n_cap
      }

-- cg_build_binary_handler_body: handler body for arity-2 field arms
-- Receives uses_self and free_locals pre-computed by cg_build_app_handler
let cg_build_binary_handler_body : List MatchArm → Option (Pair (Option Nat) Expr)
                                   → CEnv → Nat → Nat → Nat → List Nat
                                   → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                                   → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ field_arms wild henv fun_idx arg_idx uses_self free_locals ce ctab →
      let g = cenv_globals henv in
      let inner_env0 = cenv_make g Nil 0 None in
      let inner_env1 = match (nat_eq uses_self 0) {
                         | 0 →
                             match (cenv_self henv) {
                               | None → inner_env0
                               | Some fq → cenv_new_param inner_env0 fq
                             }
                         | _ → inner_env0
                       } in
      let inner_env2 = cg_bind_params free_locals inner_env1 in
      -- field2 at (n_cap+1), inner_tag at (n_cap+2), field1 at (n_cap+3)
      let field2_idx = add (cenv_arity inner_env2) 1 in
      let inner_env3 = cenv_set_arity inner_env2 field2_idx in
      let inner_tag_idx = add field2_idx 1 in
      let field1_idx = add inner_tag_idx 1 in
      let inner_env4 = cenv_set_arity inner_env3 field1_idx in
      -- Compile each arm body in inner_env4 with field1 and field2 bound
      let inner_body = match field_arms {
                         | Nil → cg_quote_nat 0 (cenv_arity inner_env4)
                         | Cons arm0 rest_arms →
                             match rest_arms {
                               | Nil →
                                   let fields = arm_get_con_fields arm0 in
                                   let ae = match fields {
                                              | Nil → inner_env4
                                              | Cons f1 rest_fields →
                                                  let ae1 = cenv_bind_local inner_env4 f1 field1_idx in
                                                  match rest_fields {
                                                    | Nil → ae1
                                                    | Cons f2 _ → cenv_bind_local ae1 f2 field2_idx
                                                  }
                                            } in
                                   ce (arm_get_con_body arm0) ae ctab 0
                               | Cons _ _ →
                                   let tag_val_pairs = map (λ arm →
                                       let fields = arm_get_con_fields arm in
                                       let ae = match fields {
                                                  | Nil → inner_env4
                                                  | Cons f1 rfs →
                                                      let ae1 = cenv_bind_local inner_env4 f1 field1_idx in
                                                      match rfs {
                                                        | Nil → ae1
                                                        | Cons f2 _ → cenv_bind_local ae1 f2 field2_idx
                                                      }
                                                } in
                                       let tag = match (contab_lookup ctab (arm_get_con_name arm)) {
                                                   | None → 0
                                                   | Some p → contab_tag p
                                                 } in
                                       MkPair tag (ce (arm_get_con_body arm) ae ctab 0)) field_arms in
                                   cg_build_precompiled_nat_dispatch (cg_sort_pv_pairs tag_val_pairs)
                                     wild (PNat inner_tag_idx) inner_env4 ce ctab 0
                             }
                       } in
      let inner_law = PPin (PLaw 0 (MkPair field1_idx inner_body)) in
      -- Apply inner_law to: [self?]+[free_locals]+outer_arg
      let n_cap = cenv_arity inner_env2 in
      let r0 = inner_law in
      let r1 = match (nat_eq uses_self 0) {
                 | 0 →
                     match (nat_eq (cenv_arity henv) 0) {
                       | 0 → cg_bapp r0 (PNat 0)
                       | _ → PApp r0 (PNat 0)
                     }
                 | _ → r0
               } in
      let r2 = cg_apply_free_locals r1 free_locals henv in
      -- Apply outer_arg (field2) which is at arg_idx in henv
      let r3 = match (nat_eq (cenv_arity henv) 0) {
                 | 0 → cg_bapp r2 (PNat arg_idx)
                 | _ → PApp r2 (PNat arg_idx)
               } in
      -- Build outer Case_ on outer_fun (N(fun_idx)) with r3 as app handler.
      -- Unary arms (arity=1) never reach the inner law: outer_fun is a bare Nat.
      --   tag=0 → outer z fires (handled by cg_build_unary_z_body)
      --   tag>0 → outer m fires with pred=tag-1 (handled by cg_build_unary_m_body)
      let z_body = cg_build_unary_z_body field_arms henv arg_idx ce ctab in
      let m_body = cg_build_unary_m_body field_arms wild henv arg_idx ce ctab in
      cg_build_reflect_dispatch r3 z_body m_body (PNat fun_idx) (cenv_arity henv)

-- cg_bodies_use_self: check if any body in list uses self-ref
let cg_bodies_use_self : List Expr → CEnv → Nat
  = λ bodies env →
      foldl (λ acc body →
               match (nat_eq acc 1) {
                 | 0 → cg_body_uses_self body env
                 | _ → 1
               }) 0 bodies

-- cg_build_app_handler: build the App-handler law for Case_ dispatch
let cg_build_app_handler : List MatchArm → Option (Pair (Option Nat) Expr) → CEnv
                          → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                          → List (Pair Nat (Pair Nat Nat)) → PlanVal
  = λ field_arms wild env ce ctab →
      let all_bodies = map arm_get_con_body field_arms in
      let field_names = cg_all_field_names field_arms in
      let free_locals = cg_free_vars_bodies all_bodies field_names env in
      let uses_self = cg_bodies_use_self all_bodies env in
      let max_arity = cg_max_con_arity field_arms in
      let g = cenv_globals env in
      let henv0 = cenv_make g Nil 0 None in
      let henv1 = match (nat_eq uses_self 0) {
                    | 0 →
                        match (cenv_self env) {
                          | None → henv0
                          | Some fq → cenv_new_param henv0 fq
                        }
                    | _ → henv0
                  } in
      let henv2 = cg_bind_params free_locals henv1 in
      let n_cap = cenv_arity henv2 in
      let fun_idx = add n_cap 1 in
      let arg_idx = add n_cap 2 in
      let henv = cenv_set_arity henv2 arg_idx in
      let handler_body = match (nat_eq max_arity 1) {
                           | 0 →
                               cg_build_binary_handler_body field_arms wild henv fun_idx arg_idx uses_self free_locals ce ctab
                           | _ →
                               cg_build_unary_handler_body field_arms wild henv fun_idx arg_idx ce ctab
                         } in
      let handler_law = PPin (PLaw 0 (MkPair arg_idx handler_body)) in
      let r0 = handler_law in
      let r1 = match (nat_eq uses_self 0) {
                 | 0 →
                     match (nat_eq (cenv_arity env) 0) {
                       | 0 → cg_bapp r0 (PNat 0)
                       | _ → PApp r0 (PNat 0)
                     }
                 | _ → r0
               } in
      cg_apply_free_locals r1 free_locals env

-- cg_compile_con_match: compile a constructor match expression
let cg_compile_con_match : PlanVal → List MatchArm → CEnv
                          → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                          → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ scr arms env ce ctab hint →
      let con_arms = filter arm_is_con arms in
      let field_arms = cg_filter_field_arms con_arms in
      let nullary_arms = cg_filter_nullary_arms con_arms in
      let wild = cg_extract_wild_arm arms in
      match (length field_arms) {
        | 0 →
            let nat_arms = cg_sort_nat_pairs (cg_arms_to_tag_expr nullary_arms ctab) in
            cg_build_nat_dispatch nat_arms wild scr env ce ctab hint
        | _ →
            let nullary_nat_arms = cg_sort_nat_pairs (cg_arms_to_tag_expr nullary_arms ctab) in
            let z_body = cg_build_z_body nullary_nat_arms wild env ce ctab in
            let remaining = cg_build_nullary_remaining nullary_nat_arms in
            let m_body = cg_build_m_body remaining wild env ce ctab in
            let app_handler = cg_build_app_handler field_arms wild env ce ctab in
            cg_build_reflect_dispatch app_handler z_body m_body scr (cenv_arity env)
      }

-- cg_compile_fallback_match: wildcard/variable match (bind scrutinee if PatVar)
let cg_compile_fallback_match : PlanVal → List MatchArm → CEnv
                                → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                                → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ scr arms env ce ctab hint →
      match arms {
        | Nil → cg_quote_nat 0 (cenv_arity env)
        | Cons arm _ →
            match (arm_is_var arm) {
              | 0 → ce (cg_free_arm_body_of arm) env ctab hint
              | _ →
                  let var_name = arm_get_var_name arm in
                  let body = arm_get_var_body arm in
                  match (nat_eq var_name 0) {
                    | 0 →
                        -- Variable binding
                        match (nat_eq (cenv_arity env) 0) {
                          | 0 →
                              let new_idx = add (cenv_arity env) 1 in
                              let arm_env = cenv_bind_local (cenv_set_arity env new_idx) var_name new_idx in
                              let body_val = ce body arm_env ctab hint in
                              PApp (PApp (PNat 1) scr) body_val
                          | _ →
                              let arm_env = cenv_bind_global env var_name scr in
                              ce body arm_env ctab hint
                        }
                    | _ → ce body env ctab hint
                  }
            }
      }

-- -------------------------------------------------------------------
-- Layer 8: Lambda lifting
-- -------------------------------------------------------------------

-- cg_make_lifted_env: build env for lifted lambda (free_vars then params)
let cg_make_lifted_env : List Nat → List Nat → List (Pair Nat PlanVal) → Option Nat → CEnv
  = λ free_vars params globals self_ref →
      let env0 = cenv_make globals Nil 0 self_ref in
      let env1 = cg_bind_params free_vars env0 in
      cg_bind_params params env1

-- cg_compile_lam_as_law: compile lambda as a named top-level law (arity == 0 context)
let cg_compile_lam_as_law : List Nat → Expr → CEnv
                            → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                            → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ params body_expr env ce ctab hint →
      let g = cenv_globals env in
      let self = cenv_self env in
      let body_env = cg_make_lifted_env Nil params g self in
      let body_val = ce body_expr body_env ctab 0 in
      PLaw hint (MkPair (length params) body_val)

-- cg_compile_lam_lifted: lambda-lift a nested lambda (arity > 0 context)
let cg_compile_lam_lifted : List Nat → Expr → CEnv
                            → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                            → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ params body_expr env ce ctab hint →
      let free_vars = cg_free_vars body_expr params env in
      let g = cenv_globals env in
      let lifted_env = cg_make_lifted_env free_vars params g None in
      let body_val = ce body_expr lifted_env ctab 0 in
      let total_arity = add (length free_vars) (length params) in
      let lifted_law = PPin (PLaw hint (MkPair total_arity body_val)) in
      cg_apply_free_locals lifted_law free_vars env


-- -------------------------------------------------------------------
-- Layer 9: Per-expression compilers and main dispatch
-- -------------------------------------------------------------------

-- cg_is_nat_match: does the arm list contain any ArmNat arms?
let cg_is_nat_match : List MatchArm → Nat
  = λ arms → foldl (λ acc arm → if nat_eq acc 1 then 1 else arm_is_nat arm) 0 arms

-- cg_is_con_match: does the arm list contain any ArmCon arms?
let cg_is_con_match : List MatchArm → Nat
  = λ arms → foldl (λ acc arm → if nat_eq acc 1 then 1 else arm_is_con arm) 0 arms

-- cg_var_from_env: look up variable name in locals then globals
-- (must be defined before cg_compile_var)
let cg_var_from_env : Nat → CEnv → PlanVal
  = λ n env →
      match (cenv_local_lookup env n) {
        | Some idx → PNat idx
        | None →
            match (cenv_global_lookup env n) {
              | Some val →
                  match (nat_eq (cenv_arity env) 0) {
                    | 0 →
                        -- Inside law body: nat globals need quoting
                        match (planval_is_nat val) {
                          | 0 →
                              match (planval_is_pin val) {
                                | 0 → PPin val
                                | _ → val
                              }
                          | _ → cg_quote_nat (planval_get_nat val) (cenv_arity env)
                        }
                    | _ → val
                  }
              | None → PNat 0  -- unbound: return 0 (error in source)
            }
      }

-- cg_compile_var: compile EVar
let cg_compile_var : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ expr env ctab hint →
      match expr {
        | EVar n →
            -- 1. Self-reference: inside a law body (arity>0), own FQ name → N(0)
            match (nat_eq (cenv_arity env) 0) {
              | 0 →
                  match (cenv_self env) {
                    | None → cg_var_from_env n env
                    | Some fq →
                        match (nat_eq n fq) {
                          | 0 → cg_var_from_env n env
                          | _ → PNat 0
                        }
                  }
              | _ → cg_var_from_env n env
            }
        | _ → PNat 0
      }

-- cg_compile_app: compile EApp
let cg_compile_app : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                   → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EApp f a →
            let fv = ce f env ctab hint in
            let av = ce a env ctab hint in
            cg_apply fv av (cenv_arity env)
        | _ → PNat 0
      }

-- cg_compile_enat: compile ENat
let cg_compile_enat : Expr → CEnv → Nat → PlanVal
  = λ expr env hint →
      match expr {
        | ENat n → cg_quote_nat n (cenv_arity env)
        | _ → PNat 0
      }

-- cg_compile_elet: compile ELet (local let binding)
let cg_compile_elet : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                    → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | ELet name pair →
            match pair {
              | MkPair rhs body →
                  let rhs_val = ce rhs env ctab name in
                  match (nat_eq (cenv_arity env) 0) {
                    | 0 →
                        -- Law body: PLAN let form A(A(N(1), rhs), body)
                        let new_idx = add (cenv_arity env) 1 in
                        let body_env = cenv_bind_local (cenv_set_arity env new_idx) name new_idx in
                        let body_val = ce body body_env ctab hint in
                        PApp (PApp (PNat 1) rhs_val) body_val
                    | _ →
                        -- Top level: add to globals
                        let body_env = cenv_bind_global env name rhs_val in
                        ce body body_env ctab hint
                  }
            }
        | _ → PNat 0
      }

-- cg_compile_if: compile EIf using Case_ (opcode 3)
let cg_compile_if : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                  → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EIf cond pair →
            match pair {
              | MkPair then_ else_ →
                  let cond_v = ce cond env ctab hint in
                  let then_v = ce then_ env ctab hint in
                  let else_v = ce else_ env ctab hint in
                  let const2_pin = PPin const2_law in
                  let const_then = cg_apply const2_pin then_v (cenv_arity env) in
                  cg_build_op2 else_v const_then cond_v (cenv_arity env)
            }
        | _ → PNat 0
      }

-- cg_compile_fix: compile EFix (fix λ self params → body)
-- Creates a law with arity = length(params). N(0) = self, N(1..n) = params.
-- self_name is bound via cenv_self so cg_compile_var returns PNat 0 for it.
let cg_compile_fix : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                   → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EFix self_name p →
            match p {
              | MkPair params body →
                  -- Start fresh: globals preserved, locals cleared, arity=0
                  -- self_name goes into cenv_self so references to it become N(0)
                  let g = cenv_globals env in
                  let env0 = cenv_make g Nil 0 (Some self_name) in
                  -- Bind each user param at N(1), N(2), ... via cenv_new_param
                  let env1 = cg_bind_params params env0 in
                  let body_val = ce body env1 ctab 0 in
                  PLaw hint (MkPair (length params) body_val)
            }
        | _ → PNat 0
      }

-- cg_compile_match: compile EMatch
let cg_compile_match : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                     → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EMatch scr arms →
            let scr_v = ce scr env ctab hint in
            match (cg_is_nat_match arms) {
              | 0 →
                  match (cg_is_con_match arms) {
                    | 0 →
                        cg_compile_fallback_match scr_v arms env ce ctab hint
                    | _ →
                        cg_compile_con_match scr_v arms env ce ctab hint
                  }
              | _ →
                  cg_compile_nat_match scr_v arms env ce ctab hint
            }
        | _ → PNat 0
      }

-- cg_compile_lam: compile ELam (lambda expression)
let cg_compile_lam : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                   → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match (cg_flatten_lam expr) {
        | MkPair params body_expr →
            match (nat_eq (cenv_arity env) 0) {
              | 0 →
                  -- Top-level: compile as named law
                  cg_compile_lam_lifted params body_expr env ce ctab hint
              | _ →
                  -- Top-level (arity=0): compile as named law
                  cg_compile_lam_as_law params body_expr env ce ctab hint
            }
      }

-- cg_compile_pin: compile EPin (@name = rhs; body)
let cg_compile_pin : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                   → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EPin name pair →
            match pair {
              | MkPair rhs body →
                  let rhs_val = ce rhs env ctab name in
                  let pinned = cg_ensure_pin rhs_val in
                  let body_env = cenv_bind_global env name pinned in
                  ce body body_env ctab hint
            }
        | _ → PNat 0
      }

-- =====================================================================
-- CPS Effect Constants (must precede handler codegen)
-- =====================================================================

-- _id_law: L(1, 0, N(1)) — identity function
let cps_id_law : PlanVal = PLaw 0 (MkPair 1 (PNat 1))

-- _null_dispatch: L(3, name, P(0)) — drops all args, returns P(0)
let nn_null_dispatch : Nat = 0x68637461707369645f6c6c756e5f  -- "_null_dispatch"
let cps_null_dispatch : PlanVal = PLaw nn_null_dispatch (MkPair 3 (PPin (PNat 0)))

-- _compose: L(3, name, A(N(1), A(N(2), N(3)))) — compose(f, g, x) = f(g(x))
let nn_compose : Nat = 0x65736f706d6f635f  -- "_compose"
let cps_compose : PlanVal = PLaw nn_compose (MkPair 3 (PApp (PNat 1) (PApp (PNat 2) (PNat 3))))

-- pure_law: L(3, "pure", A(N(3), N(1))) — pure v dispatch k = k(v)
let cps_pure_law : PlanVal = PLaw kw_pure (MkPair 3 (PApp (PNat 3) (PNat 1)))

-- run_law: L(1, "run", A(A(N(1), P(null_dispatch)), P(id_law)))
-- run comp = comp(null_dispatch, id)
let cps_run_law : PlanVal
  = PLaw kw_run (MkPair 1 (PApp (PApp (PNat 1) (PPin cps_null_dispatch)) (PPin cps_id_law)))

-- =====================================================================
-- CPS Effect Handler Codegen
-- =====================================================================

-- cg_build_handle_dispatch: build nested nat_eq dispatch on op_tag
-- Each op arm gets a sequential tag (starting from tag_counter).
-- Compiled body binds op_arg at op_arg_idx and k at k_idx.
let cg_build_handle_dispatch
      : List (Pair Nat (Pair Nat Expr)) → CEnv → Nat → Nat → Nat → PlanVal
      → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
      → List (Pair Nat (Pair Nat Nat)) → Nat → Nat → PlanVal
  = λ arms dispatch_env k_idx op_arg_idx op_tag_idx forward_body ce ctab hint tag →
      match arms {
        | Nil → forward_body
        | Cons arm rest →
            match arm {
              | MkPair op_name inner →
                  match inner {
                    | MkPair k_name body →
                        let arm_env = cenv_bind_local dispatch_env k_name k_idx in
                        let arm_env2 = cenv_bind_local arm_env op_name op_arg_idx in
                        let body_val = ce body arm_env2 ctab hint in
                        let tag_val = cg_quote_nat tag (cenv_arity dispatch_env) in
                        let rest_body = cg_build_handle_dispatch rest dispatch_env k_idx op_arg_idx op_tag_idx forward_body ce ctab hint (add tag 1) in
                        let eq_test = cg_bapp (cg_bapp (PPin (PNat 3)) (PNat op_tag_idx)) tag_val in
                        let const_body = PLaw 0 (MkPair 1 body_val) in
                        let const_pin = PPin const_body in
                        cg_build_op2 rest_body const_pin eq_test (cenv_arity dispatch_env)
                  }
            }
      }

-- cg_compile_dispatch_fn: build dispatch law for handle expression
-- Dispatch law: L(n_cap+4, name, body)
-- Slots: [cap_1..cap_n] [dispatch_parent] [op_tag] [op_arg] [resume/k]
-- Each arm matches on op_tag; unhandled tags forward to dispatch_parent.
let cg_compile_dispatch_fn
      : List (Pair Nat (Pair Nat Expr)) → CEnv
      → List (Pair Nat (Pair Nat Nat)) → Nat
      → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ op_arms env ctab hint ce →
      match op_arms {
        | Nil →
            -- No op arms: pure forwarder — dispatch_parent(tag, arg, k)
            PPin (PLaw hint (MkPair 4
              (cg_bapp (cg_bapp (cg_bapp (PNat 1) (PNat 2)) (PNat 3)) (PNat 4))))
        | _ →
            -- Collect free vars from all arm bodies
            let all_bodies = map (λ arm →
                                    match arm {
                                      | MkPair _ inner →
                                          match inner { | MkPair _ body → body }
                                    }) op_arms in
            let free_vars = cg_free_vars_bodies all_bodies Nil env in
            let n_cap = length free_vars in
            let total_arity = add n_cap 4 in
            let dp_idx     = add n_cap 1 in
            let op_tag_idx = add n_cap 2 in
            let op_arg_idx = add n_cap 3 in
            let k_idx      = add n_cap 4 in
            -- Build dispatch env: [caps] + [dp] + [tag] + [arg] + [k]
            let g = cenv_globals env in
            let dispatch_env0 = cenv_make g Nil 0 None in
            let dispatch_env1 = cg_bind_params free_vars dispatch_env0 in
            let dispatch_env = cenv_set_arity dispatch_env1 total_arity in
            -- Forward body: dispatch_parent(tag, arg, k)
            let forward_body = cg_bapp (cg_bapp (cg_bapp (PNat dp_idx) (PNat op_tag_idx)) (PNat op_arg_idx)) (PNat k_idx) in
            -- Build tag dispatch: simple nat ladder on op_tag
            -- For now use single-arm dispatch (tag 0 = first arm, forward rest)
            let dispatch_body = cg_build_handle_dispatch op_arms dispatch_env k_idx op_arg_idx op_tag_idx forward_body ce ctab hint 0 in
            let dispatch_law = PPin (PLaw hint (MkPair total_arity dispatch_body)) in
            cg_apply_free_locals dispatch_law free_vars env
      }

-- cg_compile_return_fn: build return handler law
-- L(n_cap+1, name, body) where last param is the pure return value.
let cg_compile_return_fn
      : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat
      → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ ret_fn env ctab hint ce →
      match ret_fn {
        | ELam ret_var ret_body →
            let free_vars = cg_free_vars ret_body (Cons ret_var Nil) env in
            let n_cap = length free_vars in
            let total_arity = add n_cap 1 in
            let val_idx = add n_cap 1 in
            let g = cenv_globals env in
            let ret_env0 = cenv_make g Nil 0 None in
            let ret_env1 = cg_bind_params free_vars ret_env0 in
            let ret_env2 = cenv_set_arity ret_env1 total_arity in
            let ret_env3 = cenv_bind_local ret_env2 ret_var val_idx in
            let body_val = ce ret_body ret_env3 ctab hint in
            let ret_law = PPin (PLaw hint (MkPair total_arity body_val)) in
            cg_apply_free_locals ret_law free_vars env
        | _ →
            -- Default: identity
            PPin cps_id_law
      }

-- cg_compile_handle: compile EHandle expression
-- handle comp { | return x → body_r | op arg k → body_op }
-- Produces: λ(dp, ko) → comp(dispatch(dp), compose(ko, ret_fn))
let cg_compile_handle
      : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
      → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EHandle comp pair →
            match pair {
              | MkPair ret_fn op_arms →
                  -- Collect all free vars
                  let comp_free = cg_collect_free comp Nil env Nil in
                  let ret_free = cg_collect_free ret_fn Nil env Nil in
                  let all_found = append comp_free ret_free in
                  let free_vars = cg_keep_free_locals (cenv_locals env) all_found Nil in
                  let n_cap = length free_vars in
                  -- CPS handle law: arity = n_cap + 2 [caps, dp, ko]
                  let total_arity = add n_cap 2 in
                  let dp_idx = add n_cap 1 in
                  let ko_idx = add n_cap 2 in
                  -- Build cps env
                  let g = cenv_globals env in
                  let cps_env0 = cenv_make g Nil 0 None in
                  let cps_env1 = cg_bind_params free_vars cps_env0 in
                  let cps_env = cenv_set_arity cps_env1 total_arity in
                  -- Compile comp in cps env
                  let comp_val = ce comp cps_env ctab hint in
                  -- Build dispatch function
                  let dispatch_fn = cg_compile_dispatch_fn op_arms cps_env ctab hint ce in
                  -- Build return function
                  let return_fn = cg_compile_return_fn ret_fn cps_env ctab hint ce in
                  -- dispatch(dp): apply dp as first arg to dispatch_fn
                  let dispatch_applied = cg_bapp dispatch_fn (PNat dp_idx) in
                  -- composed_k = compose(ko, return_fn) = λ x → ko(return_fn(x))
                  let composed_k = cg_bapp (cg_bapp (PPin cps_compose) (PNat ko_idx)) return_fn in
                  -- CPS body: comp(dispatch(dp), composed_k)
                  let cps_body = cg_bapp (cg_bapp comp_val dispatch_applied) composed_k in
                  let cps_law = PLaw hint (MkPair total_arity cps_body) in
                  -- Apply to captures
                  match (nat_eq (cenv_arity env) 0) {
                    | 0 → PPin cps_law
                    | _ →
                        let pinned = PPin cps_law in
                        cg_apply_free_locals pinned free_vars env
                  }
            }
        | _ → PNat 0
      }

-- cg_apply_range: partially apply val to N(start)..N(end_inclusive) via cg_bapp
let cg_apply_range : PlanVal → Nat → Nat → PlanVal
  = λ v start end_idx →
      match (lte start end_idx) {
        | 0 → v
        | _ → cg_apply_range (cg_bapp v (PNat start)) (add start 1) end_idx
      }

-- cg_compile_do: compile EDo (x ← rhs in body)
-- Outer law: arity = n_cap+2 [caps, dispatch, k_outer]
-- Inner cont law: arity = n_cap+3 [caps, dispatch, k_outer, x]
-- Outer body: rhs_comp dispatch inner_cont
let cg_compile_do
      : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
      → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match expr {
        | EDo bind_name pair →
            match pair {
              | MkPair rhs body →
                  -- Collect free vars from rhs and body
                  let rhs_free  = cg_collect_free rhs Nil env Nil in
                  let body_free = cg_collect_free body (Cons bind_name Nil) env Nil in
                  let all_found = append rhs_free body_free in
                  let free_vars = cg_keep_free_locals (cenv_locals env) all_found Nil in
                  let n_cap = length free_vars in
                  -- Outer law: arity = n_cap + 2
                  let outer_dispatch_idx = add n_cap 1 in
                  let outer_k_idx        = add n_cap 2 in
                  -- Inner continuation: arity = n_cap + 3
                  let inner_dispatch_idx = add n_cap 1 in
                  let inner_k_idx        = add n_cap 2 in
                  let inner_x_idx        = add n_cap 3 in
                  -- Build inner env
                  let g = cenv_globals env in
                  let inner_env0 = cenv_make g Nil 0 None in
                  let inner_env1 = cg_bind_params free_vars inner_env0 in
                  let inner_env2 = cenv_set_arity inner_env1 (add n_cap 3) in
                  let inner_env3 = cenv_bind_local inner_env2 bind_name inner_x_idx in
                  -- Compile body in inner env
                  let body_cps = ce body inner_env3 ctab hint in
                  -- Inner body: body_cps(dispatch, k_outer)
                  let inner_body = cg_bapp (cg_bapp body_cps (PNat inner_dispatch_idx)) (PNat inner_k_idx) in
                  let inner_law = PPin (PLaw hint (MkPair (add n_cap 3) inner_body)) in
                  -- Build outer env
                  let outer_env0 = cenv_make g Nil 0 None in
                  let outer_env1 = cg_bind_params free_vars outer_env0 in
                  let outer_env  = cenv_set_arity outer_env1 (add n_cap 2) in
                  -- Compile rhs in outer env
                  let rhs_val = ce rhs outer_env ctab hint in
                  -- Apply inner_law to captures + dispatch + k_outer
                  let inner_applied = cg_apply_range inner_law 1 n_cap in
                  let inner_cont = cg_bapp (cg_bapp inner_applied (PNat outer_dispatch_idx)) (PNat outer_k_idx) in
                  -- Outer body: rhs_comp(dispatch, inner_cont)
                  let outer_body = cg_bapp (cg_bapp rhs_val (PNat outer_dispatch_idx)) inner_cont in
                  let do_law = PLaw hint (MkPair (add n_cap 2) outer_body) in
                  -- Apply to captures
                  match (nat_eq (cenv_arity env) 0) {
                    | 0 → do_law
                    | _ →
                        let pinned = PPin do_law in
                        cg_apply_free_locals pinned free_vars env
                  }
            }
        | _ → PNat 0
      }

-- cg_compile_complex: route non-EVar, non-ENat, non-EApp expressions
-- Uses nat_eq chain on expr_tag (pred_env safe: all bodies take ce as param)
let cg_compile_complex : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
                       → (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal) → PlanVal
  = λ expr env ctab hint ce →
      match (nat_eq (expr_tag expr) 2) {
        | 0 →
            match (nat_eq (expr_tag expr) 3) {
              | 0 →
                  match (nat_eq (expr_tag expr) 5) {
                    | 0 →
                        match (nat_eq (expr_tag expr) 6) {
                          | 0 →
                              match (nat_eq (expr_tag expr) 7) {
                                | 0 →
                                    match (nat_eq (expr_tag expr) 8) {
                                      | 0 →
                                          match (nat_eq (expr_tag expr) 9) {
                                            | 0 →
                                                -- EDo (tag 10)
                                                cg_compile_do expr env ctab hint ce
                                            | _ →
                                                -- EHandle (tag 9)
                                                cg_compile_handle expr env ctab hint ce
                                          }
                                      | _ →
                                          -- EFix (tag 8)
                                          cg_compile_fix expr env ctab hint ce
                                    }
                                | _ →
                                    -- EPin (tag 7)
                                    cg_compile_pin expr env ctab hint ce
                              }
                          | _ →
                              -- EMatch (tag 6)
                              cg_compile_match expr env ctab hint ce
                        }
                    | _ →
                        -- EIf (tag 5)
                        cg_compile_if expr env ctab hint ce
                  }
              | _ →
                  -- ELet (tag 3)
                  cg_compile_elet expr env ctab hint ce
            }
        | _ →
            -- ELam (tag 2)
            cg_compile_lam expr env ctab hint ce
      }

-- cg_dispatch: main expression dispatch (routes to per-constructor handlers)
-- ce: the compile_expr function (passed for recursion — ties the knot)
let cg_dispatch : (Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal)
                → Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ ce expr env ctab hint →
      match (nat_eq (expr_tag expr) 0) {
        | 0 →
            match (nat_eq (expr_tag expr) 4) {
              | 0 →
                  match (nat_eq (expr_tag expr) 1) {
                    | 0 →
                        -- Complex expression (ELam/ELet/EIf/EMatch/EPin)
                        cg_compile_complex expr env ctab hint ce
                    | _ →
                        -- EApp (tag 1)
                        cg_compile_app expr env ctab hint ce
                  }
              | _ →
                  -- ENat (tag 4)
                  cg_compile_enat expr env hint
            }
        | _ →
            -- EVar (tag 0)
            cg_compile_var expr env ctab hint
      }

-- cg_compile_expr: main compiler entry point (self-recursive via cg_dispatch)
let cg_compile_expr : Expr → CEnv → List (Pair Nat (Pair Nat Nat)) → Nat → PlanVal
  = λ expr env ctab hint →
      cg_dispatch cg_compile_expr expr env ctab hint

-- -------------------------------------------------------------------
-- Layer 10: Program passes
-- -------------------------------------------------------------------

-- name_concat_dot: "mod" ++ "." ++ "item" as little-endian nat
let name_concat_dot : Nat → Nat → Nat
  = λ mod_name item_name →
      let blen = nat_byte_len mod_name in
      let dot = shift_left 0x2E (mul 8 blen) in
      let item_shifted = shift_left item_name (mul 8 (add blen 1)) in
      bit_or (bit_or mod_name dot) item_shifted

-- name_concat_under: "a" ++ "_" ++ "b" as little-endian nat
let name_concat_under : Nat → Nat → Nat
  = λ a_name b_name →
      let blen = nat_byte_len a_name in
      let under = shift_left 0x5F (mul 8 blen) in
      let b_shifted = shift_left b_name (mul 8 (add blen 1)) in
      bit_or (bit_or a_name under) b_shifted

-- Precomputed name nats for Core.PLAN opcodes
-- These are int.from_bytes(s.encode('utf-8'), 'little') values
let nn_Core_PLAN : Nat = 1443551261620241067843
let nn_pin   : Nat = 7235952
let nn_mk_law : Nat = 131260313725805
let nn_inc   : Nat = 6516329
let nn_reflect : Nat = 32760384559932786
let nn_force  : Nat = 435460140902

-- cg_core_plan_opcodes: list of (fq_name_nat, opcode) for Core.PLAN externals
let cg_core_plan_opcodes : List (Pair Nat Nat)
  = Cons (MkPair (name_concat_dot nn_Core_PLAN nn_pin) 0)
    (Cons (MkPair (name_concat_dot nn_Core_PLAN nn_mk_law) 1)
    (Cons (MkPair (name_concat_dot nn_Core_PLAN nn_inc) 2)
    (Cons (MkPair (name_concat_dot nn_Core_PLAN nn_reflect) 3)
    (Cons (MkPair (name_concat_dot nn_Core_PLAN nn_force) 4)
    Nil))))

-- Builtin name nats
let nn_False : Nat = 435728179526
let nn_True  : Nat = 1702195796
let nn_Unit  : Nat = 1953066581

let cg_register_builtins : CEnv → CEnv
  = λ env →
      cenv_bind_global
        (cenv_bind_global
          (cenv_bind_global
            (cenv_bind_global
              (cenv_bind_global env nn_False (PNat 0))
              nn_True (PNat 1))
            nn_Unit (PNat 0))
          kw_pure cps_pure_law)
        kw_run cps_run_law

-- cg_register_builtin_contab: add False, True, Unit to contab
let cg_register_builtin_contab : List (Pair Nat (Pair Nat Nat)) → List (Pair Nat (Pair Nat Nat))
  = λ ctab →
      contab_insert
        (contab_insert
          (contab_insert ctab nn_False (MkPair 0 0))
          nn_True (MkPair 1 0))
        nn_Unit (MkPair 0 0)

-- cg_register_type_one: register one ConDef with given tag and module name
let cg_register_type_one : ConDef → Nat → Nat → CEnv → List (Pair Nat (Pair Nat Nat))
                           → List (Pair Nat PlanVal) → Pair CEnv (Pair (List (Pair Nat (Pair Nat Nat))) (List (Pair Nat PlanVal)))
  = λ cdef tag mod_name env ctab compiled →
      match cdef {
        | MkConDef con_name n_fields →
            let fq_name = name_concat_dot mod_name con_name in
            let val = match (nat_eq n_fields 0) {
                        | 0 →
                            -- Has fields: build constructor law
                            PLaw con_name (MkPair n_fields (cg_build_constructor_body tag n_fields))
                        | _ →
                            -- Nullary: bare nat tag
                            PNat tag
                      } in
            let new_env = cenv_bind_global env fq_name val in
            let new_ctab = contab_insert ctab fq_name (MkPair tag n_fields) in
            let new_compiled = Cons (MkPair fq_name val) compiled in
            MkPair new_env (MkPair new_ctab new_compiled)
      }

-- cg_register_type_go must be defined before cg_register_type (forward ref fix)
let cg_register_type_go : List ConDef → Nat → Nat → CEnv → List (Pair Nat (Pair Nat Nat))
                          → List (Pair Nat PlanVal)
                          → Pair CEnv (Pair (List (Pair Nat (Pair Nat Nat))) (List (Pair Nat PlanVal)))
  = λ cdefs tag mod_name env ctab compiled →
      match cdefs {
        | Nil → MkPair env (MkPair ctab compiled)
        | Cons cdef rest →
            match (cg_register_type_one cdef tag mod_name env ctab compiled) {
              | MkPair new_env rest_pair →
                  match rest_pair {
                    | MkPair new_ctab new_compiled →
                        cg_register_type_go rest (add tag 1) mod_name new_env new_ctab new_compiled
                  }
            }
      }

-- cg_register_type: register all constructors of a DType decl
let cg_register_type : List ConDef → Nat → Nat → CEnv → List (Pair Nat (Pair Nat Nat))
                      → List (Pair Nat PlanVal)
                      → Pair CEnv (Pair (List (Pair Nat (Pair Nat Nat))) (List (Pair Nat PlanVal)))
  = λ cdefs mod_name type_name env ctab compiled →
      cg_register_type_go cdefs 0 mod_name env ctab compiled

-- cg_pass1: process DType declarations
let cg_pass1 : List Decl → Nat → CEnv → List (Pair Nat (Pair Nat Nat)) → List (Pair Nat PlanVal)
             → Pair CEnv (Pair (List (Pair Nat (Pair Nat Nat))) (List (Pair Nat PlanVal)))
  = λ decls mod_name env ctab compiled →
      match decls {
        | Nil → MkPair env (MkPair ctab compiled)
        | Cons decl rest →
            let result = match (nat_eq (decl_is_type decl) 0) {
                           | 0 →
                               let type_name = decl_get_type_name decl in
                               cg_register_type (decl_get_type_cdefs decl) mod_name type_name env ctab compiled
                           | _ → MkPair env (MkPair ctab compiled)
                         } in
            match result {
              | MkPair new_env rest_pair →
                  match rest_pair {
                    | MkPair new_ctab new_compiled →
                        cg_pass1 rest mod_name new_env new_ctab new_compiled
                  }
            }
      }

-- cg_register_ext_item: register one external item
let cg_register_ext_item : Nat → Nat → CEnv → List (Pair Nat PlanVal) → Pair CEnv (List (Pair Nat PlanVal))
  = λ fq_name opcode_or_sentinel env compiled →
      let val = PPin (PNat opcode_or_sentinel) in
      MkPair (cenv_bind_global env fq_name val) (Cons (MkPair fq_name val) compiled)

-- cg_lookup_opcode: look up fq_name in core plan opcodes, returns opcode or encode of name
let cg_lookup_opcode : Nat → Nat
  = λ fq_name →
      match (assoc_lookup fq_name cg_core_plan_opcodes) {
        | Some op → op
        | None → fq_name  -- opaque sentinel: pin the name nat itself
      }

-- cg_register_ext_items: register all items for one ext module
let cg_register_ext_items : List Nat → Nat → CEnv → List (Pair Nat PlanVal) → Pair CEnv (List (Pair Nat PlanVal))
  = λ items mod_name env compiled →
      match items {
        | Nil → MkPair env compiled
        | Cons item_name rest →
            let fq_name = name_concat_dot mod_name item_name in
            let op = cg_lookup_opcode fq_name in
            match (cg_register_ext_item fq_name op env compiled) {
              | MkPair new_env new_compiled →
                  cg_register_ext_items rest mod_name new_env new_compiled
            }
      }

-- cg_pass2: process DExt declarations
let cg_pass2 : List Decl → Nat → CEnv → List (Pair Nat PlanVal) → Pair CEnv (List (Pair Nat PlanVal))
  = λ decls mod_name env compiled →
      match decls {
        | Nil → MkPair env compiled
        | Cons decl rest →
            let result = match (nat_eq (decl_is_ext decl) 0) {
                           | 0 →
                               let ext_mod = decl_get_ext_mod decl in
                               cg_register_ext_items (decl_get_ext_items decl) ext_mod env compiled
                           | _ → MkPair env compiled
                         } in
            match result {
              | MkPair new_env new_compiled →
                  cg_pass2 rest mod_name new_env new_compiled
            }
      }

-- cg_compile_let_one: compile one DLet declaration
let cg_compile_let_one : Nat → Expr → Nat → CEnv → List (Pair Nat (Pair Nat Nat)) → List (Pair Nat PlanVal)
                        → Pair CEnv (List (Pair Nat PlanVal))
  = λ name body mod_name env ctab compiled →
      let fq_name = name_concat_dot mod_name name in
      let fq_env = cenv_set_self (cenv_set_arity env 0) (Some fq_name) in
      let val = cg_compile_expr body fq_env ctab name in
      let new_env = cenv_bind_global env fq_name val in
      MkPair new_env (Cons (MkPair fq_name val) compiled)

-- cg_compile_inst_members: compile each method body in a DInst
let cg_compile_inst_members
      : List (Pair Nat Expr) → Nat → Nat → CEnv → List (Pair Nat (Pair Nat Nat)) → List (Pair Nat PlanVal)
      → Pair CEnv (List (Pair Nat PlanVal))
  = λ members inst_prefix mod_name env ctab compiled →
      match members {
        | Nil → MkPair env compiled
        | Cons pair rest →
            match pair {
              | MkPair method_name body →
                  let bare    = name_concat_under inst_prefix method_name in
                  let fq_name = name_concat_dot mod_name bare in
                  let fq_env  = cenv_set_self (cenv_set_arity env 0) (Some fq_name) in
                  let val     = cg_compile_expr body fq_env ctab bare in
                  let new_env = cenv_bind_global env fq_name val in
                  cg_compile_inst_members rest inst_prefix mod_name new_env ctab
                    (Cons (MkPair fq_name val) compiled)
            }
      }

-- cg_register_eff_ops: register each op of one DEff as a 3-arg CPS law
-- Each op: L(3, op_name, dispatch(tag, op_arg, k))
-- N(1)=op_arg, N(2)=dispatch, N(3)=k
-- body = A(A(A(N(2), tag_val), N(1)), N(3))
let cg_register_eff_ops
      : List Nat → Nat → Nat → CEnv → List (Pair Nat PlanVal) → Nat
      → Pair CEnv (Pair (List (Pair Nat PlanVal)) Nat)
  = λ ops eff_fq mod_name env compiled tag →
      match ops {
        | Nil → MkPair env (MkPair compiled tag)
        | Cons op_name rest →
            let fq_op = name_concat_dot eff_fq op_name in
            -- Tag literal in a 3-arg law: quote if tag <= 3
            let tag_val = cg_quote_nat tag 3 in
            -- body = dispatch(tag, op_arg, k) = A(A(A(N(2), tag_val), N(1)), N(3))
            let body = cg_bapp (cg_bapp (cg_bapp (PNat 2) tag_val) (PNat 1)) (PNat 3) in
            let val = PLaw op_name (MkPair 3 body) in
            let new_env = cenv_bind_global (cenv_bind_global env fq_op val) op_name val in
            let new_compiled = Cons (MkPair fq_op val) compiled in
            cg_register_eff_ops rest eff_fq mod_name new_env new_compiled (add tag 1)
      }

-- cg_register_effs: process all DEff declarations
let cg_register_effs
      : List Decl → Nat → CEnv → List (Pair Nat PlanVal) → Nat
      → Pair CEnv (Pair (List (Pair Nat PlanVal)) Nat)
  = λ decls mod_name env compiled next_tag →
      match decls {
        | Nil → MkPair env (MkPair compiled next_tag)
        | Cons decl rest →
            match (nat_eq (decl_is_eff decl) 0) {
              | 0 →
                  let eff_name = decl_get_eff_name decl in
                  let eff_fq = name_concat_dot mod_name eff_name in
                  match (cg_register_eff_ops (decl_get_eff_ops decl) eff_fq mod_name env compiled next_tag) {
                    | MkPair new_env rest_pair →
                        match rest_pair {
                          | MkPair new_compiled new_tag →
                              cg_register_effs rest mod_name new_env new_compiled new_tag
                        }
                  }
              | _ → cg_register_effs rest mod_name env compiled next_tag
            }
      }

-- cg_pass3: process DLet and DInst declarations
let cg_pass3 : List Decl → Nat → CEnv → List (Pair Nat (Pair Nat Nat)) → List (Pair Nat PlanVal)
             → List (Pair Nat PlanVal)
  = λ decls mod_name env ctab compiled →
      match decls {
        | Nil → compiled
        | Cons decl rest →
            let result = match (nat_eq (decl_is_let decl) 0) {
                           | 0 →
                               cg_compile_let_one
                                 (decl_get_let_name decl)
                                 (decl_get_let_body decl)
                                 mod_name env ctab compiled
                           | _ →
                               match (nat_eq (decl_is_inst decl) 0) {
                                 | 0 →
                                     match (decl_get_inst_body decl) {
                                       | MkPair type_name members →
                                           let inst_prefix =
                                             name_concat_under
                                               (name_concat_under nn_inst
                                                  (decl_get_inst_class decl))
                                               type_name in
                                           cg_compile_inst_members members inst_prefix
                                             mod_name env ctab compiled
                                     }
                                 | _ → MkPair env compiled
                               }
                         } in
            match result {
              | MkPair new_env new_compiled →
                  cg_pass3 rest mod_name new_env ctab new_compiled
            }
      }

-- compile_program: compile a full program to a list of (fq_name, PlanVal) pairs
let compile_program : List Decl → Nat → List (Pair Nat PlanVal)
  = λ decls mod_name →
      let env0 = cg_register_builtins cenv_empty in
      let ctab0 = cg_register_builtin_contab contab_empty in
      match (cg_pass1 decls mod_name env0 ctab0 Nil) {
        | MkPair env1 rest1 →
            match rest1 {
              | MkPair ctab1 compiled1 →
                  match (cg_pass2 decls mod_name env1 compiled1) {
                    | MkPair env2 compiled2 →
                        match (cg_register_effs decls mod_name env2 compiled2 0) {
                          | MkPair env3 rest3 →
                              match rest3 {
                                | MkPair compiled3 _ →
                                    cg_pass3 decls mod_name env3 ctab1 compiled3
                              }
                        }
                  }
            }
      }

-- =====================================================================
-- End of M8.5: Codegen
-- =====================================================================

-- =====================================================================
-- Section 24b: M8.4 Scope Resolver
-- =====================================================================
--
-- resolve_program : List Decl → Nat → List Decl
--
-- Sits between parse_program and compile_program in main.
-- Rewrites every EVar n in DLet bodies: if n is a known global bare
-- name, replaces it with EVar (Module.n).  Also qualifies ArmCon
-- constructor names (looked up in contab at codegen time via FQ key).
--
-- Algorithm:
--   Pass 1 (sr_collect_globals): walk all decls, build a
--     List (Pair Nat Nat)  — bare_name → fq_name — from
--     DLet names, DType constructor names, and DExt item names.
--   Pass 2 (sr_resolve_decls): for each DLet, walk the body Expr
--     with a bound-variable set (List Nat).  EVar n in the bound set
--     is a local — leave it alone.  EVar n found in the globals table
--     is replaced by EVar fq_n.
--
-- Builtins (True, False, Unit) are not declared in source via
-- DLet/DType/DExt, so they never enter the globals table and pass
-- through unchanged.  The codegen finds them as bare nats in
-- cg_register_builtins, as required.
--
-- Pass-self (pe) breaks the pseudo-mutual recursion between
-- sr_dispatch and sr_rewrite_arms, exactly as cg_dispatch/cg_cf_dispatch.
-- =====================================================================

-- sr_collect_con_names: add constructor bare→fq pairs from a ConDef list
let sr_collect_con_names
      : List ConDef → Nat → List (Pair Nat Nat) → List (Pair Nat Nat)
  = λ cdefs mod_name acc →
      match cdefs {
        | Nil → acc
        | Cons cdef rest →
            match cdef {
              | MkConDef con_name _ →
                  let fq = name_concat_dot mod_name con_name in
                  sr_collect_con_names rest mod_name
                    (assoc_insert con_name fq acc)
            }
      }

-- sr_collect_ext_items: add external item bare→fq pairs
let sr_collect_ext_items
      : List Nat → Nat → List (Pair Nat Nat) → List (Pair Nat Nat)
  = λ items ext_mod acc →
      match items {
        | Nil → acc
        | Cons item_name rest →
            sr_collect_ext_items rest ext_mod
              (assoc_insert item_name (name_concat_dot ext_mod item_name) acc)
      }

-- sr_collect_inst_method_names: add inst method bare→fq entries to acc
let sr_collect_inst_method_names
      : List (Pair Nat Expr) → Nat → Nat → List (Pair Nat Nat) → List (Pair Nat Nat)
  = λ members inst_prefix mod_name acc →
      match members {
        | Nil → acc
        | Cons pair rest →
            match pair {
              | MkPair method_name _ →
                  let bare = name_concat_under inst_prefix method_name in
                  let fq   = name_concat_dot mod_name bare in
                  sr_collect_inst_method_names rest inst_prefix mod_name
                    (assoc_insert bare fq acc)
            }
      }

-- sr_collect_eff_op_names: collect FQ names for each eff op
-- Each op gets "Module.EffName.op_name" as its FQ name.
let sr_collect_eff_op_names
      : List Nat → Nat → Nat → List (Pair Nat Nat) → List (Pair Nat Nat)
  = λ ops eff_fq mod_name acc →
      match ops {
        | Nil → acc
        | Cons op_name rest →
            let fq = name_concat_dot eff_fq op_name in
            sr_collect_eff_op_names rest eff_fq mod_name
              (assoc_insert op_name fq acc)
      }

-- sr_collect_globals: build the bare→fq table from all decls
-- Uses direct exhaustive 6-way match (all constructors have arity 2).
let sr_collect_globals
      : List Decl → Nat → List (Pair Nat Nat) → List (Pair Nat Nat)
  = λ decls mod_name acc →
      match decls {
        | Nil → acc
        | Cons decl rest →
            let acc2 = match decl {
                         | DLet bare _ →
                             assoc_insert bare (name_concat_dot mod_name bare) acc
                         | DType _ cdefs →
                             sr_collect_con_names cdefs mod_name acc
                         | DExt ext_mod items →
                             sr_collect_ext_items items ext_mod acc
                         | DClass _ _ → acc
                         | DInst class_name body_pair →
                             match body_pair {
                               | MkPair type_name members →
                                   let inst_prefix =
                                     name_concat_under
                                       (name_concat_under nn_inst class_name)
                                       type_name in
                                   sr_collect_inst_method_names members inst_prefix mod_name acc
                             }
                         | DEff eff_name ops →
                             let eff_fq = name_concat_dot mod_name eff_name in
                             sr_collect_eff_op_names ops eff_fq mod_name acc
                       } in
            sr_collect_globals rest mod_name acc2
      }

-- sr_rewrite_arm: rewrite one MatchArm, tracking bound variables.
-- ArmCon constructor names are also qualified (contab is keyed by FQ).
let sr_rewrite_arm
      : (Expr → List Nat → List (Pair Nat Nat) → Expr)
      → MatchArm → List Nat → List (Pair Nat Nat) → MatchArm
  = λ pe arm bound gtab →
      match (arm_is_nat arm) {
        | 0 →
            match (arm_is_var arm) {
              | 0 →
                  -- ArmCon: qualify constructor name; fields are local binders
                  let fields   = arm_get_con_fields arm in
                  let con_name = arm_get_con_name arm in
                  let fq_con   = match (assoc_lookup con_name gtab) {
                                   | None    → con_name
                                   | Some fq → fq
                                 } in
                  let bound2 = append fields bound in
                  let body2  = pe (arm_get_con_body arm) bound2 gtab in
                  ArmCon fq_con (MkPair fields body2)
              | _ →
                  -- ArmVar: var name is a local binder
                  let n     = arm_get_var_name arm in
                  let body2 = pe (arm_get_var_body arm) (Cons n bound) gtab in
                  ArmVar n body2
            }
        | _ →
            -- ArmNat: no new binders
            let body2 = pe (arm_get_nat_body arm) bound gtab in
            ArmNat (arm_get_nat_tag arm) body2
      }

-- sr_rewrite_arms: rewrite a list of MatchArms
let sr_rewrite_arms
      : (Expr → List Nat → List (Pair Nat Nat) → Expr)
      → List MatchArm → List Nat → List (Pair Nat Nat) → List MatchArm
  = λ pe arms bound gtab →
      match arms {
        | Nil → Nil
        | Cons arm rest →
            Cons (sr_rewrite_arm pe arm bound gtab)
                 (sr_rewrite_arms pe rest bound gtab)
      }

-- sr_rewrite_handle_arms: rewrite handler op arm bodies
-- Each arm is (op_name, (k_name, body)). op_name is qualified via gtab,
-- k_name and arg implicit in body are bound.
let sr_rewrite_handle_arms
      : (Expr → List Nat → List (Pair Nat Nat) → Expr)
      → List (Pair Nat (Pair Nat Expr)) → List Nat → List (Pair Nat Nat)
      → List (Pair Nat (Pair Nat Expr))
  = λ pe arms bound gtab →
      match arms {
        | Nil → Nil
        | Cons arm rest →
            match arm {
              | MkPair op_name inner →
                  match inner {
                    | MkPair k_name body →
                        let fq_op = match (assoc_lookup op_name gtab) {
                                      | None    → op_name
                                      | Some fq → fq
                                    } in
                        let body2 = pe body (Cons k_name bound) gtab in
                        Cons (MkPair fq_op (MkPair k_name body2))
                             (sr_rewrite_handle_arms pe rest bound gtab)
                  }
            }
      }

-- sr_dispatch: dispatch on expr structure and recurse via pass-self pe.
-- EVar: qualify if in gtab and not in bound.
-- ELam/ELet/EPin: extend bound for body.
-- EApp/EIf/EMatch: recurse into sub-expressions.
-- ENat/EText: no names — pass through unchanged.
--
-- Dispatch strategy avoids the bootstrap mixed-arity expr_tag bug:
--   planval_is_nat expr = 1  ↔  EVar   (unary tag-0, same layout as PNat)
--   planval_is_app expr = 1  ↔  binary  (EApp/ELam/ELet/EIf/EMatch/EPin)
--   neither               ↔  ENat   (unary tag-4, returns 0/P(0) for both)
-- ENat has no names, so returning expr unchanged is correct.
let sr_dispatch
      : (Expr → List Nat → List (Pair Nat Nat) → Expr)
      → Expr → List Nat → List (Pair Nat Nat) → Expr
  = λ pe expr bound gtab →
      match (nat_eq (planval_is_nat expr) 1) {
        | 0 →
            -- Not EVar. Check for binary constructor (has App outer-fun).
            match (nat_eq (planval_is_app expr) 1) {
              | 0 →
                  -- Unary with tag > 0 (ENat, EText…): no names, pass through.
                  expr
              | _ →
                  -- Binary constructor: dispatch by tag.
                  match (nat_eq (expr_tag expr) 1) {
                    | 0 →
                        match (nat_eq (expr_tag expr) 2) {
                          | 0 →
                              match (nat_eq (expr_tag expr) 3) {
                                | 0 →
                                    match (nat_eq (expr_tag expr) 5) {
                                      | 0 →
                                          match (nat_eq (expr_tag expr) 6) {
                                            | 0 →
                                                match (nat_eq (expr_tag expr) 7) {
                                                  | 0 →
                                                      match (nat_eq (expr_tag expr) 8) {
                                                        | 0 →
                                                            match (nat_eq (expr_tag expr) 9) {
                                                              | 0 →
                                                                  -- EDo (tag 10): bind_name bound in body
                                                                  match expr {
                                                                    | EDo bind_n p →
                                                                        match p {
                                                                          | MkPair rhs body →
                                                                              let rhs2  = pe rhs bound gtab in
                                                                              let body2 = pe body (Cons bind_n bound) gtab in
                                                                              EDo bind_n (MkPair rhs2 body2)
                                                                        }
                                                                    | _ → expr
                                                                  }
                                                              | _ →
                                                                  -- EHandle (tag 9): rewrite comp and all arm bodies
                                                                  match expr {
                                                                    | EHandle comp p →
                                                                        match p {
                                                                          | MkPair ret_fn op_arms →
                                                                              let comp2 = pe comp bound gtab in
                                                                              let ret2  = pe ret_fn bound gtab in
                                                                              let arms2 = sr_rewrite_handle_arms pe op_arms bound gtab in
                                                                              EHandle comp2 (MkPair ret2 arms2)
                                                                        }
                                                                    | _ → expr
                                                                  }
                                                            }
                                                        | _ →
                                                            -- EFix (tag 8): self_name and params are bound in body
                                                            match expr {
                                                              | EFix self_n p →
                                                                  match p {
                                                                    | MkPair params body →
                                                                        let all_bound = append params (Cons self_n bound) in
                                                                        let body2 = pe body all_bound gtab in
                                                                        EFix self_n (MkPair params body2)
                                                                  }
                                                              | _ → expr
                                                            }
                                                      }
                                                  | _ →
                                                      -- EPin (tag 7)
                                                      match expr {
                                                        | EPin n p →
                                                            match p {
                                                              | MkPair rhs body →
                                                                  let rhs2  = pe rhs bound gtab in
                                                                  let body2 = pe body (Cons n bound) gtab in
                                                                  EPin n (MkPair rhs2 body2)
                                                            }
                                                        | _ → expr
                                                      }
                                                }
                                            | _ →
                                                -- EMatch (tag 6)
                                                match expr {
                                                  | EMatch scr arms →
                                                      let scr2  = pe scr bound gtab in
                                                      let arms2 = sr_rewrite_arms pe arms bound gtab in
                                                      EMatch scr2 arms2
                                                  | _ → expr
                                                }
                                          }
                                      | _ →
                                          -- EIf (tag 5)
                                          match expr {
                                            | EIf cond p →
                                                match p {
                                                  | MkPair then_ else_ →
                                                      EIf (pe cond bound gtab)
                                                          (MkPair (pe then_ bound gtab)
                                                                  (pe else_ bound gtab))
                                                }
                                            | _ → expr
                                          }
                                    }
                                | _ →
                                    -- ELet (tag 3): name bound in body, not rhs
                                    match expr {
                                      | ELet n p →
                                          match p {
                                            | MkPair rhs body →
                                                let rhs2  = pe rhs bound gtab in
                                                let body2 = pe body (Cons n bound) gtab in
                                                ELet n (MkPair rhs2 body2)
                                          }
                                      | _ → expr
                                    }
                              }
                          | _ →
                              -- ELam (tag 2): param bound in body
                              match expr {
                                | ELam p b →
                                    ELam p (pe b (Cons p bound) gtab)
                                | _ → expr
                              }
                        }
                    | _ →
                        -- EApp (tag 1)
                        match expr {
                          | EApp f a →
                              EApp (pe f bound gtab) (pe a bound gtab)
                          | _ → expr
                        }
                  }
            }
        | _ →
            -- EVar (tag 0): qualify if global and not locally bound
            match expr {
              | EVar n →
                  match (cg_name_in_list n bound) {
                    | 0 →
                        match (assoc_lookup n gtab) {
                          | None    → expr
                          | Some fq → EVar fq
                        }
                    | _ → expr
                  }
              | _ → expr
            }
      }

-- sr_rewrite_expr: tie the knot via pass-self
let sr_rewrite_expr
      : Expr → List Nat → List (Pair Nat Nat) → Expr
  = λ expr bound gtab →
      sr_dispatch sr_rewrite_expr expr bound gtab

-- sr_resolve_inst_members: resolve all member body exprs in a DInst
let sr_resolve_inst_members
      : List (Pair Nat Expr) → List (Pair Nat Nat) → List (Pair Nat Expr)
  = λ members gtab →
      match members {
        | Nil → Nil
        | Cons pair rest →
            match pair {
              | MkPair name body →
                  Cons (MkPair name (sr_rewrite_expr body Nil gtab))
                       (sr_resolve_inst_members rest gtab)
            }
      }

-- sr_resolve_decls: rewrite bodies; DType/DExt/DClass pass through unchanged.
-- Uses direct exhaustive 5-way match (all Decl constructors have arity 2).
let sr_resolve_decls
      : List Decl → List (Pair Nat Nat) → List Decl
  = λ decls gtab →
      match decls {
        | Nil → Nil
        | Cons decl rest →
            let new_decl = match decl {
                             | DLet name body →
                                 DLet name (sr_rewrite_expr body Nil gtab)
                             | DType _ _ → decl
                             | DExt _ _  → decl
                             | DClass _ _ → decl
                             | DInst class_name body_pair →
                                 match body_pair {
                                   | MkPair type_name members →
                                       DInst class_name
                                         (MkPair type_name
                                           (sr_resolve_inst_members members gtab))
                                 }
                             | DEff _ _ → decl
                           } in
            Cons new_decl (sr_resolve_decls rest gtab)
      }

-- resolve_program: collect globals then rewrite all DLet bodies
let resolve_program : List Decl → Nat → List Decl
  = λ decls mod_name →
      let gtab = sr_collect_globals decls mod_name Nil in
      sr_resolve_decls decls gtab

-- =====================================================================
-- End of M8.4: Scope Resolver
-- =====================================================================

-- =====================================================================
-- Section 25: M8.6 Plan Assembler Emitter
-- =====================================================================
--
-- Converts List (Pair Nat PlanVal) (output of compile_program) to Bytes
-- (UTF-8 Plan Assembler text, Reaver format).
--
-- Output format per definition:
--   (#bind "name_decimal" expr)
--
-- Law bodies use de Bruijn slot encoding:
--   _N          = de Bruijn reference N
--   k (decimal) = constant nat k  (auto-quoted by assembler)
--   (f x)       = application
--   _N(rhs)     = let-binding (juxtaposition syntax in #law body)
--   (#pin v)    = embedded pin
--
-- See spec/07-seed-format.md §13 for the full grammar.
-- =====================================================================

-- ---------------------------------------------------------------------------
-- nat_to_decimal_go: recursive descent decimal encoder
-- Emits digits most-significant first by recursing on n/10.
-- Stops (bytes_empty) when n = 0 — so leading zeros are never emitted.
-- ---------------------------------------------------------------------------
let nat_to_decimal_go : Nat → Bytes
  = λ n → match n {
      | 0 → MkPair 0 0
      | pred →
          bytes_concat
            (nat_to_decimal_go (div_nat n 10))
            (bytes_singleton (add 0x30 (mod_nat n 10)))
    }

-- nat_to_decimal: convert Nat to decimal Bytes, handling 0 → "0"
let nat_to_decimal : Nat → Bytes
  = λ n → match n {
      | 0 → bytes_singleton 0x30
      | pred → nat_to_decimal_go n
    }

-- ---------------------------------------------------------------------------
-- emit_debruijn_ref: emit "_N" for de Bruijn slot N
-- 0x5F = '_'
-- ---------------------------------------------------------------------------
let emit_debruijn_ref : Nat → Bytes
  = λ i →
      bytes_concat (bytes_singleton 0x5F) (nat_to_decimal i)

-- ---------------------------------------------------------------------------
-- emit_asm_app: emit "(f_asm x_asm)" — Plan Assembler application
-- 0x28='('  0x20=' '  0x29=')'
-- ---------------------------------------------------------------------------
let emit_asm_app : Bytes → Bytes → Bytes
  = λ f_asm x_asm →
      bytes_concat (bytes_singleton 0x28)
        (bytes_concat f_asm
          (bytes_concat (bytes_singleton 0x20)
            (bytes_concat x_asm (bytes_singleton 0x29))))

-- ---------------------------------------------------------------------------
-- emit_asm_let: emit "_slot(rhs_asm)\n  body_asm" — let-binding in law body
-- 0x28='('  0x29=')'  0x0A='\n'  0x20=' '
-- ---------------------------------------------------------------------------
let emit_asm_let : Nat → Bytes → Bytes → Bytes
  = λ slot rhs_asm body_asm →
      bytes_concat (emit_debruijn_ref slot)
        (bytes_concat (bytes_singleton 0x28)
          (bytes_concat rhs_asm
            (bytes_concat (bytes_singleton 0x29)
              (bytes_concat (bytes_singleton 0x0A)
                (bytes_concat (bytes_singleton 0x20)
                  (bytes_concat (bytes_singleton 0x20)
                    body_asm))))))

-- ---------------------------------------------------------------------------
-- emit_asm_pin: emit "(#pin inner_asm)"
-- 0x23='#'  0x70='p'  0x69='i'  0x6E='n'
-- ---------------------------------------------------------------------------
let emit_asm_pin : Bytes → Bytes
  = λ inner_asm →
      bytes_concat (bytes_singleton 0x28)
        (bytes_concat (bytes_singleton 0x23)
          (bytes_concat (bytes_singleton 0x70)
            (bytes_concat (bytes_singleton 0x69)
              (bytes_concat (bytes_singleton 0x6E)
                (bytes_concat (bytes_singleton 0x20)
                  (bytes_concat inner_asm (bytes_singleton 0x29)))))))

-- ---------------------------------------------------------------------------
-- emit_law_sig_go: emit " _i ... _k" (space-prefixed args beyond _0)
-- Self-recursive; terminates when i > k.
-- ---------------------------------------------------------------------------
let emit_law_sig_go : Nat → Nat → Bytes
  = λ i k →
      match (lte i k) {
        | 0 → MkPair 0 0
        | pred →
            bytes_concat
              (bytes_concat (bytes_singleton 0x20) (emit_debruijn_ref i))
              (emit_law_sig_go (add i 1) k)
      }

-- emit_law_sig: emit "(_0 _1 ... _arity)" — the full #law parameter list.
-- _0 = self-ref; _1.._arity = arguments.
-- 0x28='('  0x29=')'
let emit_law_sig : Nat → Bytes
  = λ arity →
      bytes_concat (bytes_singleton 0x28)
        (bytes_concat (emit_debruijn_ref 0)
          (bytes_concat (emit_law_sig_go 1 arity)
            (bytes_singleton 0x29)))

-- ---------------------------------------------------------------------------
-- Bootstrap compiler constraint: self-recursive calls inside nested
-- constructor-match arms are NOT supported.
--
-- When the bootstrap compiler compiles a constructor match, it creates a
-- sub-law for each arm via lambda lifting (_build_app_handler). Inside that
-- sub-law, N(0) refers to the sub-law itself, NOT the outer law. A self-
-- recursive call like `emit_body_val ep f depth` inside a nested arm therefore
-- appears as an unbound variable.
--
-- Fix: separate the DISPATCH LOGIC from the RECURSION KNOT, exactly as
-- cg_dispatch / cg_compile_expr do.
--
--   emit_bval_dispatch ep ebv pval depth
--     — no self-recursion; calls ebv (a parameter) for recursive subcases
--     — captured parameters (ep, ebv, depth) are correctly lambda-lifted
--       into sub-laws created for match arms
--
--   emit_body_val ep pval depth
--     = emit_bval_dispatch ep (emit_body_val ep) pval depth
--     — trivial wrapper that ties the knot; its body has no match arms, so
--       the self-reference N(0) works correctly
--
-- The same pattern is used for emit_pval_dispatch / emit_pval.
-- ---------------------------------------------------------------------------

-- pair_nat_planval_fst / pair_nat_planval_snd:
-- Field accessors for Pair Nat PlanVal, used by emit_pval_dispatch to avoid
-- a nested constructor match (| MkPair arity body → ...) inside an outer
-- constructor match arm, which would create another sub-law.
let pair_nat_planval_fst : Pair Nat PlanVal → Nat
  = λ p → match p { | MkPair a _ → a }

let pair_nat_planval_snd : Pair Nat PlanVal → PlanVal
  = λ p → match p { | MkPair _ b → b }

-- planval_app_fun / planval_app_arg: field accessors for PApp.
-- Used by emit_bval_dispatch to avoid a doubly-nested constructor match
-- (match f { | PApp ... } inside | PApp f x →).
-- planval_is_app is already defined in the PlanVal helpers above.
let planval_app_fun : PlanVal → PlanVal
  = λ v → match v { | PApp f _ → f | _ → v }

let planval_app_arg : PlanVal → PlanVal
  = λ v → match v { | PApp _ x → x | _ → v }

-- ---------------------------------------------------------------------------
-- emit_bval_dispatch: body-context emitter dispatch.
--
-- Parameters:
--   ep    = emit_pval (top-level emitter; for PPin content and bare PLaw)
--   ebv   = emit_body_val ep (passed for recursive subcases; NOT self-ref)
--   pval  = PlanVal node to emit
--   depth = de Bruijn slots so far (starts = arity; +1 per let-binding)
--
-- Pattern table (spec/07-seed-format.md §13.5):
--   PNat i                           → "_i"             (de Bruijn ref)
--   PApp(PNat 0)(PNat k)             → "k"              (cg_quote_nat constant)
--   PApp(PApp(PNat 0) x2) x          → "(x2 x)"         (cg_bapp application)
--   PApp(PApp(PNat 1) x2) x          → "_d(x2)\n  x"   (let-chain, d=depth+1)
--   PPin v                           → "(#pin ep(v))"   (embedded via ep)
--   PLaw ...                         → ep pval           (lambda-lifted, via ep)
--
-- Only ONE level of constructor match (on pval) is used here.
-- The | PApp f x → arm uses if/then/else + helper function calls exclusively —
-- no let-bindings inside match arms (those compile to A(A(N(1),rhs),k) forms
-- that _bjudge processes only at the top of a law body; inside a Case_ arm
-- they become stuck and are returned as-is by _bkal).
-- Helper functions emit_bval_papp_nat / emit_bval_papp_app carry the
-- sub-dispatch logic and are called with fully-applied inline arguments.
-- ---------------------------------------------------------------------------

-- emit_bval_papp_nat: sub-dispatch for PApp(PNat opcode)(x).
-- No let-bindings: avoids stuck A(A(N(1),...),k) values in Case_ arms.
let emit_bval_papp_nat
      : (PlanVal → Nat → Bytes)
      → Nat → PlanVal → PlanVal → Nat
      → Bytes
  = λ ebv opcode f x depth →
      if nat_eq opcode 0 then
        if planval_is_nat x then
          nat_to_decimal (planval_get_nat x)
        else
          emit_asm_app (ebv f depth) (ebv x depth)
      else
        emit_asm_app (ebv f depth) (ebv x depth)

-- emit_bval_papp_app: sub-dispatch for PApp(PApp(PNat opcode)(x2))(x).
-- opcode = planval_get_nat (planval_app_fun f), x2 = planval_app_arg f.
-- No let-bindings; add depth 1 computed inline (twice when needed).
let emit_bval_papp_app
      : (PlanVal → Nat → Bytes)
      → Nat → PlanVal → PlanVal → PlanVal → Nat
      → Bytes
  = λ ebv opcode x2 f x depth →
      if nat_eq opcode 0 then
        emit_asm_app (ebv x2 depth) (ebv x depth)
      else if nat_eq opcode 1 then
        emit_asm_let (add depth 1) (ebv x2 depth) (ebv x (add depth 1))
      else
        emit_asm_app (ebv f depth) (ebv x depth)

let emit_bval_dispatch
      : (PlanVal → Bytes)
      → (PlanVal → Nat → Bytes)
      → PlanVal
      → Nat
      → Bytes
  = λ ep ebv pval depth →
      match pval {
        | PNat i →
            emit_debruijn_ref i
        | PApp f x →
            -- Dispatch on f using helper functions (no let-bindings in arm body).
            -- planval_is_nat f → f = PNat opcode  → emit_bval_papp_nat
            -- planval_is_app f, planval_is_nat f2 → emit_bval_papp_app
            -- else              → PLaw / PPin: generic application
            if planval_is_nat f then
              emit_bval_papp_nat ebv (planval_get_nat f) f x depth
            else if planval_is_app f then
              if planval_is_nat (planval_app_fun f) then
                emit_bval_papp_app ebv
                  (planval_get_nat (planval_app_fun f))
                  (planval_app_arg f) f x depth
              else
                emit_asm_app (ebv f depth) (ebv x depth)
            else
              emit_asm_app (ebv f depth) (ebv x depth)
        | PPin v →
            emit_asm_pin (ep v)
        | PLaw _ _ →
            -- Lambda-lifted laws appear as PPin(PLaw ...) in law bodies.
            ep pval
      }

-- emit_body_val: ties the knot for emit_bval_dispatch.
-- Simple body (no match arms) — self-reference N(0) works correctly.
let emit_body_val : (PlanVal → Bytes) → PlanVal → Nat → Bytes
  = λ ep pval depth →
      emit_bval_dispatch ep (emit_body_val ep) pval depth

-- ---------------------------------------------------------------------------
-- emit_plaw: emit a complete #law form at top level.
--   ep    = emit_pval (for embedded PPin/PLaw in body)
--   name  = name nat
--   arity = argument count (slots 1.._arity)
--   body  = law body PlanVal
-- Output: "(#law "name_decimal" sig\n  body_asm)"
-- 0x23='#'  0x6C='l'  0x61='a'  0x77='w'  0x22='"'  0x0A='\n'
-- ---------------------------------------------------------------------------
let emit_plaw : (PlanVal → Bytes) → Nat → Nat → PlanVal → Bytes
  = λ ep name arity body →
      let name_str =
        bytes_concat (bytes_singleton 0x22)
          (bytes_concat (nat_to_decimal name) (bytes_singleton 0x22)) in
      let law_kw =
        bytes_concat (bytes_singleton 0x28)
          (bytes_concat (bytes_singleton 0x23)
            (bytes_concat (bytes_singleton 0x6C)
              (bytes_concat (bytes_singleton 0x61)
                (bytes_concat (bytes_singleton 0x77)
                  (bytes_singleton 0x20))))) in
      let sig = emit_law_sig arity in
      let body_asm = emit_body_val ep body arity in
      bytes_concat law_kw
        (bytes_concat name_str
          (bytes_concat (bytes_singleton 0x20)
            (bytes_concat sig
              (bytes_concat (bytes_singleton 0x0A)
                (bytes_concat (bytes_singleton 0x20)
                  (bytes_concat (bytes_singleton 0x20)
                    (bytes_concat body_asm (bytes_singleton 0x29))))))))

-- ---------------------------------------------------------------------------
-- emit_pval_dispatch: top-level emitter dispatch (no self-recursion).
-- Uses ep parameter for all recursive subcases.
-- pair_nat_planval_fst/snd replace the nested match on PLaw's Pair field.
-- ---------------------------------------------------------------------------
let emit_pval_dispatch : (PlanVal → Bytes) → PlanVal → Bytes
  = λ ep pval →
      match pval {
        | PNat n → nat_to_decimal n
        | PApp f x → emit_asm_app (ep f) (ep x)
        | PLaw name ap →
            emit_plaw ep name (pair_nat_planval_fst ap) (pair_nat_planval_snd ap)
        | PPin v → emit_asm_pin (ep v)
      }

-- emit_pval: ties the knot for emit_pval_dispatch.
-- Simple body (no match arms) — self-reference N(0) works correctly.
let emit_pval : PlanVal → Bytes
  = λ pval → emit_pval_dispatch emit_pval pval

-- ---------------------------------------------------------------------------
-- emit_bind: emit one top-level (#bind "name_decimal" expr_asm)\n
-- 0x23='#'  0x62='b'  0x69='i'  0x6E='n'  0x64='d'
-- ---------------------------------------------------------------------------
let emit_bind : Nat → PlanVal → Bytes
  = λ name pval →
      let name_str =
        bytes_concat (bytes_singleton 0x22)
          (bytes_concat (nat_to_decimal name) (bytes_singleton 0x22)) in
      let bind_kw =
        bytes_concat (bytes_singleton 0x28)
          (bytes_concat (bytes_singleton 0x23)
            (bytes_concat (bytes_singleton 0x62)
              (bytes_concat (bytes_singleton 0x69)
                (bytes_concat (bytes_singleton 0x6E)
                  (bytes_concat (bytes_singleton 0x64)
                    (bytes_singleton 0x20)))))) in
      let expr_asm = emit_pval pval in
      bytes_concat bind_kw
        (bytes_concat name_str
          (bytes_concat (bytes_singleton 0x20)
            (bytes_concat expr_asm
              (bytes_concat (bytes_singleton 0x29) (bytes_singleton 0x0A)))))

-- ---------------------------------------------------------------------------
-- emit_program: main entry point for M8.6.
-- Input:  List (Pair Nat PlanVal) — output of compile_program
-- Output: Bytes — UTF-8 Plan Assembler text, one (#bind ...) per definition
-- ---------------------------------------------------------------------------
let emit_program : List (Pair Nat PlanVal) → Bytes
  = λ defs →
      foldl
        (λ acc def →
          match def {
            | MkPair name pval →
                bytes_concat acc (emit_bind name pval)
          })
        (MkPair 0 0)
        defs

-- =====================================================================
-- End of M8.6: Plan Assembler Emitter
-- =====================================================================

-- =====================================================================
-- Section 26: M8.7 Driver
-- =====================================================================
-- main: top-level entry point.
-- Input:  Bytes  — UTF-8 source text of a single .gls file
-- Output: Bytes  — Plan Assembler text (one (#bind ...) per definition)
--
-- Module name is hardcoded to "Compiler" for M8.8 self-hosting validation.
-- "Compiler" as a little-endian nat:
--   int.from_bytes(b'Compiler', 'little') = 8243113893085146947
--   hex: 0x72656c69706d6f43
-- ---------------------------------------------------------------------------
let nn_Compiler : Nat = 8243113893085146947

let main : Bytes → Bytes
  = λ src →
      let tokens  = lex src 0 1 1 in
      let decls   = parse_program tokens in
      let decls2  = resolve_program decls nn_Compiler in
      let compiled = compile_program decls2 nn_Compiler in
      emit_program compiled

-- =====================================================================
-- End of M8.7: Driver
-- =====================================================================

-- =====================================================================
-- Section 27: M8.8 Path A — planvm CLI entry point
-- =====================================================================
--
-- run_main: entry point for planvm CLI execution.
--
-- planvm passes the source text as a CLI argument (a strnat — little-endian
-- Nat encoding of the UTF-8 bytes).  boot.c builds argVec as:
--   Closure(head=N(0)=Pin, args=[src_nat])
-- which forces to P(src_nat).  Core.PLAN.unpin extracts src_nat.
--
-- We then compute the byte length via nat_byte_len, construct a Bytes value,
-- run main, and write the output to stdout (fd=1) via WriteOp.
--
-- WriteOp (P(N(9))) requires its argument to be a size-4 Closure:
--   (fd, buf_nat, byte_count, offset)
-- _write_pack is a 5-arity dummy law; applying it to 4 args creates that
-- Closure, which WriteOp's unpackop.sized(closure, 4) can unpack.
--
-- run_main : Nat → Nat
--   Takes the raw argVec (forces to P(src_nat)).
--   Returns 0 (exit code).
-- =====================================================================

-- _write_pack: 5-arity dummy; applying to 4 args creates size-4 Closure
-- for WriteOp.  The body returns the last arg (never reached via jet).
let _write_pack : Nat → Nat → Nat → Nat → Nat → Nat
  = λ a b c d e → e

-- write_fd: write buf_nat (count bytes) to file descriptor fd at offset 0
let write_fd : Nat → Nat → Nat → Nat
  = λ fd buf count → write_op (_write_pack fd buf count 0)

-- run_main: planvm CLI entry point
let run_main : Nat → Nat
  = λ argVec →
      let src_nat   = Core.PLAN.unpin argVec in
      let src_len   = nat_byte_len src_nat in
      let src_bytes = MkPair src_len src_nat in
      let output    = main src_bytes in
      let out_len   = bytes_length output in
      let out_nat   = bytes_content output in
      write_fd 1 out_nat out_len

-- =====================================================================
-- End of M8.8: Path A CLI entry point
-- =====================================================================
