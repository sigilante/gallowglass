{
  "comments": {
    "lineComment": "--",
    "blockComment": ["{-", "-}"]
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(let|type|class|instance|eff|mod|match|handle|if|do)\\b.*[={]\\s*$|^.*\\{\\s*$|^.*\\bthen\\b\\s*$|^.*\\belse\\b\\s*$",
    "decreaseIndentPattern": "^\\s*[}\\]]\\s*$"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
