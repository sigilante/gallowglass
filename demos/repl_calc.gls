-- Calculator REPL — runs as a Reaver process.
--
-- Reads arithmetic expressions on stdin (one per line), parses with
-- precedence-correct recursive descent, evaluates, and writes the
-- result. Loops until stdin is exhausted.
--
-- Supports: multi-digit Nat literals, `+`, `-`, `*`, `/`, parentheses.
-- Errors (parse failure, division by zero) print "err" and continue.
--
-- Run:
--   echo "1+2" "$'\n'" "3*4" | plan-assembler <dir> <module> Main_main 0
--
-- Demonstrates: end-to-end gallowglass-as-a-Reaver-process pipeline,
-- the new `Reaver.RPLAN` (stdio) and `Reaver.BPLAN` (jetted arithmetic)
-- bindings, recursive REPL loop via `fix`, lex/parse/eval in restricted
-- dialect.

external mod Reaver.RPLAN {
  input  : Nat → Nat
  output : Nat → Nat
}

external mod Reaver.BPLAN {
  add  : Nat → Nat → Nat
  sub  : Nat → Nat → Nat
  mul  : Nat → Nat → Nat
  div  : Nat → Nat → Nat
  eq   : Nat → Nat → Nat
  lsh  : Nat → Nat → Nat
  rsh  : Nat → Nat → Nat
  bex  : Nat → Nat
  seq  : Nat → Nat → Nat   -- force a, return b: needed to thread I/O effects
}

-- ---------------------------------------------------------------------------
-- Local types — kept inline so the demo has no Core.* dependencies.
-- ---------------------------------------------------------------------------

type Pair a b = | MkPair a b

type List a =
  | Nil
  | Cons a (List a)

type Token =
  | TkNum Nat
  | TkPlus
  | TkMinus
  | TkStar
  | TkSlash
  | TkCaret
  | TkLParen
  | TkRParen
  | TkEOF
  | TkErr

type Expr =
  | EConst Nat
  | EAdd Expr Expr
  | ESub Expr Expr
  | EMul Expr Expr
  | EDiv Expr Expr
  | EPow Expr Expr
  | EErr

type EvalResult =
  | EvOk Nat
  | EvErr

-- ---------------------------------------------------------------------------
-- Bit-level helpers built on Reaver.BPLAN.
-- ---------------------------------------------------------------------------

-- nat_mod n d = n - (n / d) * d. Reserved-keyword `mod` rules out a binding
-- by that name; this is the local replacement.
let nat_mod : Nat → Nat → Nat
  = λ n d → BPLAN.sub n (BPLAN.mul (BPLAN.div n d) d)

-- bit_size n = number of bits needed to represent n (highest set bit + 1).
-- bit_size 0 = 0. Pure-recursive on right-shift; under Reaver each step
-- is one BPLAN.rsh dispatch, so this is O(log n) reductions.
let bit_size : Nat → Nat
  = fix λ self n → match n {
      | 0 → 0
      | _ → BPLAN.add 1 (self (BPLAN.rsh n 1))
    }

-- decode_input: split a `Reaver.RPLAN.input` result into (length, content).
-- The runtime returns `bytesBar(bs) = body | (1 << len*8)` — the actual
-- byte content with a high-bit length marker. Recover by:
--   len     = (bit_size n - 1) / 8
--   content = n - 2^(len*8)
-- For an empty stdin (EOF), input returns `bytesBar "" = 1`, so
-- bit_size = 1 → len = 0 → content = 0. Length 0 is the EOF signal.
-- decode_len: bytesBar length-marker position → byte length.
let decode_len : Nat → Nat
  = λ n → BPLAN.div (BPLAN.sub (bit_size n) 1) 8

let decode_input : Nat → Pair Nat Nat
  = λ n → match n {
      | 0 → MkPair 0 0
      | _ →
          MkPair (decode_len n)
                 (BPLAN.sub n (BPLAN.bex (BPLAN.mul (decode_len n) 8)))
    }

-- byte_at content i: extract byte at index i.
let byte_at : Nat → Nat → Nat
  = λ content i → nat_mod (BPLAN.rsh content (BPLAN.mul i 8)) 256

-- ---------------------------------------------------------------------------
-- Character classification.
-- ---------------------------------------------------------------------------

let is_space : Nat → Nat
  = λ b → match (BPLAN.eq b 32) {                -- ' '
      | 0 → match (BPLAN.eq b 9) {                -- tab
          | 0 → match (BPLAN.eq b 10) {           -- LF
              | 0 → BPLAN.eq b 13                 -- CR
              | _ → 1
            }
          | _ → 1
        }
      | _ → 1
    }

let is_digit : Nat → Nat
  = λ b → match (BPLAN.sub b 47) {     -- > 0 iff b >= 48 ('0')
      | 0 → 0
      | _ → match (BPLAN.sub 58 b) {    -- > 0 iff b <= 57 ('9')
          | 0 → 0
          | _ → 1
        }
    }

-- ---------------------------------------------------------------------------
-- Lexer: walk byte-by-byte, emit a List of tokens (head = first token).
-- Returns the list in source order. Skips whitespace; multi-digit numbers
-- accumulate as a single TkNum.
-- ---------------------------------------------------------------------------

-- lex_num: starting at offset `i`, scan a run of digits and return
-- (accumulated_value, next_offset).
let lex_num : Nat → Nat → Nat → Nat → Pair Nat Nat
  = fix λ self content len i acc → match (BPLAN.eq i len) {
      | 0 → match (is_digit (byte_at content i)) {
          | 0 → MkPair acc i
          | _ → self content len
                     (BPLAN.add i 1)
                     (BPLAN.add (BPLAN.mul acc 10) (BPLAN.sub (byte_at content i) 48))
        }
      | _ → MkPair acc i
    }

-- skip_ws: advance over whitespace bytes, return new offset.
let skip_ws : Nat → Nat → Nat → Nat
  = fix λ self content len i → match (BPLAN.eq i len) {
      | 0 →
          match (is_space (byte_at content i)) {
            | 0 → i
            | _ → self content len (BPLAN.add i 1)
          }
      | _ → i
    }

-- single_char_token: classify a single byte as a punctuation token, or
-- TkErr if unrecognised.
let single_char_token : Nat → Token
  = λ b → match (BPLAN.eq b 43) {           -- '+'
      | 0 → match (BPLAN.eq b 45) {          -- '-'
          | 0 → match (BPLAN.eq b 42) {      -- '*'
              | 0 → match (BPLAN.eq b 47) {  -- '/'
                  | 0 → match (BPLAN.eq b 94) {  -- '^'
                      | 0 → match (BPLAN.eq b 40) {   -- '('
                          | 0 → match (BPLAN.eq b 41) {  -- ')'
                              | 0 → TkErr
                              | _ → TkRParen
                            }
                          | _ → TkLParen
                        }
                      | _ → TkCaret
                    }
                  | _ → TkSlash
                }
              | _ → TkStar
            }
          | _ → TkMinus
        }
      | _ → TkPlus
    }

-- tokenize_at: tokenize starting at offset i_ws (already past whitespace).
-- Pass-self pattern: takes the recursion target as `self` to break the
-- pseudo-mutual link with tokenize_go below.
let tokenize_at
      : (Nat → Nat → Nat → List Token → List Token)
      → Nat → Nat → Nat → List Token → List Token
  = λ self content len i_ws acc → match (BPLAN.eq i_ws len) {
      | 0 → match (is_digit (byte_at content i_ws)) {
          | 0 → self content len (BPLAN.add i_ws 1)
                     (Cons (single_char_token (byte_at content i_ws)) acc)
          | _ → match (lex_num content len i_ws 0) {
              | MkPair v j → self content len j (Cons (TkNum v) acc)
            }
        }
      | _ → acc
    }

-- tokenize_go: skip whitespace then dispatch via tokenize_at. Recursive
-- via fix; each iteration consumes one token.
let tokenize_go : Nat → Nat → Nat → List Token → List Token
  = fix λ self content len i acc →
      tokenize_at self content len (skip_ws content len i) acc

-- list_reverse_go: needed to flip the accumulator from tokenize_go.
let list_reverse_go : List Token → List Token → List Token
  = fix λ self xs acc → match xs {
      | Nil → acc
      | Cons h t → self t (Cons h acc)
    }

let tokenize : Nat → Nat → List Token
  = λ content len → list_reverse_go (tokenize_go content len 0 Nil) Nil

-- ---------------------------------------------------------------------------
-- Parser: precedence-climbing recursive descent over List Token.
-- Each parse_* returns Pair Expr (List Token) — the expression and the
-- remaining tokens. Errors propagate as EErr.
-- ---------------------------------------------------------------------------

-- parse_factor: TkNum | '(' expr ')'. Threads `pe` (parse_expr) for the
-- paren branch to break pseudo-mutual recursion, per the restricted-
-- dialect pass-self pattern.
let parse_factor
      : (List Token → Pair Expr (List Token))
      → List Token → Pair Expr (List Token)
  = λ pe toks → match toks {
      | Nil → MkPair EErr Nil
      | Cons h t → match h {
          | TkNum n → MkPair (EConst n) t
          | TkLParen → match (pe t) {
              | MkPair e rest → match rest {
                  | Cons h2 t2 → match h2 {
                      | TkRParen → MkPair e t2
                      | _ → MkPair EErr rest
                    }
                  | Nil → MkPair EErr Nil
                }
            }
          | _ → MkPair EErr toks
        }
    }

-- parse_pow: factor ('^' parse_pow)?.  Right-associative — `2^3^2` is
-- `2^(3^2)` = 512, matching standard math convention.  We recurse into
-- parse_pow on the right rather than looping, so the deepest `^` binds
-- first.  Note: '^' here is exponentiation, not bitwise XOR; the demo
-- evaluates over Nat with no negative or boolean interpretation.
let parse_pow
      : (List Token → Pair Expr (List Token))
      → List Token → Pair Expr (List Token)
  = fix λ self pe toks → match (parse_factor pe toks) {
      | MkPair lhs rest → match rest {
          | Nil → MkPair lhs Nil
          | Cons h t → match h {
              | TkCaret → match (self pe t) {
                  | MkPair rhs rest2 → MkPair (EPow lhs rhs) rest2
                }
              | _ → MkPair lhs rest
            }
        }
    }

-- parse_term_loop: pow (('*' | '/') pow)* loop body. `pe` is the
-- pass-self for the paren branch — restricted dialect doesn't capture
-- outer-lambda params through nested `fix`, so we thread it explicitly.
let parse_term_loop
      : (List Token → Pair Expr (List Token))
      → Expr → List Token → Pair Expr (List Token)
  = fix λ self pe lhs rest → match rest {
      | Nil → MkPair lhs Nil
      | Cons h t → match h {
          | TkStar → match (parse_pow pe t) {
              | MkPair rhs rest2 → self pe (EMul lhs rhs) rest2
            }
          | TkSlash → match (parse_pow pe t) {
              | MkPair rhs rest2 → self pe (EDiv lhs rhs) rest2
            }
          | _ → MkPair lhs rest
        }
    }

-- parse_term: pow (('*' | '/') pow)*.
let parse_term
      : (List Token → Pair Expr (List Token))
      → List Token → Pair Expr (List Token)
  = λ pe toks → match (parse_pow pe toks) {
      | MkPair lhs rest → parse_term_loop pe lhs rest
    }

-- parse_expr_loop: term (('+' | '-') term)*. `pe` here is the parse_expr
-- self-reference, threaded explicitly for the same reason as
-- parse_term_loop.
let parse_expr_loop
      : (List Token → Pair Expr (List Token))
      → Expr → List Token → Pair Expr (List Token)
  = fix λ self pe lhs rest → match rest {
      | Nil → MkPair lhs Nil
      | Cons h t → match h {
          | TkPlus → match (parse_term pe t) {
              | MkPair rhs rest2 → self pe (EAdd lhs rhs) rest2
            }
          | TkMinus → match (parse_term pe t) {
              | MkPair rhs rest2 → self pe (ESub lhs rhs) rest2
            }
          | _ → MkPair lhs rest
        }
    }

-- parse_expr: top of the precedence chain. `self` (the parse_expr fix
-- self-reference) flows down as the `pe` arg of parse_factor's paren
-- branch, closing the recursion.
let parse_expr : List Token → Pair Expr (List Token)
  = fix λ self toks → match (parse_term self toks) {
      | MkPair lhs rest → parse_expr_loop self lhs rest
    }

-- parse: tokens → Expr. Discards trailing tokens silently — the REPL
-- treats any remainder as a successful parse of the prefix.
let parse : List Token → Expr
  = λ toks → match (parse_expr toks) {
      | MkPair e _ → e
    }

-- ---------------------------------------------------------------------------
-- Evaluator: tree-walking, division-by-zero → EvErr.
-- ---------------------------------------------------------------------------

-- pow_loop: tail-recursive accumulator.  `n^k = pow_loop 1 n k`.  Each
-- step multiplies acc by base and decrements k.  Reaver has no Pow
-- primop (declared in boot.plan but unimplemented in Plan.hs), so this
-- builds the operation out of BPLAN.mul.  Cost is O(k) multiplications;
-- for the calc REPL's use case (small integer exponents) that's fine.
let pow_loop : Nat → Nat → Nat → Nat
  = fix λ self acc base k → match k {
      | 0 → acc
      | _ → self (BPLAN.mul acc base) base (BPLAN.sub k 1)
    }

-- pow n k: n raised to the k-th power.  By convention `0^0 = 1` and
-- `n^0 = 1` for all n; this falls out of the accumulator seed of 1.
let pow : Nat → Nat → Nat
  = λ n k → pow_loop 1 n k

let eval : Expr → EvalResult
  = fix λ self e → match e {
      | EConst n → EvOk n
      | EAdd a b → match (self a) {
          | EvErr → EvErr
          | EvOk x → match (self b) {
              | EvErr → EvErr
              | EvOk y → EvOk (BPLAN.add x y)
            }
        }
      | ESub a b → match (self a) {
          | EvErr → EvErr
          | EvOk x → match (self b) {
              | EvErr → EvErr
              | EvOk y → EvOk (BPLAN.sub x y)
            }
        }
      | EMul a b → match (self a) {
          | EvErr → EvErr
          | EvOk x → match (self b) {
              | EvErr → EvErr
              | EvOk y → EvOk (BPLAN.mul x y)
            }
        }
      | EDiv a b → match (self a) {
          | EvErr → EvErr
          | EvOk x → match (self b) {
              | EvErr → EvErr
              | EvOk y → match y {
                  | 0 → EvErr
                  | _ → EvOk (BPLAN.div x y)
                }
            }
        }
      | EPow a b → match (self a) {
          | EvErr → EvErr
          | EvOk x → match (self b) {
              | EvErr → EvErr
              | EvOk y → EvOk (pow x y)
            }
        }
      | EErr → EvErr
    }

-- ---------------------------------------------------------------------------
-- Output: render an EvalResult as a nat suitable for `Reaver.RPLAN.output`.
-- The output nat uses Reaver's bytesBar encoding — content bytes packed
-- little-endian (byte 0 = first character) with a length-marker bit set
-- one position past the last content byte. Without that marker, Reaver's
-- `natBytes` reader treats the topmost byte as the marker and drops it,
-- truncating the trailing newline. The seed `(1 << 8) | 0x0A` = 0x10A
-- starts every render with marker-after-newline, which lsh-shifts upward
-- as digits are prepended.
-- ---------------------------------------------------------------------------

-- nat_render_go: build the bytes for a positive Nat, byte 0 = first digit.
-- `acc` starts with marker | trailing-newline; each step left-shifts by
-- one byte (marker rises with it) and prepends a digit byte.
let nat_render_go : Nat → Nat → Nat
  = fix λ self n acc → match n {
      | 0 → acc
      | _ → self (BPLAN.div n 10)
                 (BPLAN.add (BPLAN.lsh acc 8) (BPLAN.add 48 (nat_mod n 10)))
    }

-- render_ok n: bytes representing decimal-rendered n followed by '\n',
-- with the bytesBar length-marker set. Special-cases n=0 → "0\n".
let render_ok : Nat → Nat
  = λ n → match n {
      -- "0\n": bytes 0x30 0x0A; marker at position 16 → 0x1_0A30.
      | 0 → BPLAN.add (BPLAN.lsh 1 16)
                      (BPLAN.add (BPLAN.lsh 10 8) 48)
      -- digits ... '\n' with marker; seed acc = (1<<8) | 10 = 0x10A.
      | _ → nat_render_go n (BPLAN.add (BPLAN.lsh 1 8) 10)
    }

-- render_err: bytes "err\n" with marker. Content: 0x0A_72_72_65,
-- length 4 → marker at position 32 → 0x1_0A727265.
let render_err : Nat
  = BPLAN.add (BPLAN.lsh 1 32)                      -- marker bit
      (BPLAN.add 101                                 -- 'e'
        (BPLAN.add (BPLAN.lsh 114 8)                 -- 'r' << 8
          (BPLAN.add (BPLAN.lsh 114 16)              -- 'r' << 16
                     (BPLAN.lsh 10  24))))           -- '\n' << 24

let render : EvalResult → Nat
  = λ r → match r {
      | EvOk n → render_ok n
      | EvErr  → render_err
    }

-- banner: startup line "gallowglass calc -- ops: + - * / ^ ( )\n"
-- (39 bytes pure ASCII).  Pre-computed as the bytesBar-encoded nat —
-- bytes packed little-endian (byte 0 = first character) with the
-- length-marker bit set at position 312.  Embedded as a decimal literal
-- rather than a chain of BPLAN ops because the byte count makes a
-- nested-add tower unwieldy; the comment shows the source text and the
-- helper invocation that produced the constant.
--
--   python3 -c "s='gallowglass calc -- ops: + - * / ^ ( )\n'; \
--     b=s.encode(); print(int.from_bytes(b,'little')|(1<<(len(b)*8)))"
let banner : Nat
  = 8674861012264874464982291786170712127760553755613318012354086273863761094284939518916432781671

-- prompt: bytes for the input prompt "Ᵹ» " (UTF-8: EA 9D BD C2 BB 20)
-- with the bytesBar marker bit set at byte 6.  Layout:
--   byte 0 0xEA  - "Ᵹ" U+A77D (LATIN CAPITAL LETTER INSULAR G), UTF-8 byte 0
--   byte 1 0x9D  - "Ᵹ" UTF-8 byte 1
--   byte 2 0xBD  - "Ᵹ" UTF-8 byte 2
--   byte 3 0xC2  - "»" U+00BB (RIGHT-POINTING DOUBLE ANGLE QUOTATION MARK), UTF-8 byte 0
--   byte 4 0xBB  - "»" UTF-8 byte 1
--   byte 5 0x20  - ' '
--   marker @ 48
let prompt : Nat
  = BPLAN.add (BPLAN.lsh 1 48)                      -- marker bit
      (BPLAN.add 234                                 -- 0xEA
        (BPLAN.add (BPLAN.lsh 157 8)                 -- 0x9D
          (BPLAN.add (BPLAN.lsh 189 16)              -- 0xBD
            (BPLAN.add (BPLAN.lsh 194 24)            -- 0xC2
              (BPLAN.add (BPLAN.lsh 187 32)          -- 0xBB
                         (BPLAN.lsh 32  40))))))     -- ' '

-- ---------------------------------------------------------------------------
-- REPL loop: read input → tokenize → drain expressions → recurse.
-- An input length of 0 means EOF; the loop terminates by returning 0.
-- ---------------------------------------------------------------------------
--
-- A single `Input 1024` call returns whatever bytes are buffered on
-- stdin — typically multiple newline-separated expressions in one
-- chunk under non-interactive piping. `process_tokens` parses
-- expressions out of the token list one at a time, evaluating and
-- outputting each, until the list is exhausted (or a parse error
-- breaks the inner loop). Then `repl_step` recurses for the next
-- input chunk.
--
-- The `BPLAN.seq` calls are load-bearing: a plain `match … { | _ →
-- ... }` shape with a single wildcard arm lets the codegen elide
-- the scrutinee evaluation as dead code, killing the `output` side
-- effect. `seq` forces its first argument's evaluation explicitly,
-- producing a use-site the optimisation can't drop.

-- handle_one: render+output one eval result; return 0 to break the
-- inner loop on EvErr, 1 to continue. Matching on EvalResult (which
-- has exactly two constructors, both explicit) routes via
-- _compile_adt_dispatch and avoids the all-nullary wildcard codegen
-- path.
let handle_one : EvalResult → Nat
  = λ r → match r {
      | EvErr → BPLAN.seq (RPLAN.output render_err) 0
      | EvOk _ → BPLAN.seq (RPLAN.output (render r)) 1
    }

-- process_tokens: drain expressions from a token list, output each.
let process_tokens : List Token → Nat
  = fix λ self toks → match toks {
      | Nil → 0
      | Cons _ _ → match (parse_expr toks) {
          | MkPair e rest → match (handle_one (eval e)) {
              | 0 → 0   -- break on parse / eval error
              | _ → self rest
            }
        }
    }

-- repl_step: process one input chunk. Pass-self threads the outer
-- recursion target so we can avoid body-let forms (which Reaver's
-- Plan-Asm parser doesn't recognise as let bindings).
let repl_step
      : (Nat → Nat) → Nat → Nat → Nat
  = λ self len content → match len {
      | 0 → 0   -- EOF
      | _ → BPLAN.seq (process_tokens (tokenize content len))
                      (self 0)
    }

-- Print the system prompt before each `Input` read.  The trailing prompt
-- printed at EOF is harmless (the process exits immediately after).  The
-- `BPLAN.seq` keeps the prompt's side-effect from being elided.
let repl : Nat → Nat
  = fix λ self _ →
      BPLAN.seq (RPLAN.output prompt)
        (match (decode_input (RPLAN.input 1024)) {
          | MkPair len content → repl_step self len content
        })

-- main : Nat → Nat — Reaver applies main to the strNat-encoded CLI args
-- (we ignore them) and forces the result. The return value is unused.
-- The startup banner fires once before entering the REPL loop.
let main : Nat → Nat
  = λ _ → BPLAN.seq (RPLAN.output banner) (repl 0)
